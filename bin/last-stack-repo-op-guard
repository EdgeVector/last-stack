#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: last-stack-repo-op-guard <candidate-repo> [workspace-root]

Resolve a repo operation target to a concrete Git checkout root. Rejects an
aggregate workspace/container root before agents run repo-scoped git or gh
commands from the wrong directory.
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

candidate="${1:-}"
workspace="${2:-${LAST_STACK_WORKSPACE_ROOT:-}}"

if [ -z "$candidate" ]; then
  echo "LAST_STACK_REPO_OP_GUARD: missing candidate repo path" >&2
  usage
  exit 2
fi

physical_path() {
  local path="$1"
  if [ -d "$path" ]; then
    (cd "$path" >/dev/null 2>&1 && pwd -P) || return 1
    return
  fi
  return 1
}

candidate_physical="$(physical_path "$candidate" || true)"
workspace_physical=""
if [ -n "$workspace" ]; then
  workspace_physical="$(physical_path "$workspace" || true)"
fi

if [ -n "$workspace_physical" ] && [ "$candidate_physical" = "$workspace_physical" ]; then
  echo "LAST_STACK_REPO_OP_GUARD: refusing aggregate workspace root: $candidate" >&2
  echo "Select a child checkout such as $workspace/<repo> before running repo-scoped git/gh commands." >&2
  exit 2
fi

if [ -z "$candidate_physical" ]; then
  echo "LAST_STACK_REPO_OP_GUARD: path is not a directory: $candidate" >&2
  exit 2
fi

if ! repo_root="$(git -C "$candidate_physical" rev-parse --show-toplevel 2>/dev/null)"; then
  echo "LAST_STACK_REPO_OP_GUARD: path is not a Git checkout: $candidate" >&2
  echo "If this is a workspace container, select a concrete child checkout first." >&2
  exit 2
fi

repo_root="$(physical_path "$repo_root")"

if [ -n "$workspace_physical" ] && [ "$repo_root" = "$workspace_physical" ]; then
  echo "LAST_STACK_REPO_OP_GUARD: resolved target is the aggregate workspace root: $repo_root" >&2
  echo "Select a child checkout before running repo-scoped git/gh commands." >&2
  exit 2
fi

printf '%s\n' "$repo_root"
