#!/usr/bin/env bash
# WORKTREES-ONLY (Tom 2026-07-22 won't-undo).
# Reject Git writes from ambient workspace checkouts under ~/code/edgevector/<repo>.
# Those paths are browse / fetch / object-store only. All feature work must use a
# linked worktree (typically under ~/.fkanban/worktrees). Linked worktrees use a
# .git *file* and are allowed.
set -euo pipefail

action="${1:-write}"
workspace="${LAST_STACK_SHARED_WORKSPACE:-$HOME/code/edgevector}"
top="$(git rev-parse --show-toplevel 2>/dev/null || true)"

[ -n "$top" ] || exit 0
top="$(cd "$top" && pwd -P)"
workspace="$(cd "$workspace" 2>/dev/null && pwd -P || printf '%s' "$workspace")"

# Only an immediate child with a real .git *directory* is an ambient checkout.
# Linked worktrees have a .git *file* and are the required place for changes.
[ "$(dirname "$top")" = "$workspace" ] || exit 0
[ -d "$top/.git" ] || exit 0

if [ "${LAST_STACK_ALLOW_SHARED_CHECKOUT_WRITE:-0}" = "1" ]; then
  exit 0
fi

branch="$(git -C "$top" branch --show-current 2>/dev/null || true)"
printf 'BLOCKED_SHARED_CHECKOUT action=%s repo=%s branch=%s\n' \
  "$action" "$(basename "$top")" "${branch:-detached}" >&2
printf 'WORKTREES_ONLY: ambient ~/code/edgevector/<repo> is not a work surface.\n' >&2
printf 'Create/use an isolated worktree, then retry:\n' >&2
printf '  git -C ~/code/edgevector/%s fetch <gate-remote> main\n' "$(basename "$top")" >&2
printf '  git -C ~/code/edgevector/%s worktree add ~/.fkanban/worktrees/<slug> -b kanban/<slug> <gate>/main\n' "$(basename "$top")" >&2
printf '  # or: git worktree add under WORKTREES_DIR outside the shared tree\n' >&2
printf 'Emergency override (audited, Tom-only recovery): LAST_STACK_ALLOW_SHARED_CHECKOUT_WRITE=1\n' >&2
printf 'Do not use git commit --no-verify / push --no-verify to bypass this policy.\n' >&2
exit 1
