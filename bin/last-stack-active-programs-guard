#!/usr/bin/env python3
"""Guard active-programs rewrites against silent section loss."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path
from typing import Optional


HEADER_RE = re.compile(r"^##\s+(\d+)\.\s+(.+)$", re.MULTILINE)
ANY_PROGRAM_HEADER_RE = re.compile(r"##\s+\d+\.\s+")
PROGRAM_SLUG_RE = re.compile(r"\*\*program-slug:\*\*\s*`\[\[([^]]+)\]\]`")
REFERENCE_SLUG_RE = re.compile(r"\[\[([^]]+)\]\]")
BACKTICK_SLUG_RE = re.compile(r"`([a-z0-9][a-z0-9-]{2,})`")
ROLLUP_CARDS_RE = re.compile(r"^cards:\s*(.+)$", re.MULTILINE)
CLOSED_MARKERS = (
    "✅",
    "closed",
    "complete",
    "retired",
    "prod cutover shipped",
    "dev capstone landed",
)
LIVE_COLUMNS = {"todo", "doing"}
STALE_COLUMNS = {"done"}
ACTIVE_SECTION_MARKER_RE = re.compile(
    r"\b(reopened|re-opened|active|live|next move|first todo|in-flight|in flight|todo|doing)\b",
    re.IGNORECASE,
)
ACTIVE_CUE_RE = re.compile(
    r"\b(next move|live|first todo|todo|doing|in-flight|in flight|ready|current)\b",
    re.IGNORECASE,
)


def read_text(path: str) -> str:
    return Path(path).read_text(encoding="utf-8")


def fail(message: str) -> None:
    print(f"active-programs guard failed: {message}", file=sys.stderr)
    raise SystemExit(1)


def embedded_headers(body: str) -> list[str]:
    lines: list[str] = []
    for match in ANY_PROGRAM_HEADER_RE.finditer(body):
        if match.start() == 0 or body[match.start() - 1] == "\n":
            continue
        line_start = body.rfind("\n", 0, match.start()) + 1
        line_end = body.find("\n", match.start())
        if line_end == -1:
            line_end = len(body)
        lines.append(body[line_start:line_end][:160])
    return lines


def canonical_headers(body: str) -> list[tuple[str, str]]:
    return [(match.group(1), match.group(2).strip()) for match in HEADER_RE.finditer(body)]


def program_slugs(body: str) -> set[str]:
    return set(PROGRAM_SLUG_RE.findall(body))


def reference_slugs(body: str) -> set[str]:
    return set(REFERENCE_SLUG_RE.findall(body))


def backtick_slugs(body: str) -> set[str]:
    return set(BACKTICK_SLUG_RE.findall(body))


def rollup_card_slugs(body: str) -> set[str]:
    slugs: set[str] = set()
    for match in ROLLUP_CARDS_RE.finditer(body):
        for part in match.group(1).split(","):
            slug = part.strip().removesuffix(" (gone)").strip()
            if re.fullmatch(r"[a-z0-9][a-z0-9-]*", slug):
                slugs.add(slug)
    return slugs


def section_card_ref_sources(section: str) -> dict[str, set[str]]:
    sources: dict[str, set[str]] = {}
    for source, refs in [
        ("wiki", reference_slugs(section)),
        ("backtick", backtick_slugs(section)),
        ("rollup", rollup_card_slugs(section)),
    ]:
        for slug in refs - program_slugs(section):
            sources.setdefault(slug, set()).add(source)
    return sources


def card_entries(value: object) -> list[dict[str, object]]:
    if isinstance(value, list):
        return [item for item in value if isinstance(item, dict)]
    if not isinstance(value, dict):
        return []
    if isinstance(value.get("cards"), list):
        return [item for item in value["cards"] if isinstance(item, dict)]
    entries: list[dict[str, object]] = []
    for key, item in value.items():
        if isinstance(item, list):
            for card in item:
                if isinstance(card, dict):
                    entries.append({**card, "column": str(card.get("column") or key)})
        elif isinstance(item, dict):
            slug = item.get("slug") or key
            entries.append({**item, "slug": slug})
    return entries


def load_board_cards(board_path: str) -> dict[str, dict[str, object]]:
    raw = json.loads(read_text(board_path))
    cards: dict[str, dict[str, object]] = {}
    for card in card_entries(raw):
        slug = card.get("slug")
        column = card.get("column")
        if isinstance(slug, str) and isinstance(column, str):
            cards[slug] = card
    return cards


def load_board_columns(board_path: str) -> dict[str, str]:
    return {
        slug: str(card["column"])
        for slug, card in load_board_cards(board_path).items()
        if isinstance(card.get("column"), str)
    }


def load_proof_slugs(path: Optional[str]) -> set[str]:
    if not path:
        return set()
    text = read_text(path)
    if not text.strip():
        return set()
    try:
        raw = json.loads(text)
    except json.JSONDecodeError:
        return set(re.findall(r"[a-z0-9][a-z0-9-]{2,}", text))
    if isinstance(raw, list):
        return {item for item in raw if isinstance(item, str)}
    if isinstance(raw, dict):
        return {key for key, value in raw.items() if value and isinstance(key, str)}
    return set()


def check_rewrite(before_path: str, after_path: str, completed_after_path: str | None = None) -> None:
    before = read_text(before_path)
    after = read_text(after_path)
    completed_after = read_text(completed_after_path) if completed_after_path else ""

    embedded = embedded_headers(after)
    if embedded:
        fail(f"embedded program header not at line start: {embedded[0]}")

    before_headers = canonical_headers(before)
    after_headers = canonical_headers(after)
    before_slugs = program_slugs(before)
    after_slugs = program_slugs(after)
    completed_slugs = reference_slugs(completed_after)
    missing = before_slugs - after_slugs
    unarchived_missing = sorted(missing - completed_slugs)

    if len(after_headers) < len(before_headers):
        dropped = len(before_headers) - len(after_headers)
        if not completed_after_path or dropped > len(missing) or not missing <= completed_slugs:
            fail(f"program header count dropped from {len(before_headers)} to {len(after_headers)}")

    if unarchived_missing:
        fail("program slugs disappeared: " + ", ".join(unarchived_missing))

    print(
        "active-programs guard ok: "
        f"headers {len(before_headers)} -> {len(after_headers)}, "
        f"program slugs {len(before_slugs)} -> {len(after_slugs)}"
        + (f", archived {len(missing)}" if missing else "")
    )


def split_sections(body: str) -> tuple[str, list[tuple[str, str, str]]]:
    matches = list(HEADER_RE.finditer(body))
    if not matches:
        return body, []

    preamble = body[: matches[0].start()]
    sections: list[tuple[str, str, str]] = []
    for idx, match in enumerate(matches):
        end = matches[idx + 1].start() if idx + 1 < len(matches) else len(body)
        sections.append((match.group(1), match.group(2).strip(), body[match.start() : end].strip()))
    return preamble, sections


def is_closed_section(title: str) -> bool:
    title_lower = title.lower()
    return any(marker in title_lower for marker in CLOSED_MARKERS)


def has_active_board_state(title: str, section: str) -> bool:
    return ACTIVE_SECTION_MARKER_RE.search(f"{title}\n{section}") is not None


def is_held_card(card: dict[str, object]) -> bool:
    column = str(card.get("column") or "")
    block_status = str(card.get("block_status") or "").strip().lower()
    block_reason = str(card.get("block_reason") or "").strip()
    if column != "backlog":
        return False
    return bool(block_reason) or block_status not in {"", "none", "unblocked"}


def section_cue(section: str, slugs: set[str]) -> str:
    for line in section.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("<!--") or stripped.startswith("**Status (auto):"):
            continue
        if any(slug in stripped for slug in slugs) and ACTIVE_CUE_RE.search(stripped):
            return stripped[:180]
    for line in section.splitlines():
        stripped = line.strip()
        if stripped and ACTIVE_CUE_RE.search(stripped):
            return stripped[:180]
    return "section has active/live wording"


def suggested_fix(state: str, stale_refs: list[str], held_refs: list[str], live_refs: list[str]) -> str:
    if state == "drained":
        return "archive done row or clear stale next move"
    if held_refs and not stale_refs:
        return "mark prose blocked/held or move next move to a ready card"
    if live_refs:
        return "clear stale refs and advance prose to the live card"
    if held_refs:
        return "archive done refs and mark held refs as blocked"
    return "clear stale next move"


def archive_line(title: str, section: str) -> str:
    slug_match = PROGRAM_SLUG_RE.search(section)
    if slug_match:
        return f"- [[{slug_match.group(1)}]] - {title}"
    return f"- {title}"


def archive_closed(active_path: str, completed_path: str, active_out: str, completed_out: str) -> None:
    active = read_text(active_path)
    completed = Path(completed_path).read_text(encoding="utf-8") if Path(completed_path).exists() else ""

    embedded = embedded_headers(active)
    if embedded:
        fail(f"input has embedded program header not at line start: {embedded[0]}")

    preamble, sections = split_sections(active)
    if not sections:
        fail("no canonical program sections found")

    kept: list[str] = []
    archived: list[str] = []
    for _ordinal, title, section in sections:
        if is_closed_section(title) and not has_active_board_state(title, section):
            line = archive_line(title, section)
            if line not in completed:
                archived.append(line)
        else:
            kept.append(section)

    if not archived:
        fail("no closed program sections found to archive")

    new_active = "\n\n".join(part for part in [preamble.strip(), *kept] if part).rstrip() + "\n"
    archive_block = "## Completed programs archive\n\n" + "\n".join(archived) + "\n"
    new_completed = (completed.rstrip() + "\n\n" if completed.strip() else "") + archive_block

    Path(active_out).write_text(new_active, encoding="utf-8")
    Path(completed_out).write_text(new_completed, encoding="utf-8")
    print(f"archived {len(archived)} closed program section(s)")


def stale_report(active_path: str, board_path: str, proof_slugs_path: Optional[str] = None) -> int:
    active = read_text(active_path)
    board_cards = load_board_cards(board_path)
    proof_slugs = load_proof_slugs(proof_slugs_path)
    _preamble, sections = split_sections(active)
    reports: list[str] = []

    for _ordinal, title, section in sections:
        ref_sources = section_card_ref_sources(section)
        if not ref_sources:
            continue

        live_refs: list[str] = []
        stale_refs: list[str] = []
        held_refs: list[str] = []
        unknown_refs: list[str] = []
        for slug in sorted(ref_sources):
            card = board_cards.get(slug)
            column = str(card.get("column")) if card else None
            if column in LIVE_COLUMNS:
                live_refs.append(f"{slug} ({column})")
            elif column in STALE_COLUMNS:
                stale_refs.append(f"{slug} ({column})")
            elif card and is_held_card(card):
                block_status = str(card.get("block_status") or "held")
                held_refs.append(f"{slug} ({column}, {block_status})")
            elif slug in proof_slugs:
                stale_refs.append(f"{slug} (gone, proof)")
            elif column is None and "rollup" in ref_sources[slug]:
                stale_refs.append(f"{slug} (gone)")
            elif column is None:
                unknown_refs.append(f"{slug} (gone?)")
            else:
                unknown_refs.append(f"{slug} ({column})")

        if not stale_refs and not held_refs:
            continue

        state = "mixed"
        if not live_refs and not unknown_refs and not held_refs:
            state = "drained"
        elif held_refs and not live_refs and not unknown_refs and not stale_refs:
            state = "held"
        program = sorted(program_slugs(section))
        prefix = f"{title}"
        if program:
            prefix += f" [{program[0]}]"
        cue = section_cue(section, set(ref_sources))
        detail = "; ".join(
            part
            for part in [
                f"cue: {cue}",
                f"stale: {', '.join(stale_refs)}",
                f"held: {', '.join(held_refs)}" if held_refs else "",
                f"live: {', '.join(live_refs)}" if live_refs else "",
                f"unknown: {', '.join(unknown_refs)}" if unknown_refs else "",
                f"suggested fix: {suggested_fix(state, stale_refs, held_refs, live_refs)}",
            ]
            if part
        )
        reports.append(f"- {prefix}: {state}; {detail}")

    if not reports:
        print("stale active-program references: none")
        return 0

    print("stale active-program references:")
    print("\n".join(reports))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    check = subparsers.add_parser("check", help="fail if an active-programs rewrite lost sections")
    check.add_argument("before")
    check.add_argument("after")
    check.add_argument(
        "--completed-after",
        help="completed-programs body after an intentional archive move",
    )

    archive = subparsers.add_parser("archive-closed", help="split closed sections into completed archive")
    archive.add_argument("--active", required=True)
    archive.add_argument("--completed", required=True)
    archive.add_argument("--active-out", required=True)
    archive.add_argument("--completed-out", required=True)

    stale = subparsers.add_parser(
        "stale-report",
        help="report active-program sections that still reference done, gone, or held board cards",
    )
    stale.add_argument("--active", required=True)
    stale.add_argument(
        "--board",
        required=True,
        help="JSON from kanban list/show aggregation; only slug and column are required",
    )
    stale.add_argument(
        "--proof-slugs",
        help="optional file containing slugs with external proof for gone cards",
    )

    args = parser.parse_args()
    if args.command == "check":
        check_rewrite(args.before, args.after, args.completed_after)
    elif args.command == "archive-closed":
        archive_closed(args.active, args.completed, args.active_out, args.completed_out)
    elif args.command == "stale-report":
        return stale_report(args.active, args.board, args.proof_slugs)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
