#!/usr/bin/env bash
# Resolve dogfood recipe checkouts to current, clean isolated checkouts.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
FRESHNESS="$ROOT/bin/last-stack-git-checkout-freshness"

usage() {
  cat <<'EOF'
Usage:
  last-stack-dogfood-target-checkout <repo> [<repo>...]

For each recipe target checkout, prints:
  TARGET <non-mutating freshness report for the recipe target>
  SELECTED <non-mutating freshness report for the checkout to use>
  RESULT input=<repo> selected=<repo> result=<ok|blocker> reason=<reason>

When the recipe target is stale or unknown, this command selects a clean,
fresh sibling git worktree or dedicated dogfood checkout that tracks the same
upstream and exactly matches that remote oid. If needed, it creates or
fast-forwards a clean dedicated checkout under the dogfood target roots. It
never fetches, checks out, rebases, stashes, resets, or cleans the source
target checkout. If no current isolated checkout can be selected or safely
managed, it exits non-zero after reporting a workflow blocker so product
assertions do not run on stale local code.

Additional isolated checkouts are discovered under
LAST_STACK_DOGFOOD_TARGET_ROOTS, a colon-separated list that defaults to
$HOME/.fkanban/dogfood-targets.

Set LAST_STACK_DOGFOOD_TARGET_MANAGE=0 to disable dedicated checkout
create/refresh behavior and report a blocker instead.
EOF
}

quote_field() {
  printf '%s' "$1" | tr '\t\n' '  '
}

field_value() {
  local line="$1"
  local key="$2"
  local part
  local -a parts

  IFS=$'\t' read -r -a parts <<< "$line"
  for part in "${parts[@]}"; do
    if [[ "$part" == "$key="* ]]; then
      printf '%s' "${part#*=}"
      return 0
    fi
  done

  return 1
}

real_path() {
  local path="$1"

  if [ -d "$path" ]; then
    (cd "$path" && pwd -P)
  else
    printf '%s' "$path"
  fi
}

print_blocker() {
  local input="$1"
  local reason="$2"
  local selected="${3:--}"

  printf 'RESULT\tinput=%s\tselected=%s\tresult=blocker\treason=%s\n' \
    "$(quote_field "$input")" "$(quote_field "$selected")" "$reason"
}

print_checkout_remediation() {
  local input="$1"
  local roots="$2"
  local remote_name="$3"
  local remote_url_value="$4"
  local upstream="$5"
  local path branch root

  branch="${upstream#*/}"
  path="$(managed_checkout_path "$roots" "$remote_url_value" "$upstream" || true)"
  if [ -z "$path" ] || [ -e "$path" ]; then
    path="$(managed_checkout_collision_path "$roots" "$remote_url_value" "$upstream" || true)"
  fi

  root="$(first_target_root "$roots" || true)"
  if [ -n "$path" ] && [ ! -e "$path" ]; then
    printf 'REMEDIATION\tinput=%s\taction=create-current-isolated-checkout\tpath=%s\tcommand=git clone --origin %s --branch %s --single-branch %s %s\n' \
      "$(quote_field "$input")" "$(quote_field "$path")" \
      "$(quote_field "$remote_name")" "$(quote_field "$branch")" \
      "$(quote_field "$remote_url_value")" "$(quote_field "$path")"
  elif [ -n "$root" ]; then
    printf 'REMEDIATION\tinput=%s\taction=choose-empty-target-root\troot=%s\tcommand=LAST_STACK_DOGFOOD_TARGET_ROOTS=%s last-stack-dogfood-target-checkout %s\n' \
      "$(quote_field "$input")" "$(quote_field "$root")" \
      "$(quote_field "$root/current")" "$(quote_field "$input")"
  fi
}

add_candidate() {
  local candidate="$1"
  local candidate_real seen seen_real

  [ -n "$candidate" ] || return 0
  candidate_real="$(real_path "$candidate")"
  if [ "${#worktrees[@]}" -gt 0 ]; then
    for seen in "${worktrees[@]}"; do
      seen_real="$(real_path "$seen")"
      if [ "$seen_real" = "$candidate_real" ]; then
        return 0
      fi
    done
  fi

  worktrees+=("$candidate")
}

remote_url() {
  local repo="$1"
  local remote="$2"

  git -C "$repo" remote get-url "$remote" 2>/dev/null || true
}

forge_auth_scope() {
  local url="$1"

  case "$url" in
    http://localhost:3300/*) printf 'http://localhost:3300/' ;;
    http://127.0.0.1:3300/*) printf 'http://127.0.0.1:3300/' ;;
    http://100.109.94.59:3300/*) printf 'http://100.109.94.59:3300/' ;;
  esac
}

git_with_remote_url_auth() {
  local remote_url_value="$1"
  shift
  local scope token auth

  scope="$(forge_auth_scope "$remote_url_value")"
  if [ -n "$scope" ] &&
    token="$(security find-generic-password -s forgejo-token -w 2>/dev/null)"; then
    auth="$(printf 'tom:%s' "$token" | base64 | tr -d '\n')"
    git \
      -c credential.helper= \
      -c "http.${scope}.extraHeader=Authorization: Basic $auth" \
      "$@"
    return
  fi

  git "$@"
}

remote_branch_exists() {
  local repo="$1"
  local remote="$2"
  local remote_url_value="$3"
  local branch="$4"

  git_with_remote_url_auth "$remote_url_value" \
    -C "$repo" ls-remote --exit-code "$remote" "refs/heads/$branch" \
    >/dev/null 2>&1
}

default_remote() {
  local repo="$1"
  local remote

  if git -C "$repo" remote get-url origin >/dev/null 2>&1; then
    printf 'origin'
    return 0
  fi

  remote="$(git -C "$repo" remote | awk 'NR == 1 {print}')"
  [ -n "$remote" ] || return 1
  printf '%s' "$remote"
}

safe_path_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '-'
}

repo_name_from_url() {
  local url="$1"
  local name

  name="${url##*/}"
  name="${name%.git}"
  safe_path_name "$name"
}

is_fold_remote_url() {
  local url="$1"

  case "$url" in
    */EdgeVector/fold|*/EdgeVector/fold.git|*github.com:EdgeVector/fold|*github.com:EdgeVector/fold.git)
      return 0
      ;;
  esac

  return 1
}

remote_slug_from_url() {
  local url="$1"
  local slug

  slug="$(printf '%s' "$url" |
    sed -E \
      -e 's#^[A-Za-z][A-Za-z0-9+.-]*://([^/@]+@)?##' \
      -e 's#^([^@]+@)?([^:]+):#\2/#' \
      -e 's#\.git$##' \
      -e 's#[/:]+#-#g' \
      -e 's#[^A-Za-z0-9._-]#-#g' \
      -e 's#^-+##' \
      -e 's#-+$##')"
  safe_path_name "$slug"
}

first_target_root() {
  local roots="$1"
  local root
  local -a root_list=()

  IFS=':' read -r -a root_list <<< "$roots"
  for root in "${root_list[@]}"; do
    [ -n "$root" ] || continue
    printf '%s' "$root"
    return 0
  done

  return 1
}

managed_checkout_path() {
  local roots="$1"
  local remote_url_value="$2"
  local upstream="$3"
  local root repo_name branch branch_name

  root="$(first_target_root "$roots" || true)"
  [ -n "$root" ] || return 1

  repo_name="$(repo_name_from_url "$remote_url_value")"
  [ -n "$repo_name" ] || return 1

  branch="${upstream#*/}"
  branch_name="$(safe_path_name "$branch")"
  if [ "$branch_name" = "main" ]; then
    printf '%s/%s' "$root" "$repo_name"
  else
    printf '%s/%s-%s' "$root" "$repo_name" "$branch_name"
  fi
}

managed_checkout_collision_path() {
  local roots="$1"
  local remote_url_value="$2"
  local upstream="$3"
  local root remote_slug branch branch_name

  root="$(first_target_root "$roots" || true)"
  [ -n "$root" ] || return 1

  remote_slug="$(remote_slug_from_url "$remote_url_value")"
  [ -n "$remote_slug" ] || return 1

  branch="${upstream#*/}"
  branch_name="$(safe_path_name "$branch")"
  if [ "$branch_name" = "main" ]; then
    printf '%s/%s' "$root" "$remote_slug"
  else
    printf '%s/%s-%s' "$root" "$remote_slug" "$branch_name"
  fi
}

target_management_enabled() {
  [ "${LAST_STACK_DOGFOOD_TARGET_MANAGE:-1}" != "0" ] &&
    [ "${LAST_STACK_DOGFOOD_TARGET_AUTO_MANAGE:-1}" != "0" ]
}

refresh_managed_checkout() {
  local path="$1"
  local target_remote="$2"
  local target_upstream="$3"
  local target_remote_url="$4"
  local branch remote_ref report dirty upstream

  git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 1
  [ "$(remote_url "$path" "$target_remote")" = "$target_remote_url" ] || return 1

  report="$("$FRESHNESS" "$path")"
  dirty="$(field_value "$report" dirty || true)"
  upstream="$(field_value "$report" upstream || true)"
  [ "$dirty" = "no" ] || return 1
  [ "$upstream" = "$target_upstream" ] || return 1

  branch="$(git -C "$path" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  [ "$branch" = "${target_upstream#*/}" ] || return 1

  remote_ref="refs/heads/${target_upstream#*/}"
  git_with_remote_url_auth "$target_remote_url" \
    -C "$path" fetch "$target_remote" "$remote_ref" >/dev/null 2>&1 || return 1
  git -C "$path" merge --ff-only FETCH_HEAD >/dev/null 2>&1 || return 1
}

create_managed_checkout() {
  local path="$1"
  local target_remote="$2"
  local target_upstream="$3"
  local target_remote_url="$4"
  local branch

  [ -e "$path" ] && return 1
  branch="${target_upstream#*/}"
  mkdir -p "$(dirname "$path")"
  git_with_remote_url_auth "$target_remote_url" \
    clone \
    --origin "$target_remote" \
    --branch "$branch" \
    --single-branch \
    "$target_remote_url" \
    "$path" >/dev/null 2>&1
}

ensure_managed_candidate() {
  local roots="$1"
  local target_remote="$2"
  local target_upstream="$3"
  local target_remote_url="$4"
  local path collision_path

  target_management_enabled || return 1
  [ -n "$target_remote_url" ] || return 1

  path="$(managed_checkout_path "$roots" "$target_remote_url" "$target_upstream" || true)"
  [ -n "$path" ] || return 1

  if git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1 &&
    refresh_managed_checkout "$path" "$target_remote" "$target_upstream" "$target_remote_url"; then
    printf '%s' "$path"
    return 0
  elif [ -e "$path" ]; then
    collision_path="$(managed_checkout_collision_path "$roots" "$target_remote_url" "$target_upstream" || true)"
    [ -n "$collision_path" ] || return 1
    [ "$collision_path" != "$path" ] || return 1
    path="$collision_path"
  fi

  if git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    refresh_managed_checkout "$path" "$target_remote" "$target_upstream" "$target_remote_url" || return 1
    printf '%s' "$path"
    return 0
  fi

  create_managed_checkout "$path" "$target_remote" "$target_upstream" "$target_remote_url" || return 1
  printf '%s' "$path"
}

try_select_candidate() {
  local target="$1"
  local target_real="$2"
  local target_remote="$3"
  local target_remote_url="$4"
  local target_upstream="$5"
  local candidate="$6"
  local candidate_real candidate_report candidate_result candidate_dirty
  local candidate_upstream candidate_head candidate_remote_upstream

  candidate_real="$(real_path "$candidate")"
  if [ "$candidate_real" = "$target_real" ]; then
    return 1
  fi

  if [ -n "$target_remote_url" ] &&
    [ "$(remote_url "$candidate" "$target_remote")" != "$target_remote_url" ]; then
    return 1
  fi

  candidate_report="$("$FRESHNESS" "$candidate")"
  candidate_result="$(field_value "$candidate_report" result || true)"
  candidate_dirty="$(field_value "$candidate_report" dirty || true)"
  candidate_upstream="$(field_value "$candidate_report" upstream || true)"
  candidate_head="$(field_value "$candidate_report" head || true)"
  candidate_remote_upstream="$(field_value "$candidate_report" remote_upstream || true)"

  if [ "$candidate_result" = "fresh" ] &&
    [ "$candidate_dirty" = "no" ] &&
    [ "$candidate_upstream" = "$target_upstream" ] &&
    [ "$candidate_head" = "$candidate_remote_upstream" ]; then
    printf 'SELECTED\t%s\n' "$candidate_report"
    printf 'RESULT\tinput=%s\tselected=%s\tresult=ok\treason=current-isolated-checkout\n' \
      "$(quote_field "$target")" "$(quote_field "$candidate")"
    return 0
  fi

  return 1
}

select_for_target() {
  local target="$1"
  local target_report target_path target_result target_dirty target_upstream target_reason
  local target_real candidate managed_candidate
  local target_remote target_remote_url
  local roots root git_entry repo_path
  local -a worktrees=()
  local -a root_list=()

  target_report="$("$FRESHNESS" "$target")"
  printf 'TARGET\t%s\n' "$target_report"

  target_result="$(field_value "$target_report" result || true)"
  target_dirty="$(field_value "$target_report" dirty || true)"
  target_upstream="$(field_value "$target_report" upstream || true)"
  target_reason="$(field_value "$target_report" reason || true)"
  target_path="$(field_value "$target_report" path || printf '%s' "$target")"

  if ! git -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print_blocker "$target" "target-is-not-a-git-worktree"
    return 1
  fi

  if [ "$target_result" = "fresh" ] && [ "$target_dirty" = "no" ]; then
    printf 'SELECTED\t%s\n' "$target_report"
    printf 'RESULT\tinput=%s\tselected=%s\tresult=ok\treason=recipe-target-current-clean\n' \
      "$(quote_field "$target")" "$(quote_field "$target_path")"
    return 0
  fi

  target_real="$(real_path "$target")"
  if [ -z "$target_upstream" ] || [ "$target_upstream" = "-" ]; then
    target_remote="$(default_remote "$target" || true)"
    target_remote_url="$(remote_url "$target" "$target_remote")"
    if [ -n "$target_remote" ] &&
      [ -n "$target_remote_url" ] &&
      remote_branch_exists "$target" "$target_remote" "$target_remote_url" main; then
      target_upstream="$target_remote/main"
    else
      print_blocker "$target" "target-upstream-unknown"
      return 1
    fi
  else
    target_remote="${target_upstream%%/*}"
    target_remote_url="$(remote_url "$target" "$target_remote")"
    if [ "$target_result" = "unknown" ] &&
      [ "$target_reason" = "remote-upstream-unreadable" ] &&
      [ "$target_dirty" = "no" ] &&
      is_fold_remote_url "$target_remote_url" &&
      remote_branch_exists "$target" "$target_remote" "$target_remote_url" main; then
      target_upstream="$target_remote/main"
    fi
  fi

  while IFS= read -r candidate; do
    add_candidate "$candidate"
  done < <(git -C "$target" worktree list --porcelain | awk '/^worktree / {print substr($0, 10)}')

  roots="${LAST_STACK_DOGFOOD_TARGET_ROOTS:-$HOME/.fkanban/dogfood-targets}"
  IFS=':' read -r -a root_list <<< "$roots"
  for root in "${root_list[@]}"; do
    [ -n "$root" ] || continue
    [ -d "$root" ] || continue
    while IFS= read -r git_entry; do
      repo_path="${git_entry%/.git}"
      add_candidate "$repo_path"
    done < <(find "$root" -maxdepth 4 -name .git -print 2>/dev/null)
  done

  if [ "${#worktrees[@]}" -gt 0 ]; then
    for candidate in "${worktrees[@]}"; do
      if try_select_candidate \
        "$target" "$target_real" "$target_remote" "$target_remote_url" \
        "$target_upstream" "$candidate"; then
        return 0
      fi
    done
  fi

  managed_candidate="$(ensure_managed_candidate \
    "$roots" "$target_remote" "$target_upstream" "$target_remote_url" || true)"
  if [ -n "$managed_candidate" ]; then
    if try_select_candidate \
      "$target" "$target_real" "$target_remote" "$target_remote_url" \
      "$target_upstream" "$managed_candidate"; then
      return 0
    fi
  fi

  print_blocker "$target" "no-current-isolated-checkout"
  print_checkout_remediation "$target" "$roots" "$target_remote" "$target_remote_url" "$target_upstream"
  return 1
}

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 2
fi

exit_code=0
for target in "$@"; do
  if ! select_for_target "$target"; then
    exit_code=1
  fi
done

exit "$exit_code"
