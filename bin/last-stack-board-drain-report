#!/usr/bin/env python3
"""Report F-Kanban board position and pickup drain velocity."""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from collections import Counter
from dataclasses import dataclass, field
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any


COLUMNS = ("backlog", "todo", "doing", "review", "done")
WINDOW_HOURS = (1, 6, 24)
PICKUP_ROUTINE = "kanban-pickup"


@dataclass
class PickupEvent:
    ts: datetime
    routine: str
    outcome: str
    detail: str
    worked: list[str] = field(default_factory=list)
    result: str = ""
    noop_reason: str = ""


def parse_ts(raw: str) -> datetime | None:
    value = raw.strip()
    if not value:
        return None
    if value.endswith("Z"):
        value = value[:-1] + "+00:00"
    try:
        dt = datetime.fromisoformat(value)
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc)


def iso_minute(dt: datetime) -> str:
    return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%MZ")


def run_json(cmd: list[str]) -> Any:
    proc = subprocess.run(cmd, check=False, capture_output=True, text=True)
    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "").strip()
        raise RuntimeError(f"command failed ({proc.returncode}): {' '.join(cmd)}\n{err}")
    text = proc.stdout.strip()
    if not text:
        return []
    return json.loads(text)


def first_executable(candidates: list[str]) -> str | None:
    for candidate in candidates:
        if os.path.isabs(candidate):
            if os.access(candidate, os.X_OK):
                return candidate
            continue
        for path_dir in os.environ.get("PATH", "").split(os.pathsep):
            path = Path(path_dir or ".") / candidate
            if path.is_file() and os.access(path, os.X_OK):
                return candidate
    return None


def load_cards(args: argparse.Namespace) -> list[dict[str, Any]]:
    if args.cards_json:
        data = json.loads(Path(args.cards_json).read_text(encoding="utf-8"))
        if isinstance(data, list):
            return data
        if isinstance(data, dict) and isinstance(data.get("cards"), list):
            return data["cards"]
        raise ValueError(f"unrecognized cards JSON shape in {args.cards_json}")

    board_cmd = os.environ.get("LAST_STACK_KANBAN") or first_executable(["fkanban", "kanban"])
    if not board_cmd:
        raise RuntimeError("fkanban or kanban is required")

    commands = [
        [board_cmd, "list", "--json", "--all"],
        [board_cmd, "list", "--json"],
    ]
    last_err = ""
    for cmd in commands:
        try:
            data = run_json(cmd)
            if isinstance(data, list):
                return data
            if isinstance(data, dict) and isinstance(data.get("cards"), list):
                return data["cards"]
            raise RuntimeError("board list did not return a card list")
        except Exception as exc:  # fall through to the narrower command
            last_err = str(exc)
    raise RuntimeError(last_err or "could not load board cards")


def load_heartbeats(args: argparse.Namespace) -> str:
    if args.heartbeats_file:
        return Path(args.heartbeats_file).read_text(encoding="utf-8")

    brain_cmd = os.environ.get("LAST_STACK_BRAIN") or first_executable(["fbrain", "brain"])
    if not brain_cmd:
        return ""
    try:
        data = run_json([brain_cmd, "get", "routine-heartbeats", "--type", "reference", "--json"])
    except Exception:
        return ""
    if isinstance(data, dict):
        return str(data.get("body") or "")
    return ""


def parse_heartbeat_line(line: str) -> PickupEvent | None:
    m = re.match(r"^(\S+)\s+(\d{4}-\d{2}-\d{2}T\S+)\s+(\S+)\s*(.*)$", line.strip())
    if not m:
        return None
    routine, raw_ts, outcome, detail = m.groups()
    if routine != PICKUP_ROUTINE:
        return None
    ts = parse_ts(raw_ts)
    if not ts:
        return None

    worked: list[str] = []
    worked_match = re.search(r"(?:^|\s)worked=([^ \t]+)", detail)
    if worked_match:
        worked = [part for part in worked_match.group(1).split(",") if part]

    result = ""
    result_match = re.search(r"(?:^|\s)result=([^ \t]+)", detail)
    if result_match:
        result = result_match.group(1)

    noop_reason = ""
    if outcome == "noop":
        reason_match = re.search(r"(?:^|\s)(?:reason|detail)=([^ \t]+)", detail)
        if reason_match:
            noop_reason = reason_match.group(1)
        else:
            noop_reason = detail.split()[0] if detail.split() else "unspecified"

    return PickupEvent(
        ts=ts,
        routine=routine,
        outcome=outcome,
        detail=detail,
        worked=worked,
        result=result,
        noop_reason=noop_reason,
    )


def parse_heartbeats(text: str) -> list[PickupEvent]:
    events: list[PickupEvent] = []
    for line in text.splitlines():
        event = parse_heartbeat_line(line)
        if event:
            events.append(event)
    return events


def load_run_meta(args: argparse.Namespace) -> list[dict[str, Any]]:
    base = Path(args.runs_dir).expanduser()
    if not base.exists():
        return []
    metas: list[dict[str, Any]] = []
    for path in base.glob("last-stack-fkanban-pickup*/**/meta.json"):
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue
        if isinstance(data, dict):
            data["_path"] = str(path)
            metas.append(data)
    return metas


def count_position(cards: list[dict[str, Any]]) -> dict[str, int]:
    counts = Counter(str(card.get("column") or "unknown") for card in cards)
    out = {col: int(counts.get(col, 0)) for col in COLUMNS}
    for col, count in sorted(counts.items()):
        if col not in out:
            out[col] = int(count)
    return out


def summarize_window(
    events: list[PickupEvent],
    metas: list[dict[str, Any]],
    now: datetime,
    hours: int,
) -> dict[str, Any]:
    cutoff = now - timedelta(hours=hours)
    win_events = [event for event in events if event.ts >= cutoff]
    claim_events = [event for event in win_events if event.worked]
    merged_events = [
        event
        for event in claim_events
        if event.result == "merged" or " result=merged" in f" {event.detail}"
    ]
    review_events = [event for event in claim_events if event.result.startswith("review")]
    rolled_back_events = [event for event in claim_events if "rolled-back" in event.result]
    unique_cards = sorted({card for event in claim_events for card in event.worked})
    noop_counts = Counter(event.noop_reason for event in win_events if event.outcome == "noop")

    win_metas: list[dict[str, Any]] = []
    for meta in metas:
        started = parse_ts(str(meta.get("startedAt") or ""))
        if started and started >= cutoff:
            win_metas.append(meta)

    meta_claim_runs = 0
    for meta in win_metas:
        detail = str(meta.get("outcomeDetail") or "")
        if "worked=" in detail or re.search(r"(?:^|\s)cards=[1-9]", detail):
            meta_claim_runs += 1

    return {
        "hours": hours,
        "since": iso_minute(cutoff),
        "heartbeat_wakes": len(win_events),
        "run_meta_wakes": len(win_metas),
        "claim_runs": len(claim_events),
        "meta_claim_runs": meta_claim_runs,
        "unique_cards": len(unique_cards),
        "unique_card_slugs": unique_cards,
        "merged": len(merged_events),
        "review_blocked": len(review_events),
        "rolled_back": len(rolled_back_events),
        "noop_reasons": dict(sorted(noop_counts.items())),
        "claim_rate_per_hour": round(len(claim_events) / hours, 2),
        "merge_rate_per_hour": round(len(merged_events) / hours, 2),
    }


def build_report(
    cards: list[dict[str, Any]],
    events: list[PickupEvent],
    metas: list[dict[str, Any]],
    now: datetime,
) -> dict[str, Any]:
    return {
        "generated_at": iso_minute(now),
        "position": count_position(cards),
        "velocity": [
            summarize_window(events, metas, now, hours) for hours in WINDOW_HOURS
        ],
        "sources": {
            "cards": len(cards),
            "heartbeat_events": len(events),
            "run_meta_events": len(metas),
        },
    }


def render_text(report: dict[str, Any]) -> str:
    lines = [f"Board drain report ({report['generated_at']})", ""]
    position = report["position"]
    ordered = [f"{col}={position.get(col, 0)}" for col in COLUMNS]
    extras = [f"{col}={n}" for col, n in position.items() if col not in COLUMNS]
    lines.append("Position: " + " ".join(ordered + extras))
    lines.append("")
    lines.append("Velocity:")
    for win in report["velocity"]:
        lines.append(
            "  "
            f"{win['hours']}h: wakes={win['heartbeat_wakes']} "
            f"run_meta={win['run_meta_wakes']} "
            f"claim_runs={win['claim_runs']} "
            f"meta_claim_runs={win['meta_claim_runs']} "
            f"unique_cards={win['unique_cards']} "
            f"merged={win['merged']} "
            f"claim_rate/h={win['claim_rate_per_hour']:.2f} "
            f"merge_rate/h={win['merge_rate_per_hour']:.2f}"
        )
        if win["noop_reasons"]:
            reasons = ", ".join(
                f"{reason}:{count}" for reason, count in win["noop_reasons"].items()
            )
            lines.append(f"      noop_reasons={reasons}")
    lines.append("")
    src = report["sources"]
    lines.append(
        "Sources: "
        f"cards={src['cards']} "
        f"heartbeat_events={src['heartbeat_events']} "
        f"run_meta_events={src['run_meta_events']}"
    )
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--cards-json", help="fixture board cards JSON")
    parser.add_argument("--heartbeats-file", help="fixture routine-heartbeats body")
    parser.add_argument(
        "--runs-dir",
        default=os.path.expanduser("~/.routines/runs"),
        help="routines run directory (default: ~/.routines/runs)",
    )
    parser.add_argument(
        "--now",
        help="override current UTC timestamp, e.g. 2026-07-16T10:00:00Z",
    )
    parser.add_argument("--json", action="store_true", help="print JSON instead of text")
    args = parser.parse_args(argv)

    now = parse_ts(args.now) if args.now else datetime.now(timezone.utc)
    if now is None:
        raise SystemExit(f"invalid --now timestamp: {args.now}")

    cards = load_cards(args)
    heartbeats = load_heartbeats(args)
    events = parse_heartbeats(heartbeats)
    metas = load_run_meta(args)
    report = build_report(cards, events, metas, now)

    if args.json:
        json.dump(report, sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
    else:
        print(render_text(report))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
