#!/usr/bin/env bash
# Install / uninstall / status the zero-LLM board-closeout LaunchAgent.
#
# Usage:
#   last-stack-board-closeout-install install|uninstall|status|run-once
set -euo pipefail

self_dir="$(cd "$(dirname "$0")" && pwd -P)"
last_stack="$(cd "$self_dir/.." && pwd -P)"
label="com.edgevector.board-closeout"
plist_src="$last_stack/launchd/${label}.plist"
plist_dst="${BOARD_CLOSEOUT_PLIST:-$HOME/Library/LaunchAgents/${label}.plist}"
uid="$(id -u)"
domain="gui/${uid}"

cmd="${1:-status}"

install_agent() {
  if [ ! -x "$last_stack/bin/last-stack-board-closeout-sweep" ]; then
    chmod +x "$last_stack/bin/last-stack-board-closeout-sweep" 2>/dev/null || true
  fi
  if [ ! -x "$last_stack/bin/last-stack-board-closeout-sweep" ]; then
    echo "missing executable: $last_stack/bin/last-stack-board-closeout-sweep" >&2
    exit 1
  fi
  if [ ! -f "$plist_src" ]; then
    echo "missing plist: $plist_src" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$plist_dst")"
  # Rewrite LAST_STACK paths to this install root and HOME if needed.
  sed \
    -e "s|/Users/tomtang/.last-stack|${last_stack}|g" \
    -e "s|/Users/tomtang|${HOME}|g" \
    "$plist_src" >"$plist_dst"
  # Also ensure ProgramArguments points at this install's sweep binary.
  /usr/libexec/PlistBuddy -c "Set :ProgramArguments:0 ${last_stack}/bin/last-stack-board-closeout-sweep" "$plist_dst" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Set :EnvironmentVariables:LAST_STACK_ROOT ${last_stack}" "$plist_dst" 2>/dev/null || true

  if command -v launchctl >/dev/null 2>&1; then
    launchctl bootout "${domain}/${label}" >/dev/null 2>&1 || true
    if launchctl bootstrap "$domain" "$plist_dst" >/dev/null 2>&1; then
      launchctl enable "${domain}/${label}" >/dev/null 2>&1 || true
      launchctl kickstart -k "${domain}/${label}" >/dev/null 2>&1 || true
      echo "board-closeout: loaded ${label} (every 15m)"
    else
      echo "board-closeout: plist written to $plist_dst (launchctl bootstrap failed)" >&2
    fi
  else
    echo "board-closeout: plist written to $plist_dst (no launchctl)"
  fi
}

uninstall_agent() {
  if command -v launchctl >/dev/null 2>&1; then
    launchctl bootout "${domain}/${label}" >/dev/null 2>&1 || true
  fi
  rm -f "$plist_dst"
  echo "board-closeout: uninstalled ${label}"
}

status_agent() {
  echo "sweep: $last_stack/bin/last-stack-board-closeout-sweep"
  echo "plist: $plist_dst"
  if [ -f "$plist_dst" ]; then
    echo "plist: present"
  else
    echo "plist: missing"
  fi
  if command -v launchctl >/dev/null 2>&1; then
    launchctl print "${domain}/${label}" 2>/dev/null | head -30 || echo "launchctl: not loaded"
  fi
  if [ -f "$HOME/Library/Logs/board-closeout.out.log" ]; then
    echo "--- last log lines ---"
    tail -5 "$HOME/Library/Logs/board-closeout.out.log" 2>/dev/null || true
  fi
}

case "$cmd" in
  install) install_agent ;;
  uninstall) uninstall_agent ;;
  status) status_agent ;;
  run-once)
    exec "$last_stack/bin/last-stack-board-closeout-sweep" "${@:2}"
    ;;
  -h|--help)
    sed -n '2,8p' "$0"
    ;;
  *)
    echo "usage: $0 install|uninstall|status|run-once" >&2
    exit 2
    ;;
esac
