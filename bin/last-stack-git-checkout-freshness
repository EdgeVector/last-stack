#!/usr/bin/env bash
# Report whether Git checkouts are behind their tracked remote without mutating them.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  last-stack-git-checkout-freshness <repo> [<repo>...]

For each checkout, prints one tab-separated record:
  path=<repo> branch=<branch> head=<oid> dirty=<yes|no> upstream=<remote/ref>
  local_upstream=<oid|-> remote_upstream=<oid|-> result=<fresh|stale|unknown>
  reason=<reason>

The command uses local ref inspection plus git ls-remote. It never fetches,
checks out, rebases, stashes, resets, or cleans the target checkout.
EOF
}

quote_field() {
  printf '%s' "$1" | tr '\t\n' '  '
}

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 2
fi

for repo in "$@"; do
  if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'path=%s\tbranch=-\thead=-\tdirty=-\tupstream=-\tlocal_upstream=-\tremote_upstream=-\tresult=unknown\treason=not-a-git-worktree\n' \
      "$(quote_field "$repo")"
    continue
  fi

  head_oid="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"
  branch="$(git -C "$repo" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  [ -n "$branch" ] || branch="DETACHED"

  if [ -n "$(git -C "$repo" status --porcelain=v1 --untracked-files=all 2>/dev/null || true)" ]; then
    dirty="yes"
  else
    dirty="no"
  fi

  if [ "$branch" = "DETACHED" ]; then
    printf 'path=%s\tbranch=%s\thead=%s\tdirty=%s\tupstream=-\tlocal_upstream=-\tremote_upstream=-\tresult=unknown\treason=no-current-branch\n' \
      "$(quote_field "$repo")" "$branch" "$head_oid" "$dirty"
    continue
  fi

  upstream_fields="$(git -C "$repo" for-each-ref \
    --format='%(upstream:remotename)%09%(upstream:remoteref)' \
    "refs/heads/$branch" 2>/dev/null || true)"
  remote_name="$(printf '%s' "$upstream_fields" | awk -F '\t' '{print $1}')"
  remote_ref="$(printf '%s' "$upstream_fields" | awk -F '\t' '{print $2}')"

  if [ -z "$remote_name" ] || [ -z "$remote_ref" ]; then
    printf 'path=%s\tbranch=%s\thead=%s\tdirty=%s\tupstream=-\tlocal_upstream=-\tremote_upstream=-\tresult=unknown\treason=no-upstream\n' \
      "$(quote_field "$repo")" "$(quote_field "$branch")" "$head_oid" "$dirty"
    continue
  fi

  upstream="$remote_name/${remote_ref#refs/heads/}"
  local_upstream="$(git -C "$repo" rev-parse --verify -q '@{u}' 2>/dev/null || true)"
  [ -n "$local_upstream" ] || local_upstream="-"

  remote_upstream="$(git -C "$repo" ls-remote "$remote_name" "$remote_ref" 2>/dev/null | awk 'NR == 1 {print $1}')"
  if [ -z "$remote_upstream" ]; then
    printf 'path=%s\tbranch=%s\thead=%s\tdirty=%s\tupstream=%s\tlocal_upstream=%s\tremote_upstream=-\tresult=unknown\treason=remote-upstream-unreadable\n' \
      "$(quote_field "$repo")" "$(quote_field "$branch")" "$head_oid" "$dirty" \
      "$(quote_field "$upstream")" "$local_upstream"
    continue
  fi

  result="unknown"
  reason="cannot-prove-current"
  if [ "$head_oid" = "$remote_upstream" ]; then
    result="fresh"
    reason="head-matches-remote-upstream"
  elif [ "$local_upstream" = "$remote_upstream" ]; then
    behind_count="$(git -C "$repo" rev-list --count "$head_oid..$local_upstream" 2>/dev/null || echo 1)"
    if [ "$behind_count" = "0" ]; then
      result="fresh"
      reason="head-not-behind-upstream"
    else
      result="stale"
      reason="head-behind-upstream-by-$behind_count"
    fi
  else
    result="stale"
    reason="remote-upstream-advanced-without-local-fetch"
  fi

  printf 'path=%s\tbranch=%s\thead=%s\tdirty=%s\tupstream=%s\tlocal_upstream=%s\tremote_upstream=%s\tresult=%s\treason=%s\n' \
    "$(quote_field "$repo")" "$(quote_field "$branch")" "$head_oid" "$dirty" \
    "$(quote_field "$upstream")" "$local_upstream" "$remote_upstream" "$result" "$reason"
done
