#!/usr/bin/env bash
# The Last Stack — update check
# Compares the installed checkout against the latest on GitHub and prints one of:
#   UP_TO_DATE
#   UPGRADE_AVAILABLE  local=<x> remote=<y>
#   GIT_UPDATE_AVAILABLE  local_head=<sha> remote_head=<sha>
#   UNKNOWN            (offline / lookup failed — never blocks)
# Version lookups are cached for 60 minutes so they're cheap to call from a
# skill preamble. Git HEAD checks are intentionally uncached, because routine
# fixes can land without a VERSION bump.
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
LOCAL="$(cat "$ROOT/VERSION" 2>/dev/null || echo "0.0.0")"

REMOTE_URL="${LASTSTACK_REMOTE_URL:-https://raw.githubusercontent.com/EdgeVector/last-stack/main/VERSION}"
CACHE="$ROOT/.update-check"
TTL=3600  # seconds

artifact_update_check() {
  command -v host-track >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1
  # Only apply Host Track status to the live install / artifact tree — never to
  # fixture checkouts or development worktrees (those use the git path below).
  # Tests may set LASTSTACK_USE_HOST_TRACK_STATUS=1 to force this path.
  if [ "${LASTSTACK_USE_HOST_TRACK_STATUS:-0}" != "1" ]; then
    compat_root="${LAST_STACK_COMPAT_ROOT:-$HOME/.last-stack}"
    compat_res="$(cd "$compat_root" 2>/dev/null && pwd -P || printf '%s\n' "$compat_root")"
    case "$ROOT" in
      "$compat_root"|"$compat_root"/*|"$compat_res"|"$compat_res"/*) ;;
      */.last-stack/.artifacts/*|*/.artifacts/versions/*|*/.artifacts/current*|*/.last-stack) ;;
      *) return 1 ;;
    esac
  fi
  artifact_status="$(host-track status --json last-stack 2>/dev/null || true)"
  [ "$(printf '%s\n' "$artifact_status" | jq -r '.install_mode // ""' 2>/dev/null)" = "artifact" ] || return 1
  stale="$(printf '%s\n' "$artifact_status" | jq -r '.stale | tostring' 2>/dev/null)"
  local_manifest="$(printf '%s\n' "$artifact_status" | jq -r '.manifest_digest // ""' 2>/dev/null)"
  channel_manifest="$(printf '%s\n' "$artifact_status" | jq -r '.channel_manifest_digest // ""' 2>/dev/null)"
  case "$stale" in
    false) printf 'UP_TO_DATE\n' ;;
    true) printf 'ARTIFACT_UPDATE_AVAILABLE  local_manifest=%s channel_manifest=%s\n' \
      "${local_manifest:0:12}" "${channel_manifest:0:12}" ;;
    *) printf 'UNKNOWN\n' ;;
  esac
  return 0
}

if artifact_update_check; then
  exit 0
fi

short_sha() {
  printf '%s' "$1" | cut -c1-12
}

default_remote() {
  if git -C "$ROOT" remote get-url lastgit >/dev/null 2>&1; then
    venue="$(git -C "$ROOT" config --get laststack.pr-venue 2>/dev/null || true)"
    [ -n "$venue" ] || venue="$(git -C "$ROOT" config --get laststack.prVenue 2>/dev/null || true)"
    if [ -z "$venue" ] && [ -f "$ROOT/.last-stack/pr-venue" ]; then
      venue="$(sed -n '1{s/[[:space:]]*$//;p;}' "$ROOT/.last-stack/pr-venue")"
    fi
    if [ "$venue" = "lastgit" ]; then
      printf 'lastgit\n'
      return 0
    fi
  fi
  printf 'origin\n'
}

git_update_check() {
  git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  remote="${LASTSTACK_REMOTE_REPO:-$(default_remote)}"
  local_ref="$(git -C "$ROOT" symbolic-ref -q HEAD 2>/dev/null || true)"
  [ -n "$local_ref" ] || return 0

  remote_info="$(git -C "$ROOT" ls-remote --symref "$remote" HEAD 2>/dev/null || true)"
  [ -n "$remote_info" ] || return 0

  remote_ref="$(printf '%s\n' "$remote_info" | awk '$1 == "ref:" && $3 == "HEAD" {print $2; exit}')"
  remote_head="$(printf '%s\n' "$remote_info" | awk '$2 == "HEAD" && $1 != "ref:" {print $1; exit}')"
  [ -n "$remote_ref" ] && [ -n "$remote_head" ] || return 0

  local_head="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || true)"
  [ -n "$local_head" ] || return 0

  if [ "$local_ref" != "$remote_ref" ]; then
    if ! git -C "$ROOT" merge-base --is-ancestor "$remote_head" HEAD >/dev/null 2>&1; then
      printf 'GIT_UPDATE_AVAILABLE  local_ref=%s remote_ref=%s local_head=%s remote_head=%s\n' \
        "$local_ref" "$remote_ref" "$(short_sha "$local_head")" "$(short_sha "$remote_head")"
      exit 0
    fi
    return 0
  fi

  if [ "$local_head" != "$remote_head" ]; then
    if git -C "$ROOT" cat-file -e "$remote_head^{commit}" 2>/dev/null &&
       ! git -C "$ROOT" merge-base --is-ancestor "$local_head" "$remote_head" >/dev/null 2>&1; then
      return 0
    fi
    printf 'GIT_UPDATE_AVAILABLE  local_head=%s remote_head=%s\n' \
      "$(short_sha "$local_head")" "$(short_sha "$remote_head")"
    exit 0
  fi
}

git_update_check

now="$(date +%s 2>/dev/null || echo 0)"
if [ -f "$CACHE" ]; then
  ts="$(sed -n '1p' "$CACHE" 2>/dev/null || echo 0)"
  cached="$(sed -n '2p' "$CACHE" 2>/dev/null || true)"
  if [ -n "$cached" ] && [ "$now" -gt 0 ] && [ $((now - ts)) -lt "$TTL" ]; then
    echo "$cached"; exit 0
  fi
fi

REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || true)"
if [ -z "$REMOTE" ]; then
  echo "UNKNOWN"; exit 0
fi

if [ "$REMOTE" = "$LOCAL" ]; then
  result="UP_TO_DATE"
else
  # Lexically-newest wins via sort -V; only flag when remote is strictly newer.
  newest="$(printf '%s\n%s\n' "$LOCAL" "$REMOTE" | sort -V | tail -1)"
  if [ "$newest" = "$REMOTE" ]; then
    result="UPGRADE_AVAILABLE  local=$LOCAL remote=$REMOTE"
  else
    result="UP_TO_DATE"
  fi
fi

printf '%s\n%s\n' "$now" "$result" > "$CACHE" 2>/dev/null || true
echo "$result"
