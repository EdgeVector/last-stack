#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: last-stack-pr-venue [--json|--compare-ref] <owner/repo> [repo-root]

Print the PR/CR venue for a repo: github, forgejo, or lastgit.
With --compare-ref, print the canonical ref for local-ahead checks.

LastGit is opt-in only. A repo opts in with one of:
  git config laststack.pr-venue lastgit
  git config laststack.prVenue lastgit
  .last-stack/pr-venue containing lastgit
  LAST_STACK_LASTGIT_NATIVE_REPOS containing owner/repo

Repo-local config may also set:
  git config laststack.lastgit-slug <slug>
  git config laststack.lastgit-ci-context <context>
EOF
}

mode=plain
if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi
while [ "${1:-}" = "--json" ] || [ "${1:-}" = "--compare-ref" ]; do
  case "$1" in
    --json)
      mode=json
      ;;
    --compare-ref)
      mode=compare_ref
      ;;
  esac
  shift
done

repo="${1:-}"
repo_root="${2:-}"

if [ -z "$repo" ]; then
  echo "LAST_STACK_PR_VENUE: missing owner/repo" >&2
  usage
  exit 2
fi

case "$repo" in
  */*) ;;
  *)
    echo "LAST_STACK_PR_VENUE: repo must be owner/name, got: $repo" >&2
    exit 2
    ;;
esac

repo_name="${repo##*/}"
default_slug="$repo_name"
ci_context="ci-required"
venue=""
reason=""

repo_config() {
  key="$1"
  if [ -n "$repo_root" ] && git -C "$repo_root" rev-parse --show-toplevel >/dev/null 2>&1; then
    git -C "$repo_root" config --get "$key" 2>/dev/null || true
  fi
}

remote_ref_exists() {
  remote="$1"
  branch="$2"
  [ -n "$branch" ] || return 1
  [ -n "$repo_root" ] || return 1
  git -C "$repo_root" show-ref --verify --quiet "refs/remotes/$remote/$branch"
}

canonical_compare_ref() {
  [ -n "$repo_root" ] || return 0
  git -C "$repo_root" rev-parse --show-toplevel >/dev/null 2>&1 || return 0

  branch="$(git -C "$repo_root" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

  if [ "$venue" = "lastgit" ] && remote_ref_exists lastgit "$branch"; then
    printf 'lastgit/%s\n' "$branch"
    return 0
  fi

  upstream="$(git -C "$repo_root" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    printf '%s\n' "$upstream"
    return 0
  fi

  if remote_ref_exists origin "$branch"; then
    printf 'origin/%s\n' "$branch"
    return 0
  fi

  if remote_ref_exists origin main; then
    printf 'origin/main\n'
    return 0
  fi
}

normalize_venue() {
  value="$1"
  case "$value" in
    github|forgejo|lastgit) printf '%s\n' "$value" ;;
    "") ;;
    *)
      echo "LAST_STACK_PR_VENUE: unsupported venue '$value' for $repo" >&2
      exit 2
      ;;
  esac
}

venue="$(normalize_venue "$(repo_config laststack.pr-venue)")"
if [ -n "$venue" ]; then
  reason="git-config:laststack.pr-venue"
fi

if [ -z "$venue" ]; then
  venue="$(normalize_venue "$(repo_config laststack.prVenue)")"
  if [ -n "$venue" ]; then
    reason="git-config:laststack.prVenue"
  fi
fi

if [ -z "$venue" ] && [ -n "$repo_root" ] && [ -f "$repo_root/.last-stack/pr-venue" ]; then
  marker="$(sed -n '1{s/[[:space:]]*$//;p;}' "$repo_root/.last-stack/pr-venue")"
  venue="$(normalize_venue "$marker")"
  if [ -n "$venue" ]; then
    reason=".last-stack/pr-venue"
  fi
fi

list_contains_repo() {
  haystack="$1"
  old_ifs=$IFS
  IFS=', '
  for item in $haystack; do
    if [ "$item" = "$repo" ]; then
      IFS=$old_ifs
      return 0
    fi
  done
  IFS=$old_ifs
  return 1
}

if [ -z "$venue" ] && list_contains_repo "${LAST_STACK_LASTGIT_NATIVE_REPOS:-}"; then
  venue="lastgit"
  reason="env:LAST_STACK_LASTGIT_NATIVE_REPOS"
fi

if [ -z "$venue" ] && list_contains_repo "${LAST_STACK_FORGEJO_REPOS:-}"; then
  venue="forgejo"
  reason="env:LAST_STACK_FORGEJO_REPOS"
fi

if [ -z "$venue" ]; then
  case "$repo" in
    # Remaining Forgejo gates of record (GitHub = read-only mirror).
    EdgeVector/fold|EdgeVector/lastgit)
      venue="forgejo"
      reason="default:forge-hot"
      ;;
    # LastGit-native fleet (GitHub = read-only mirror). Keep in sync with
    # brain reference-edgevector-github-mirrors-read-only.
    EdgeVector/brain|EdgeVector/demo-repository|EdgeVector/discovery|EdgeVector/dogfood-graph|EdgeVector/edgevector-website|EdgeVector/exemem-infra|EdgeVector/exemem-workspace|EdgeVector/fkanban|EdgeVector/fold_db_website|EdgeVector/homebrew-lastdb|EdgeVector/last-stack|EdgeVector/lastsecrets|EdgeVector/org|EdgeVector/routines|EdgeVector/schema-infra|EdgeVector/situations|EdgeVector/configurations|EdgeVector/autoresearch-docstore|EdgeVector/coderings|EdgeVector/lastdb-core|EdgeVector/lastdb-nano|EdgeVector/laststore|EdgeVector/photos|EdgeVector/remote)
      venue="lastgit"
      reason="default:lastgit-native"
      ;;
    # True GitHub primaries only. Everything else defaults lastgit-warden
    # (safer than github: agents must not push mirrors).
    EdgeVector/Keepside_Desktop|EdgeVector/.github|EdgeVector/edgevectorlabs-website|EdgeVector/canonical-samples|EdgeVector/runner-smoke)
      venue="github"
      reason="default:github-primary"
      ;;
    *)
      venue="lastgit"
      reason="default:lastgit-prefer-over-github-mirror"
      ;;
  esac
fi

configured_slug="$(repo_config laststack.lastgit-slug)"
if [ -n "$configured_slug" ]; then
  default_slug="$configured_slug"
fi

configured_context="$(repo_config laststack.lastgit-ci-context)"
if [ -n "$configured_context" ]; then
  ci_context="$configured_context"
fi

compare_ref="$(canonical_compare_ref)"

if [ "$mode" = json ]; then
  jq -n \
    --arg repo "$repo" \
    --arg repo_root "$repo_root" \
    --arg venue "$venue" \
    --arg lastgit_slug "$default_slug" \
    --arg ci_context "$ci_context" \
    --arg reason "$reason" \
    --arg compare_ref "$compare_ref" \
    '{repo:$repo, repo_root:$repo_root, venue:$venue, lastgit_slug:$lastgit_slug, ci_context:$ci_context, reason:$reason, compare_ref:$compare_ref}'
elif [ "$mode" = compare_ref ]; then
  if [ -z "$compare_ref" ]; then
    echo "LAST_STACK_PR_VENUE: no comparison ref found for $repo" >&2
    exit 1
  fi
  printf '%s\n' "$compare_ref"
else
  printf '%s\n' "$venue"
fi
