#!/usr/bin/env bash
# Scan LastGit post-merge deploy-pipeline logs under ~/.lastgit/deploy-*/deploy.log
# and report repos whose latest terminal state is failure, or pending too long.
#
# Usage:
#   last-stack-pipeline-deploy-scan [--json] [--root <dir>] [--pending-max-s <n>]
#
# Exit codes:
#   0  scanned OK (even if some pipelines are blocked — check .blocked)
#   2  usage / bad args
#
# A pipeline is blocked when:
#   - the latest success|failure line is `failure`, OR
#   - the latest line is `pending` older than --pending-max-s (default 4h)
#   AND there is no later success.
set -u

json=0
root="${LASTGIT_DEPLOY_ROOT:-$HOME/.lastgit}"
pending_max_s=14400

usage() {
  cat >&2 <<'EOF'
usage: last-stack-pipeline-deploy-scan [--json] [--root <dir>] [--pending-max-s <seconds>]

Scans <root>/deploy-*/deploy.log for LastGit deploy-pipeline health.
Prints human lines by default, or a JSON array with --json.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json=1; shift ;;
    --root)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      root="$2"
      shift 2
      ;;
    --pending-max-s)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      pending_max_s="$2"
      shift 2
      ;;
    -h|--help) usage; exit 0 ;;
    *) usage; exit 2 ;;
  esac
done

now="$(date -u +%s)"
# Portable JSON string escape
json_escape() {
  # shellcheck disable=SC2001
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/	/\\t/g' | tr '\n' ' '
}

# Collect results as lines: repo|status|sha|blocked|reason|log|mtime
results=()
shopt -s nullglob
for dir in "$root"/deploy-*/; do
  [ -d "$dir" ] || continue
  base="$(basename "${dir%/}")"
  case "$base" in
    deploy-*) repo="${base#deploy-}" ;;
    *) continue ;;
  esac
  log="$dir/deploy.log"
  if [ ! -f "$log" ]; then
    results+=("$repo|missing||1|deploy.log missing|$log|0")
    continue
  fi

  # last success / failure / pending lines (ignore skip / JSON telemetry)
  last_term=""
  last_pend=""
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      success\ *|failure\ *) last_term="$line" ;;
      pending\ *) last_pend="$line" ;;
    esac
  done <"$log"

  mtime="$(stat -f %m "$log" 2>/dev/null || stat -c %Y "$log" 2>/dev/null || echo 0)"
  pipe_status="unknown"
  sha=""
  blocked=0
  reason="no success/failure/pending lines"

  if [ -n "$last_term" ]; then
    # e.g. "failure abcdef deploy-pipeline" or "success abcdef deploy-pipeline"
    set -- $last_term
    pipe_status="$1"
    sha="${2:-}"
    if [ "$pipe_status" = "failure" ]; then
      blocked=1
      reason="latest terminal status is failure for $sha"
    else
      reason="latest terminal status is success for $sha"
    fi
  fi

  # Pending after last terminal, or only pending ever
  if [ -n "$last_pend" ]; then
    set -- $last_pend
    pend_sha="${2:-}"
    # If pending is the newest event overall, check age via log mtime as proxy
    # (deploy.log lines lack timestamps on success/failure lines).
    age=$(( now - mtime ))
    # Prefer blocked if pending is more recent than last terminal:
    # approximate: if last line of file is pending-ish via reading last matching line order
    last_any=""
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        success\ *|failure\ *|pending\ *) last_any="$line" ;;
      esac
    done <"$log"
    case "$last_any" in
      pending\ *)
        pipe_status="pending"
        sha="$pend_sha"
        if [ "$age" -gt "$pending_max_s" ]; then
          blocked=1
          reason="pending ${age}s (max ${pending_max_s}s) for $sha"
        else
          blocked=0
          reason="pending ${age}s (within grace) for $sha"
        fi
        ;;
    esac
  fi

  results+=("$repo|$pipe_status|$sha|$blocked|$reason|$log|$mtime")
done
shopt -u nullglob

if [ "$json" -eq 1 ]; then
  printf '['
  first=1
  for row in "${results[@]+"${results[@]}"}"; do
    IFS='|' read -r repo pipe_status sha blocked reason log mtime <<<"$row"
    [ "$first" -eq 1 ] || printf ','
    first=0
    if [ "$blocked" = "1" ]; then bj=true; else bj=false; fi
    printf '{"repo":"%s","status":"%s","sha":"%s","blocked":%s,"reason":"%s","log":"%s","log_mtime":%s}' \
      "$(json_escape "$repo")" \
      "$(json_escape "$pipe_status")" \
      "$(json_escape "$sha")" \
      "$bj" \
      "$(json_escape "$reason")" \
      "$(json_escape "$log")" \
      "${mtime:-0}"
  done
  printf ']\n'
else
  if [ "${#results[@]}" -eq 0 ]; then
    echo "no deploy logs under $root/deploy-*"
  fi
  blocked_n=0
  for row in "${results[@]+"${results[@]}"}"; do
    IFS='|' read -r repo pipe_status sha blocked reason log mtime <<<"$row"
    mark="ok"
    if [ "$blocked" = "1" ]; then
      mark="BLOCKED"
      blocked_n=$((blocked_n + 1))
    fi
    printf '%s  %-20s  status=%-8s  sha=%s  %s\n' "$mark" "$repo" "$pipe_status" "${sha:--}" "$reason"
  done
  echo "summary blocked=$blocked_n total=${#results[@]}"
fi
