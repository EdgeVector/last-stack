#!/usr/bin/env bash
# Scan LastGit post-merge deploy-pipeline logs under ~/.lastgit/deploy-*/deploy.log
# and report repos whose latest terminal state is failure, or pending too long.
#
# Usage:
#   last-stack-pipeline-deploy-scan [--json] [--root <dir>] [--pending-max-s <n>] [--tail-bytes <n>]
#
# Exit codes:
#   0  scanned OK (even if some pipelines are blocked — check .blocked)
#   2  usage / bad args
#
# A pipeline is blocked when:
#   - the latest success|failure line is `failure`, OR
#   - the latest line is `pending` older than --pending-max-s (default 4h)
#   AND there is no later success.
set -eu

json=0
root="${LASTGIT_DEPLOY_ROOT:-$HOME/.lastgit}"
pending_max_s=14400
tail_bytes="${LAST_STACK_DEPLOY_SCAN_TAIL_BYTES:-1048576}"

usage() {
  cat >&2 <<'EOF'
usage: last-stack-pipeline-deploy-scan [--json] [--root <dir>] [--pending-max-s <seconds>] [--tail-bytes <bytes>]

Scans <root>/deploy-*/deploy.log for LastGit deploy-pipeline health.
Prints human lines by default, or a JSON array with --json.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json=1; shift ;;
    --root)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      root="$2"
      shift 2
      ;;
    --pending-max-s)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      pending_max_s="$2"
      shift 2
      ;;
    --tail-bytes)
      [ "$#" -ge 2 ] || { usage; exit 2; }
      tail_bytes="$2"
      shift 2
      ;;
    -h|--help) usage; exit 0 ;;
    *) usage; exit 2 ;;
  esac
done

now="$(date -u +%s)"

json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/	/\\t/g' | tr '\n' ' '
}

log_mtime() {
  local f="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os,sys; print(int(os.path.getmtime(sys.argv[1])))' "$f" 2>/dev/null && return 0
  fi
  # GNU stat
  if stat -c %Y "$f" >/dev/null 2>&1; then
    stat -c %Y "$f"
    return 0
  fi
  # BSD stat
  if stat -f %m "$f" >/dev/null 2>&1; then
    stat -f %m "$f"
    return 0
  fi
  echo 0
}

last_matching_line() {
  local log="$1"
  local pattern="$2"
  # Production deploy logs can be tens of MB. Keep the shell bounded by reading
  # only the recent tail and using grep's C implementation for matching.
  tail -c "$tail_bytes" "$log" 2>/dev/null | grep -aE "$pattern" | tail -n 1 || true
}

# Collect results as lines: repo|pipe_status|sha|blocked|reason|log|mtime
results=()
shopt -s nullglob
for dir in "$root"/deploy-*/; do
  [ -d "$dir" ] || continue
  base="$(basename "${dir%/}")"
  case "$base" in
    deploy-*) repo="${base#deploy-}" ;;
    *) continue ;;
  esac
  log="${dir}deploy.log"
  if [ ! -f "$log" ]; then
    results+=("$repo|missing||1|deploy.log missing|$log|0")
    continue
  fi

  # Latest deploy event from a bounded tail window (ignore skip / JSON telemetry).
  last_term="$(last_matching_line "$log" '^(success|failure) ')"
  last_any="$(last_matching_line "$log" '^(success|failure|pending) ')"

  mtime="$(log_mtime "$log")"
  pipe_status="unknown"
  sha=""
  blocked=0
  reason="no success/failure/pending lines"

  if [ -n "$last_term" ]; then
    # e.g. "failure abcdef deploy-pipeline"
    pipe_status="${last_term%% *}"
    rest="${last_term#* }"
    sha="${rest%% *}"
    if [ "$pipe_status" = "failure" ]; then
      blocked=1
      reason="latest terminal status is failure for $sha"
    else
      reason="latest terminal status is success for $sha"
    fi
  fi

  # If the newest event overall is pending, apply grace on log mtime
  case "$last_any" in
    pending\ *)
      rest="${last_any#* }"
      pend_sha="${rest%% *}"
      pipe_status="pending"
      sha="$pend_sha"
      age=$((now - mtime))
      if [ "$age" -gt "$pending_max_s" ]; then
        blocked=1
        reason="pending ${age}s (max ${pending_max_s}s) for $sha"
      else
        blocked=0
        reason="pending ${age}s (within grace) for $sha"
      fi
      ;;
  esac

  results+=("$repo|$pipe_status|$sha|$blocked|$reason|$log|$mtime")
done
shopt -u nullglob

if [ "$json" -eq 1 ]; then
  printf '['
  first=1
  for row in "${results[@]+"${results[@]}"}"; do
    IFS='|' read -r repo pipe_status sha blocked reason log mtime <<<"$row"
    [ "$first" -eq 1 ] || printf ','
    first=0
    if [ "$blocked" = "1" ]; then bj=true; else bj=false; fi
    printf '{"repo":"%s","status":"%s","sha":"%s","blocked":%s,"reason":"%s","log":"%s","log_mtime":%s}' \
      "$(json_escape "$repo")" \
      "$(json_escape "$pipe_status")" \
      "$(json_escape "$sha")" \
      "$bj" \
      "$(json_escape "$reason")" \
      "$(json_escape "$log")" \
      "${mtime:-0}"
  done
  printf ']\n'
else
  if [ "${#results[@]}" -eq 0 ]; then
    echo "no deploy logs under $root/deploy-*"
  fi
  blocked_n=0
  for row in "${results[@]+"${results[@]}"}"; do
    IFS='|' read -r repo pipe_status sha blocked reason log mtime <<<"$row"
    mark="ok"
    if [ "$blocked" = "1" ]; then
      mark="BLOCKED"
      blocked_n=$((blocked_n + 1))
    fi
    printf '%s  %-20s  status=%-8s  sha=%s  %s\n' "$mark" "$repo" "$pipe_status" "${sha:--}" "$reason"
  done
  echo "summary blocked=$blocked_n total=${#results[@]}"
fi
