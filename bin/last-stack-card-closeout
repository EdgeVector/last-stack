#!/usr/bin/env bash
# Atomic post-merge board closeout for pickup/kanban-agent.
#
# Usage:
#   last-stack-card-closeout <slug> [--board-cli fkanban|kanban] \
#     [--pr-url URL] [--branch NAME] [--force]
#
# 1. Optionally stamps --pr-url / --branch via add (preserves column).
# 2. Refuses deploy-gated closeout unless Requires-Deploy has terminal success.
# 3. Moves the card to done (with lastdb-retry).
# 4. Verifies show --json reports column=done; retries once if not.
# 5. Exits 0 only when the card is in the terminal column.
#
# Refuse final_column=done in ROUTINE_RESULT unless this helper exits 0.
set -euo pipefail

self_dir="$(cd "$(dirname "$0")" && pwd -P)"
slug="${1:-}"
shift || true
if [ -z "$slug" ]; then
  echo "usage: last-stack-card-closeout <slug> [--board-cli fkanban|kanban] [--pr-url u] [--branch b] [--force]" >&2
  exit 2
fi

board_cli=""
pr_url=""
branch=""
force=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --board-cli) board_cli="${2:-}"; shift 2 ;;
    --pr-url) pr_url="${2:-}"; shift 2 ;;
    --branch) branch="${2:-}"; shift 2 ;;
    --force) force=1; shift ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done

if [ -z "$board_cli" ]; then
  if command -v fkanban >/dev/null 2>&1; then board_cli=fkanban
  elif command -v kanban >/dev/null 2>&1; then board_cli=kanban
  else
    echo "last-stack-card-closeout: need fkanban or kanban on PATH" >&2
    exit 2
  fi
fi

retry=( )
if [ -x "$self_dir/last-stack-lastdb-retry" ]; then
  retry=( "$self_dir/last-stack-lastdb-retry" --attempts 3 -- )
fi

run() {
  if [ "${#retry[@]}" -gt 0 ]; then
    "${retry[@]}" "$@"
  else
    "$@"
  fi
}

card_json="$(run "$board_cli" show "$slug" --json 2>/dev/null || true)"
if [ -z "$card_json" ]; then
  echo "last-stack-card-closeout: FAILED card-read-failed slug=$slug" >&2
  exit 1
fi

deploy_info="$(CARD_JSON="$card_json" python3 - <<'PY'
import json, re, sys
import os

try:
    raw = json.loads(os.environ.get("CARD_JSON", "{}"))
except Exception:
    sys.exit(0)
card = raw.get("card") if isinstance(raw, dict) else None
if not isinstance(card, dict):
    card = raw if isinstance(raw, dict) else {}
body = str(card.get("body") or "")
repo = str(card.get("repo") or "")
if not repo:
    m = re.search(r"(?im)^\s*Repo:\s*(\S+)\s*$", body)
    if m:
        repo = m.group(1)
repo_name = repo.rsplit("/", 1)[-1] if repo else ""
print(f"repo={repo_name}")
seen = set()
for line in body.splitlines():
    m = re.match(r"^\s*Requires-Deploy:\s*(.+?)\s*$", line)
    if not m:
        continue
    for part in re.split(r"[, ]+", m.group(1).strip()):
        if not part:
            continue
        if part in seen:
            continue
        seen.add(part)
        print(f"requires={part}")
PY
)"

deploy_repo="$(printf '%s\n' "$deploy_info" | sed -n 's/^repo=//p' | head -n 1)"
deploy_reqs="$(printf '%s\n' "$deploy_info" | sed -n 's/^requires=//p')"

if [ -n "$deploy_reqs" ]; then
  if [ -z "$deploy_repo" ]; then
    echo "last-stack-card-closeout: FAILED deploy-gate-missing-repo slug=$slug" >&2
    exit 1
  fi
  if [ ! -x "$self_dir/last-stack-pipeline-deploy-scan" ]; then
    echo "last-stack-card-closeout: FAILED deploy-scan-missing slug=$slug" >&2
    exit 1
  fi
  deploy_scan_json="$("$self_dir/last-stack-pipeline-deploy-scan" --json 2>/dev/null || true)"
  if [ -z "$deploy_scan_json" ]; then
    echo "last-stack-card-closeout: FAILED deploy-scan-empty slug=$slug repo=$deploy_repo" >&2
    exit 1
  fi
  while IFS= read -r deploy_req; do
    [ -n "$deploy_req" ] || continue
    if [ "$deploy_req" != "deploy-pipeline" ]; then
      echo "last-stack-card-closeout: FAILED unsupported-deploy-gate=$deploy_req slug=$slug" >&2
      exit 1
    fi
    gate_status="$(DEPLOY_SCAN_JSON="$deploy_scan_json" DEPLOY_REPO="$deploy_repo" python3 - <<'PY'
import json, os

repo = os.environ.get("DEPLOY_REPO", "")
try:
    rows = json.loads(os.environ.get("DEPLOY_SCAN_JSON", "[]"))
except Exception:
    rows = []
match = None
for row in rows if isinstance(rows, list) else []:
    if str(row.get("repo") or "") == repo:
        match = row
        break
if not match:
    print("missing|true|deploy log missing")
else:
    print(f"{match.get('status','')}|{str(bool(match.get('blocked'))).lower()}|{match.get('reason','')}")
PY
)"
    IFS='|' read -r gate_state gate_blocked gate_reason <<EOF
$gate_status
EOF
    if [ "$gate_state" != "success" ] || [ "$gate_blocked" != "false" ]; then
      echo "last-stack-card-closeout: deploy gate pending slug=$slug repo=$deploy_repo requires=$deploy_req status=${gate_state:-unknown} reason=$gate_reason" >&2
      exit 1
    fi
  done <<EOF
$deploy_reqs
EOF
fi

# Stamp PR/branch without changing column (add preserves existing column).
if [ -n "$pr_url" ] || [ -n "$branch" ]; then
  add_args=( "$board_cli" add "$slug" )
  [ -n "$pr_url" ] && add_args+=( --pr-url "$pr_url" )
  [ -n "$branch" ] && add_args+=( --branch "$branch" )
  run "${add_args[@]}"
fi

move_to_done() {
  if [ "$force" -eq 1 ]; then
    run "$board_cli" move "$slug" done --force
  else
    run "$board_cli" move "$slug" done
  fi
}

column_of() {
  "$board_cli" show "$slug" --json 2>/dev/null | python3 -c '
import sys, json
d = json.load(sys.stdin)
c = d.get("card") or d
print(c.get("column") or "")
' 2>/dev/null || true
}

move_to_done || true
col="$(column_of)"
if [ "$col" != "done" ]; then
  echo "last-stack-card-closeout: column=$col after first move; retrying with --force" >&2
  force=1
  move_to_done || true
  col="$(column_of)"
fi

if [ "$col" != "done" ]; then
  echo "last-stack-card-closeout: FAILED column=$col (wanted done) slug=$slug" >&2
  exit 1
fi

echo "last-stack-card-closeout: ok slug=$slug column=done"
exit 0
