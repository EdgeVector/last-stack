#!/usr/bin/env python3
"""Roll up kanban cards by north_star × column into markdown + HTML.

Read-only against the board/brain by default. Optional --put-brain writes the
markdown snapshot into the durable brain reference `north-star-dashboard`.

Also computes North Star **completion** (terminal verification contract):
`last-stack-north-star-dashboard --stdout completion` or the wrapper
`last-stack-north-star-completion-check`. See brain
`sop-north-star-terminal-verification`.
"""

from __future__ import annotations

import argparse
import html
import json
import os
import re
import subprocess
import sys
import tempfile
from collections import Counter, defaultdict
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Optional


COLUMNS = ("backlog", "todo", "doing", "review", "done")
LIVE_COLUMNS = ("backlog", "todo", "doing", "review")
DEFAULT_BRAIN_SLUG = "north-star-dashboard"
DEFAULT_HTML_PATH = Path.home() / "code" / "edgevector" / "north-star-dashboard.html"

# Historical / alias card.north_star values → canonical NS slug.
ALIASES: dict[str, str] = {
    "lastdb-secrets-and-local-schema-resolver-roadmap-2026-07-06": (
        "north-star-schema-shared-surface-native-resolver"
    ),
}

# Product-token families used for low-confidence mis-tag heuristics.
# A live card attributed to an NS family but matching a *different* family
# (and none of the NS family tokens) is reported as mistag_candidate.
NS_TOKEN_FAMILIES: dict[str, set[str]] = {
    "discovery": {"discovery", "fof", "deliver", "slice", "slices"},
    "lastgit": {"lastgit", "forgejo", "forge", "mirror"},
    "schema": {"schema", "resolver", "shared-surface", "pack"},
    "metering": {"metering", "quota", "billing", "stripe", "b2", "r2", "storage"},
    "coderings": {"coderings", "complexity", "snapshot"},
    "nano": {"nano", "bm25", "kernel"},
    "sentry": {"sentry"},
    "dogfood": {"dogfood"},
    "routine": {"routine", "routines", "last-stack"},
}



# --- North Star completion / terminal verification --------------------------

TERMINAL_SECTION_RE = re.compile(
    r"^##[ \t]+Terminal verification\b[^\n]*\n(.*?)(?=^##[ \t]|\Z)",
    re.IGNORECASE | re.MULTILINE | re.DOTALL,
)
END_STATE_SECTION_RE = re.compile(
    r"^##[ \t]+(?:End state|What \"done\" looks like|What 'done' looks like)\b",
    re.IGNORECASE | re.MULTILINE,
)
# Prefer explicit "Card:" / "Terminal card:" lines; fall back to first slug-like token.
TERMINAL_CARD_LINE_RE = re.compile(
    r"(?im)^\s*(?:[-*]\s*)?(?:\*\*)?(?:Card|Terminal card|Capstone(?: card)?)(?:\*\*)?\s*:\s*`?([a-z0-9][a-z0-9._-]*)`?"
)
BACKTICK_SLUG_RE = re.compile(r"`([a-z0-9][a-z0-9._-]{2,})`")
DATE_ONLY_DONE_WHEN_RE = re.compile(
    r"(?im)^\s*DONE-WHEN:\s*date\s*>=\s*\d{4}-\d{2}-\d{2}\s*$"
)


def has_end_state_section(body: str) -> bool:
    return bool(END_STATE_SECTION_RE.search(body or ""))


def parse_terminal_card_from_body(body: str) -> str:
    """Return the named terminal card slug from ## Terminal verification, or ''."""
    if not body:
        return ""
    m = TERMINAL_SECTION_RE.search(body)
    if not m:
        return ""
    section = m.group(1) or ""
    m2 = TERMINAL_CARD_LINE_RE.search(section)
    if m2:
        return m2.group(1).strip()
    # First backtick slug in the section that looks like a card id (has a hyphen).
    for hit in BACKTICK_SLUG_RE.findall(section):
        if "-" in hit and not hit.startswith("north-star"):
            return hit
    return ""


def is_terminal_shaped_card(card: dict[str, Any]) -> bool:
    kind = str(card.get("kind") or "").lower()
    slug = str(card.get("slug") or "").lower()
    title = str(card.get("title") or "")
    if kind in {"validation", "capstone"}:
        return True
    if "capstone" in slug:
        return True
    if title.upper().startswith("CAPSTONE"):
        return True
    if "terminal" in slug and "verification" in slug:
        return True
    return False


def terminal_proof_quality(card: Optional[dict[str, Any]]) -> str:
    """Classify how good a terminal card is as proof: good | weak | missing."""
    if not card:
        return "missing"
    kind = str(card.get("kind") or "").lower()
    body = str(card.get("body") or "")
    # Date-only DONE-WHEN parents are weak (calendar ≠ product proof).
    if DATE_ONLY_DONE_WHEN_RE.search(body) and kind in {"capstone", "validation", "meta"}:
        return "weak"
    if kind == "tracker":
        return "weak"
    if kind in {"pr", "validation", "capstone"} or is_terminal_shaped_card(card):
        return "good"
    return "weak"


def pick_inferred_terminal(
    member_cards: list[dict[str, Any]],
) -> Optional[dict[str, Any]]:
    """Prefer live terminal-shaped cards, else done ones."""
    shaped = [c for c in member_cards if is_terminal_shaped_card(c)]
    if not shaped:
        return None

    def rank(c: dict[str, Any]) -> tuple[int, int, str]:
        col = str(c.get("column") or "")
        # Prefer live non-done, then done.
        live_i = 0 if col in LIVE_COLUMNS else 1
        kind = str(c.get("kind") or "")
        kind_i = {"pr": 0, "validation": 1, "capstone": 2}.get(kind, 9)
        return (live_i, kind_i, str(c.get("slug") or ""))

    return sorted(shaped, key=rank)[0]


def enrich_projects_with_bodies(
    projects: list[dict[str, Any]],
    *,
    fetch: bool,
) -> list[dict[str, Any]]:
    """When fetch=True, brain-get bodies for North Star projects missing body."""
    if not fetch:
        return projects
    out: list[dict[str, Any]] = []
    for p in projects:
        if not is_north_star_project(p):
            out.append(p)
            continue
        if p.get("body"):
            out.append(p)
            continue
        slug = str(p.get("slug") or "")
        if not slug:
            out.append(p)
            continue
        try:
            full = run_json(["brain", "get", slug, "--type", "project", "--json"])
            if isinstance(full, dict) and full.get("body") is not None:
                merged = dict(p)
                merged["body"] = full.get("body") or ""
                # Prefer fresher status/title from get when present.
                for k in ("status", "title", "tags"):
                    if full.get(k) is not None:
                        merged[k] = full[k]
                out.append(merged)
                continue
        except Exception:  # noqa: BLE001 — completion is best-effort
            pass
        out.append(p)
    return out


def build_completion_for_section(
    section: dict[str, Any],
    rec: Optional[dict[str, Any]],
    member_cards: list[dict[str, Any]],
    cards_by_slug: dict[str, dict[str, Any]],
) -> dict[str, Any]:
    body = str((rec or {}).get("body") or "")
    has_end = has_end_state_section(body)
    named = parse_terminal_card_from_body(body)
    named_card = cards_by_slug.get(named) if named else None
    inferred = pick_inferred_terminal(member_cards)
    # Prefer explicit name when present; fall back to board inference.
    terminal_card = named_card or inferred
    terminal_slug = (
        named
        if named
        else (str(terminal_card.get("slug")) if terminal_card else "")
    )
    terminal_column = str(terminal_card.get("column") or "") if terminal_card else ""
    terminal_kind = str(terminal_card.get("kind") or "") if terminal_card else ""
    quality = terminal_proof_quality(terminal_card)
    if named and not named_card:
        terminal_state = "named_missing_on_board"
        quality = "missing"
    elif not terminal_card:
        terminal_state = "missing"
    elif terminal_column == "done":
        terminal_state = "done"
    else:
        terminal_state = "live"

    ns_status = str(section.get("status") or "")
    closed = ns_status in {"completed", "archived", "done"}
    board_drained = int(section.get("live") or 0) == 0 and not closed
    flags: list[str] = []
    if not closed and not has_end:
        flags.append("definition_incomplete")
    if not closed and terminal_state in {"missing", "named_missing_on_board"}:
        flags.append("terminal_missing")
    if not closed and terminal_state == "live":
        flags.append("terminal_live")
    if terminal_state == "done":
        flags.append("terminal_done")
    if quality == "weak":
        flags.append("terminal_weak")
    if board_drained and terminal_state != "done":
        flags.append("board_drained_ns_open")
    if not closed and terminal_state == "done":
        flags.append("ns_completable")
    if closed:
        flags.append("ns_closed")

    if closed:
        verdict = "closed"
    elif "ns_completable" in flags:
        verdict = "completable"
    elif "terminal_missing" in flags or "definition_incomplete" in flags:
        verdict = "definition_incomplete"
    elif "board_drained_ns_open" in flags:
        verdict = "board_drained_ns_open"
    elif "terminal_live" in flags:
        verdict = "in_progress"
    else:
        verdict = "in_progress"

    return {
        "north_star": section.get("slug"),
        "ns_status": ns_status,
        "has_end_state_section": has_end,
        "named_terminal_slug": named or "",
        "terminal_slug": terminal_slug,
        "terminal_source": (
            "body" if named_card else ("inferred" if inferred and terminal_card is inferred else ("body_missing_card" if named else "none"))
        ),
        "terminal_column": terminal_column,
        "terminal_kind": terminal_kind,
        "terminal_state": terminal_state,
        "terminal_quality": quality,
        "board_drained": board_drained,
        "live": int(section.get("live") or 0),
        "pct_done": int(section.get("pct_done") or 0),
        "flags": flags,
        "verdict": verdict,
    }


def attach_completion(
    sections: list[dict[str, Any]],
    by_slug: dict[str, dict[str, Any]],
    groups: dict[str, list[dict[str, Any]]],
    all_cards: list[dict[str, Any]],
) -> dict[str, Any]:
    cards_by_slug = {
        str(c.get("slug")): c for c in all_cards if c.get("slug")
    }
    rows: list[dict[str, Any]] = []
    for s in sections:
        slug = str(s.get("slug") or "")
        rec = by_slug.get(slug)
        members = groups.get(slug, [])
        comp = build_completion_for_section(s, rec, members, cards_by_slug)
        s["completion"] = comp
        rows.append(comp)

    def count_flag(flag: str) -> int:
        return sum(1 for r in rows if flag in (r.get("flags") or []))

    summary = {
        "north_stars": len(rows),
        "closed": sum(1 for r in rows if r.get("verdict") == "closed"),
        "completable": count_flag("ns_completable"),
        "terminal_missing": count_flag("terminal_missing"),
        "terminal_live": count_flag("terminal_live"),
        "terminal_done": count_flag("terminal_done"),
        "definition_incomplete": count_flag("definition_incomplete"),
        "board_drained_ns_open": count_flag("board_drained_ns_open"),
        "terminal_weak": count_flag("terminal_weak"),
        "needs_work": False,
    }
    summary["needs_work"] = bool(
        summary["completable"]
        or summary["terminal_missing"]
        or summary["definition_incomplete"]
        or summary["board_drained_ns_open"]
        or summary["terminal_weak"]
    )
    return {"summary": summary, "north_stars": rows}


def render_completion_markdown(model: dict[str, Any]) -> str:
    comp = model.get("completion") or {}
    summary = comp.get("summary") or {}
    rows = comp.get("north_stars") or []
    lines: list[str] = []
    lines.append("# North Star completion report")
    lines.append("")
    lines.append(f"**Generated:** `{model.get('generated_at')}`")
    lines.append("")
    lines.append(
        f"- closed={summary.get('closed', 0)} · completable={summary.get('completable', 0)} · "
        f"terminal_missing={summary.get('terminal_missing', 0)} · "
        f"terminal_live={summary.get('terminal_live', 0)} · "
        f"board_drained_ns_open={summary.get('board_drained_ns_open', 0)} · "
        f"definition_incomplete={summary.get('definition_incomplete', 0)} · "
        f"terminal_weak={summary.get('terminal_weak', 0)}"
    )
    lines.append("")
    lines.append(
        "| North Star | status | verdict | terminal | col | quality | flags |"
    )
    lines.append("|---|---|---|---|---|---|---|")
    for r in rows:
        flags = ",".join(r.get("flags") or []) or "—"
        lines.append(
            f"| `{r.get('north_star')}` | {r.get('ns_status')} | {r.get('verdict')} | "
            f"`{r.get('terminal_slug') or '—'}` | {r.get('terminal_column') or '—'} | "
            f"{r.get('terminal_quality')} | {flags} |"
        )
    if not rows:
        lines.append("| _(none)_ | | | | | | |")
    lines.append("")
    action = [r for r in rows if r.get("verdict") in {
        "completable", "definition_incomplete", "board_drained_ns_open"
    } or "terminal_missing" in (r.get("flags") or [])]
    if action:
        lines.append("## Action queue (program-driver)")
        lines.append("")
        for r in action:
            slug = r.get("north_star")
            v = r.get("verdict")
            if "ns_completable" in (r.get("flags") or []):
                lines.append(
                    f"- `{slug}`: terminal `{r.get('terminal_slug')}` is done → "
                    f"**mark NS done (status=done)** + archive active-programs section"
                )
            elif "terminal_missing" in (r.get("flags") or []):
                lines.append(
                    f"- `{slug}`: **file terminal verification card** "
                    f"(see [[sop-north-star-terminal-verification]])"
                )
            elif v == "board_drained_ns_open":
                lines.append(
                    f"- `{slug}`: board drained but terminal not done → "
                    f"promote/file only terminal work (`{r.get('terminal_slug') or 'new'}`)"
                )
            else:
                lines.append(f"- `{slug}`: verdict={v} flags={r.get('flags')}")
        lines.append("")
    lines.append(
        "SOP: `brain get sop-north-star-terminal-verification --type sop` · "
        "Design: `brain get design-north-star-completion-contract --type design`"
    )
    lines.append("")
    return "\n".join(lines)


def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%MZ")


def run_json(cmd: list[str], *, env: Optional[dict[str, str]] = None) -> Any:
    proc = subprocess.run(
        cmd,
        check=False,
        capture_output=True,
        text=True,
        env=env,
    )
    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "").strip()
        raise RuntimeError(f"command failed ({proc.returncode}): {' '.join(cmd)}\n{err}")
    text = proc.stdout.strip()
    if not text:
        return []
    return json.loads(text)


def normalize_north_star(raw: Optional[str]) -> str:
    value = (raw or "").strip()
    if not value:
        return ""
    # Accept [[slug]] body mentions if someone stuffed them into the field.
    if value.startswith("[[") and value.endswith("]]"):
        value = value[2:-2].strip()
    return ALIASES.get(value, value)


def priority_of(card: dict[str, Any]) -> str:
    tags = card.get("tags") or []
    for tag in tags:
        t = str(tag).lower()
        if t in {"p0", "p1", "p2", "p3"}:
            return t.upper()
    return ""


def is_north_star_project(rec: dict[str, Any]) -> bool:
    tags = {str(t).lower() for t in (rec.get("tags") or [])}
    slug = str(rec.get("slug") or "")
    title = str(rec.get("title") or "")
    if "north-star" in tags:
        return True
    if slug.startswith("north-star-"):
        return True
    if "North Star" in title or "🌟" in title:
        return True
    return False


def load_cards_from_file(path: Path) -> list[dict[str, Any]]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if isinstance(data, list):
        return data
    if isinstance(data, dict):
        if isinstance(data.get("cards"), list):
            return data["cards"]
        # column-keyed maps
        out: list[dict[str, Any]] = []
        for key, val in data.items():
            if isinstance(val, list) and val and isinstance(val[0], dict) and "slug" in val[0]:
                for c in val:
                    card = dict(c)
                    card.setdefault("column", key)
                    out.append(card)
        if out:
            return out
    raise ValueError(f"unrecognized cards JSON shape in {path}")


def load_projects_from_file(path: Path) -> list[dict[str, Any]]:
    data = json.loads(path.read_text(encoding="utf-8"))
    if isinstance(data, list):
        return data
    if isinstance(data, dict) and isinstance(data.get("records"), list):
        return data["records"]
    raise ValueError(f"unrecognized projects JSON shape in {path}")


def fetch_live(board: str) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
    cards = run_json(["kanban", "list", "--board", board, "--json", "--all"])
    if not isinstance(cards, list):
        raise RuntimeError("kanban list --json did not return a list")
    projects = run_json(["brain", "list", "--type", "project", "--json", "--limit", "200"])
    if not isinstance(projects, list):
        raise RuntimeError("brain list --json did not return a list")
    return cards, projects


def build_model(
    cards: list[dict[str, Any]],
    projects: list[dict[str, Any]],
) -> dict[str, Any]:
    ns_projects = [p for p in projects if is_north_star_project(p)]
    by_slug: dict[str, dict[str, Any]] = {
        str(p.get("slug")): p for p in ns_projects if p.get("slug")
    }

    # Group cards by resolved north_star.
    groups: dict[str, list[dict[str, Any]]] = defaultdict(list)
    unattributed: list[dict[str, Any]] = []
    for card in cards:
        ns = normalize_north_star(card.get("north_star"))
        if not ns:
            unattributed.append(card)
            continue
        groups[ns].append(card)

    # Active first (in_progress / planning), then others, then orphans with cards.
    def ns_sort_key(slug: str) -> tuple[int, str]:
        rec = by_slug.get(slug)
        if rec is None:
            return (2, slug)
        status = str(rec.get("status") or "")
        if status in {"in_progress", "planning"}:
            return (0, slug)
        if status in {"archived", "done"}:
            return (1, slug)
        return (1, slug)

    all_ns = set(by_slug) | set(groups)
    ordered_ns = sorted(all_ns, key=ns_sort_key)

    sections: list[dict[str, Any]] = []
    for slug in ordered_ns:
        rec = by_slug.get(slug)
        member_cards = groups.get(slug, [])
        col_counts = Counter(str(c.get("column") or "?") for c in member_cards)
        live = [c for c in member_cards if str(c.get("column") or "") in LIVE_COLUMNS]
        done_n = col_counts.get("done", 0)
        total = len(member_cards)
        pct = int(round(100.0 * done_n / total)) if total else 0

        def card_sort(c: dict[str, Any]) -> tuple[int, str, str]:
            col = str(c.get("column") or "")
            try:
                col_i = COLUMNS.index(col)  # type: ignore[arg-type]
            except ValueError:
                col_i = 99
            pri = priority_of(c)
            pri_i = {"P0": 0, "P1": 1, "P2": 2, "P3": 3}.get(pri, 9)
            return (col_i, pri_i, str(c.get("slug") or ""))

        live_sorted = sorted(live, key=card_sort)
        sections.append(
            {
                "slug": slug,
                "title": (rec or {}).get("title") or slug,
                "status": (rec or {}).get("status") or ("orphan" if member_cards else "missing"),
                "tags": list((rec or {}).get("tags") or []),
                "record_present": rec is not None,
                "counts": {col: int(col_counts.get(col, 0)) for col in COLUMNS},
                "other_counts": {
                    k: v for k, v in col_counts.items() if k not in COLUMNS
                },
                "total": total,
                "done": done_n,
                "live": len(live),
                "pct_done": pct,
                "live_cards": live_sorted,
                "blocked_cards": [
                    c
                    for c in live_sorted
                    if c.get("blocked")
                    or str(c.get("block_status") or "none") not in {"", "none"}
                ],
            }
        )

    board_counts = Counter(str(c.get("column") or "?") for c in cards)
    active_sections = [
        s
        for s in sections
        if s["status"] in {"in_progress", "planning"} or (s["live"] > 0 and s["record_present"])
    ]

    hygiene = build_hygiene(sections, by_slug, groups, unattributed)
    completion = attach_completion(sections, by_slug, groups, cards)

    return {
        "generated_at": now_iso(),
        "board_total": len(cards),
        "board_counts": {col: int(board_counts.get(col, 0)) for col in COLUMNS},
        "north_star_records": len(by_slug),
        "sections": sections,
        "active_sections": active_sections,
        "unattributed": {
            "total": len(unattributed),
            "live": sorted(
                [c for c in unattributed if str(c.get("column") or "") in LIVE_COLUMNS],
                key=lambda c: (
                    COLUMNS.index(c["column"]) if c.get("column") in COLUMNS else 99,
                    str(c.get("slug") or ""),
                ),
            ),
            "by_column": dict(Counter(str(c.get("column") or "?") for c in unattributed)),
        },
        "aliases": ALIASES,
        "hygiene": hygiene,
        "completion": completion,
    }


def _tokens(text: str) -> set[str]:
    return {t for t in re.split(r"[^a-z0-9]+", (text or "").lower()) if len(t) >= 3}


def _family_hits(tokens: set[str]) -> set[str]:
    hits: set[str] = set()
    for family, fam_tokens in NS_TOKEN_FAMILIES.items():
        if tokens & fam_tokens:
            hits.add(family)
    return hits


def build_hygiene(
    sections: list[dict[str, Any]],
    by_slug: dict[str, dict[str, Any]],
    groups: dict[str, list[dict[str, Any]]],
    unattributed: list[dict[str, Any]],
) -> dict[str, Any]:
    """Structured actions for north-star-hygiene skill/routine."""
    orphan_live: list[dict[str, Any]] = []
    orphan_done_only: list[dict[str, Any]] = []
    for s in sections:
        if s["record_present"]:
            continue
        if s["total"] == 0:
            continue
        entry = {
            "slug": s["slug"],
            "live": s["live"],
            "total": s["total"],
            "done": s["done"],
            "live_slugs": [c.get("slug") for c in s["live_cards"]],
            "action": "create_north_star_project",
            "priority": "P1" if s["live"] else "P3",
        }
        if s["live"] > 0:
            orphan_live.append(entry)
        else:
            orphan_done_only.append(entry)

    # Prefer live orphans first, then done-only (still useful for checkpoints).
    orphan_live.sort(key=lambda e: (-e["live"], e["slug"]))
    orphan_done_only.sort(key=lambda e: (-e["total"], e["slug"]))

    mistag_candidates: list[dict[str, Any]] = []
    for ns_slug, member_cards in groups.items():
        ns_tokens = _tokens(ns_slug)
        ns_fams = _family_hits(ns_tokens)
        if not ns_fams:
            continue
        for card in member_cards:
            if str(card.get("column") or "") not in LIVE_COLUMNS:
                continue
            blob = f"{card.get('slug') or ''} {card.get('title') or ''}"
            card_tokens = _tokens(blob)
            card_fams = _family_hits(card_tokens)
            # Card strongly matches another product family and none of the NS family.
            if card_fams and not (card_fams & ns_fams) and (card_fams - ns_fams):
                mistag_candidates.append(
                    {
                        "slug": card.get("slug"),
                        "column": card.get("column"),
                        "title": card.get("title"),
                        "north_star": ns_slug,
                        "card_families": sorted(card_fams),
                        "ns_families": sorted(ns_fams),
                        "action": "clear_or_repoint_north_star",
                        "confidence": "heuristic",
                    }
                )

    mistag_candidates.sort(key=lambda e: (str(e.get("north_star")), str(e.get("slug"))))

    live_unattributed = [
        c for c in unattributed if str(c.get("column") or "") in LIVE_COLUMNS
    ]

    return {
        "orphan_north_stars_live": orphan_live,
        "orphan_north_stars_done_only": orphan_done_only,
        "mistag_candidates": mistag_candidates,
        "unattributed_live_count": len(live_unattributed),
        "summary": {
            "orphan_live_count": len(orphan_live),
            "orphan_done_only_count": len(orphan_done_only),
            "mistag_candidate_count": len(mistag_candidates),
            "unattributed_live_count": len(live_unattributed),
            "needs_work": bool(orphan_live or mistag_candidates),
        },
    }


def render_hygiene_markdown(model: dict[str, Any]) -> str:
    h = model.get("hygiene") or {}
    lines: list[str] = []
    lines.append("# North Star hygiene report")
    lines.append("")
    lines.append(f"**Generated:** `{model.get('generated_at')}`")
    lines.append("")
    summary = h.get("summary") or {}
    lines.append(
        f"- orphan NS with **live** cards: **{summary.get('orphan_live_count', 0)}** "
        f"(create brain project)"
    )
    lines.append(
        f"- orphan NS done-only: **{summary.get('orphan_done_only_count', 0)}** "
        f"(optional create for checkpoints)"
    )
    lines.append(
        f"- mistag candidates (heuristic): **{summary.get('mistag_candidate_count', 0)}**"
    )
    lines.append(
        f"- unattributed live cards: **{summary.get('unattributed_live_count', 0)}** "
        f"(report only — do not invent NS)"
    )
    lines.append("")
    if not summary.get("needs_work") and not h.get("orphan_north_stars_done_only"):
        lines.append("_No hygiene actions needed._")
        lines.append("")
        return "\n".join(lines)

    if h.get("orphan_north_stars_live"):
        lines.append("## Orphan North Stars (live cards) — CREATE PROJECT")
        lines.append("")
        for e in h["orphan_north_stars_live"]:
            lines.append(
                f"### `{e['slug']}` · live={e['live']} total={e['total']} · {e['priority']}"
            )
            lines.append("")
            lines.append(f"- **action:** `{e['action']}`")
            lines.append(
                "- **live cards:** "
                + (", ".join(f"`{s}`" for s in (e.get("live_slugs") or [])[:20]) or "—")
            )
            lines.append("")
    if h.get("orphan_north_stars_done_only"):
        lines.append("## Orphan North Stars (done-only) — optional create")
        lines.append("")
        for e in h["orphan_north_stars_done_only"]:
            lines.append(
                f"- `{e['slug']}` · done={e['done']} total={e['total']} · "
                f"action=`{e['action']}`"
            )
        lines.append("")
    if h.get("mistag_candidates"):
        lines.append("## Mistag candidates (heuristic — agent confirms before clear)")
        lines.append("")
        for e in h["mistag_candidates"]:
            lines.append(
                f"- `{e['slug']}` ({e['column']}) → ns `{e['north_star']}` · "
                f"card_fams={e['card_families']} ns_fams={e['ns_families']}"
            )
        lines.append("")
    lines.append(
        "Run the **north-star-hygiene** skill/routine to materialize projects and "
        "clear confirmed mis-tags, then `last-stack-north-star-dashboard --put-brain`."
    )
    lines.append("")
    return "\n".join(lines)


def fmt_card_line(card: dict[str, Any]) -> str:
    slug = card.get("slug") or "?"
    col = card.get("column") or "?"
    kind = card.get("kind") or ""
    pri = priority_of(card)
    bits = [f"`{slug}`", f"({col})"]
    if pri:
        bits.append(pri)
    if kind and kind != "pr":
        bits.append(f"kind:{kind}")
    if card.get("blocked"):
        by = ",".join(card.get("blockedBy") or []) or "deps"
        bits.append(f"blocked:{by}")
    if card.get("block_status") and card.get("block_status") != "none":
        bits.append(f"hold:{card.get('block_status')}")
    if card.get("pr_url"):
        bits.append("has-pr")
    return "- " + " ".join(bits)


def render_markdown(model: dict[str, Any]) -> str:
    lines: list[str] = []
    lines.append("# North Star dashboard")
    lines.append("")
    lines.append(
        f"**Generated:** `{model['generated_at']}` · "
        f"**Board cards:** {model['board_total']} · "
        f"**NS records:** {model['north_star_records']}"
    )
    lines.append("")
    lines.append(
        "Point-in-time rollup of kanban cards by the card `north_star` field "
        "(aliases applied) against brain `project` North Star records. "
        "Regenerate with `last-stack-north-star-dashboard`."
    )
    lines.append("")
    lines.append("## Board funnel")
    lines.append("")
    bc = model["board_counts"]
    lines.append(
        "| "
        + " | ".join(COLUMNS)
        + " | total |"
    )
    lines.append("| " + " | ".join(["---:"] * (len(COLUMNS) + 1)) + " |")
    lines.append(
        "| "
        + " | ".join(str(bc.get(c, 0)) for c in COLUMNS)
        + f" | {model['board_total']} |"
    )
    lines.append("")
    lines.append("## Active North Stars (live pressure)")
    lines.append("")
    lines.append(
        "| North Star | status | terminal | verdict | backlog | todo | doing | review | done | live | %done |"
    )
    lines.append("|---|---|---|---|---:|---:|---:|---:|---:|---:|---:|")
    for s in model["active_sections"]:
        c = s["counts"]
        comp = s.get("completion") or {}
        term = comp.get("terminal_slug") or "—"
        verdict = comp.get("verdict") or "—"
        lines.append(
            f"| `{s['slug']}` | {s['status']} | `{term}` | {verdict} | "
            f"{c['backlog']} | {c['todo']} | {c['doing']} | {c['review']} | "
            f"{c['done']} | {s['live']} | {s['pct_done']}% |"
        )
    if not model["active_sections"]:
        lines.append("| _(none)_ | | | | | | | | | | |")
    lines.append("")

    for s in model["sections"]:
        # Skip empty archived orphans with zero cards? Keep all with cards or records.
        if not s["record_present"] and s["total"] == 0:
            continue
        title = s["title"]
        lines.append(f"## {title}")
        lines.append("")
        lines.append(f"- **slug:** `[[{s['slug']}]]`")
        lines.append(f"- **status:** `{s['status']}`")
        comp = s.get("completion") or {}
        if comp:
            lines.append(
                f"- **terminal:** `{comp.get('terminal_slug') or '—'}` "
                f"({comp.get('terminal_state') or 'missing'}, "
                f"quality={comp.get('terminal_quality')}, "
                f"verdict={comp.get('verdict')})"
            )
            if comp.get("flags"):
                lines.append(f"- **completion flags:** {', '.join(comp['flags'])}")
        if not s["record_present"]:
            lines.append(
                "- **record:** missing brain project (cards still reference this slug)"
            )
        c = s["counts"]
        lines.append(
            f"- **counts:** backlog={c['backlog']} · todo={c['todo']} · "
            f"doing={c['doing']} · review={c['review']} · done={c['done']} "
            f"· live={s['live']} · total={s['total']} · {s['pct_done']}% done"
        )
        if s["blocked_cards"]:
            lines.append(
                "- **blocked/held:** "
                + ", ".join(f"`{c.get('slug')}`" for c in s["blocked_cards"][:12])
            )
        lines.append("")
        if s["live_cards"]:
            lines.append("### Live cards")
            lines.append("")
            for card in s["live_cards"]:
                lines.append(fmt_card_line(card))
            lines.append("")
        else:
            lines.append("_No live (non-done) cards attributed to this North Star._")
            lines.append("")

    ua = model["unattributed"]
    lines.append("## Unattributed cards (no `north_star`)")
    lines.append("")
    lines.append(
        f"**{ua['total']}** cards have no `north_star` "
        f"(live: {len(ua['live'])}; by column: `{ua['by_column']}`)."
    )
    lines.append("")
    if ua["live"]:
        lines.append("### Live unattributed (sample ≤40)")
        lines.append("")
        for card in ua["live"][:40]:
            lines.append(fmt_card_line(card))
        lines.append("")

    if model["aliases"]:
        lines.append("## Aliases applied")
        lines.append("")
        for src, dst in sorted(model["aliases"].items()):
            lines.append(f"- `{src}` → `{dst}`")
        lines.append("")

    # Compact hygiene summary so the dashboard brain record surfaces work items.
    h = model.get("hygiene") or {}
    summary = h.get("summary") or {}
    if summary.get("orphan_live_count") or summary.get("mistag_candidate_count"):
        lines.append("## Hygiene (needs action)")
        lines.append("")
        lines.append(
            f"- **orphan NS with live cards:** {summary.get('orphan_live_count', 0)} "
            f"— create brain `project` (skill/routine `north-star-hygiene`)"
        )
        for e in (h.get("orphan_north_stars_live") or [])[:8]:
            lines.append(
                f"  - `{e['slug']}` live={e['live']} total={e['total']}"
            )
        lines.append(
            f"- **mistag candidates:** {summary.get('mistag_candidate_count', 0)} "
            f"(heuristic; confirm before clearing)"
        )
        lines.append(
            f"- **unattributed live:** {summary.get('unattributed_live_count', 0)}"
        )
        lines.append("")

    lines.append("## How to refresh")
    lines.append("")
    lines.append("```bash")
    lines.append("last-stack-north-star-dashboard --put-brain --html ~/code/edgevector/north-star-dashboard.html")
    lines.append("last-stack-north-star-dashboard --stdout hygiene   # orphan/mistag report only")
    lines.append("last-stack-north-star-completion-check            # terminal verification contract")
    lines.append("```")
    lines.append("")
    lines.append(
        "Routines: `north-star-rollup` (hourly matrix) · `north-star-hygiene` "
        "(materialize orphan NS projects) · `program-driver` (terminal feed + "
        "completion). Related: `[[active-programs]]`, "
        "`[[sop-north-star-terminal-verification]]`, `program-rollup`."
    )
    lines.append("")
    return "\n".join(lines)


def render_html(model: dict[str, Any]) -> str:
    def esc(s: Any) -> str:
        return html.escape(str(s if s is not None else ""), quote=True)

    bc = model["board_counts"]
    stats = "".join(
        f'<div class="stat"><b>{bc.get(col, 0)}</b><span>{col}</span></div>'
        for col in COLUMNS
    )
    stats += (
        f'<div class="stat"><b>{model["board_total"]}</b><span>total cards</span></div>'
        f'<div class="stat"><b>{model["north_star_records"]}</b><span>NS records</span></div>'
        f'<div class="stat"><b>{len(model["active_sections"])}</b><span>active NS</span></div>'
    )

    cards_html: list[str] = []
    for s in model["sections"]:
        if not s["record_present"] and s["total"] == 0:
            continue
        status = s["status"]
        status_class = "active" if status in {"in_progress", "planning"} else (
            "orphan" if status == "orphan" else "closed"
        )
        c = s["counts"]
        mini = []
        for card in s["live_cards"][:24]:
            col = esc(card.get("column") or "")
            slug = esc(card.get("slug") or "")
            title = esc(card.get("title") or card.get("slug") or "")
            pri = priority_of(card)
            pri_s = f" · {pri}" if pri else ""
            mini.append(
                f'<div class="mini {col}"><span>{col}{esc(pri_s)}</span>'
                f"<b>{slug}</b><span>{title}</span></div>"
            )
        if not mini:
            mini_html = '<div class="muted">No live cards.</div>'
        else:
            mini_html = f'<div class="mini-cards">{"".join(mini)}</div>'

        search_blob = " ".join(
            [
                s["slug"],
                str(s["title"]),
                status,
                " ".join(str(c.get("slug") or "") for c in s["live_cards"]),
            ]
        ).lower()

        cards_html.append(
            f'<section class="program" data-status="{esc(status_class)}" '
            f'data-text="{esc(search_blob)}">'
            f'<div class="program-head"><div>'
            f'<h3>{esc(s["title"])}</h3>'
            f'<div class="slug">{esc(s["slug"])}</div></div>'
            f'<div class="program-metrics">'
            f'<span class="pill {status_class}">{esc(status)}</span> '
            f'<span class="pill">{s["live"]} live</span> '
            f'<span class="pill">{s["pct_done"]}% done</span>'
            f"</div></div>"
            f'<div class="bar"><span style="width:{s["pct_done"]}%"></span></div>'
            f'<p class="brief">backlog {c["backlog"]} · todo {c["todo"]} · '
            f'doing {c["doing"]} · review {c["review"]} · done {c["done"]}</p>'
            f"{mini_html}</section>"
        )

    # Matrix table
    rows = []
    for s in model["active_sections"]:
        c = s["counts"]
        comp = s.get("completion") or {}
        rows.append(
            "<tr>"
            f'<td><code>{esc(s["slug"])}</code><div class="muted">{esc(s["title"])}</div></td>'
            f'<td>{esc(s["status"])}</td>'
            f'<td><code>{esc(comp.get("terminal_slug") or "—")}</code></td>'
            f'<td>{esc(comp.get("verdict") or "—")}</td>'
            + "".join(f"<td>{c[col]}</td>" for col in COLUMNS)
            + f'<td><b>{s["live"]}</b></td>'
            f'<td>{s["pct_done"]}%</td>'
            "</tr>"
        )

    ua = model["unattributed"]
    ua_rows = []
    for card in ua["live"][:60]:
        ua_rows.append(
            "<tr>"
            f'<td><code>{esc(card.get("slug"))}</code></td>'
            f'<td>{esc(card.get("column"))}</td>'
            f'<td>{esc(priority_of(card) or "—")}</td>'
            f'<td>{esc(card.get("kind") or "")}</td>'
            f'<td>{esc(card.get("title") or "")}</td>'
            "</tr>"
        )

    return f"""<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>North Star dashboard</title>
<style>
:root{{--bg:#f4f1ea;--ink:#1c1917;--muted:#78716c;--line:#d6d3d1;--panel:#fffdf8;--blue:#1d4ed8;--green:#15803d;--amber:#b45309;--red:#b91c1c;--violet:#6d28d9;--slate:#57534e;--teal:#0f766e}}
*{{box-sizing:border-box}} body{{margin:0;font:14px/1.45 ui-sans-serif,system-ui,-apple-system,Segoe UI,sans-serif;background:var(--bg);color:var(--ink)}}
header{{background:#1c1917;color:#fafaf9;padding:28px 32px 22px}} header h1{{margin:0 0 6px;font-size:28px}} header p{{margin:0;color:#a8a29e;max-width:920px}}
main{{padding:24px 32px 48px;max-width:1400px;margin:0 auto}}
.topline{{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:18px}}
.stat{{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:12px 14px;min-width:110px}}
.stat b{{display:block;font-size:24px}} .stat span{{color:var(--muted);font-size:12px}}
