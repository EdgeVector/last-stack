#!/usr/bin/env bash
# The Last Stack — uninstall
# Removes the skill directories this repo registered into each agent harness.
# Only removes entries whose SKILL.md points back into THIS repo's skills/ dir
# (or is a copy of it), so it never touches skills you added yourself.
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
SKILLS_SRC="$ROOT/skills"

# Collect the skill names this repo provides.
names=()
for skill_dir in "$SKILLS_SRC"/*/; do
  [ -f "$skill_dir/SKILL.md" ] || continue
  n="$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')"
  [ -z "$n" ] && n="$(basename "$skill_dir")"
  names+=("$n")
done

remove_from() {
  local skills_dir="$1" label="$2"
  [ -d "$skills_dir" ] || return 0
  local removed=()
  for n in "${names[@]}"; do
    local target="$skills_dir/$n"
    [ -e "$target" ] || [ -L "$target" ] || continue
    # Only remove if the SKILL.md links/copies from this repo.
    local md="$target/SKILL.md" dest=""
    if [ -L "$md" ]; then dest="$(readlink "$md" 2>/dev/null || true)"; fi
    case "$dest" in
      "$SKILLS_SRC"/*) rm -rf "$target"; removed+=("$n") ;;
      *)
        # Windows copy case: match on a stable marker line.
        if [ -f "$md" ] && grep -q "^name:[[:space:]]*$n" "$md" 2>/dev/null; then
          rm -rf "$target"; removed+=("$n")
        fi
        ;;
    esac
  done
  [ ${#removed[@]} -gt 0 ] && echo "  $label: removed ${removed[*]}"
  return 0
}

remove_brain_kanban_block() {
  # Strip the setup-managed brain-kanban block from a harness instructions file.
  local file="$1" label="$2"
  [ -f "$file" ] || return 0
  grep -q 'last-stack:brain-kanban:start' "$file" || return 0
  local tmp
  tmp="$(mktemp)"
  awk '
    /last-stack:brain-kanban:start/ { ib = 1; next }
    /last-stack:brain-kanban:end/   { ib = 0; next }
    !ib { lines[++n] = $0 }
    END {
      while (n > 0 && lines[n] == "") n--
      for (i = 1; i <= n; i++) print lines[i]
    }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
  echo "  $label: removed brain-kanban instructions block"
}

echo "Uninstalling The Last Stack skills ..."
remove_from "$HOME/.claude/skills"          "claude"
remove_from "$HOME/.codex/skills"           "codex"
remove_from "$HOME/.factory/skills"         "factory"
remove_from "$HOME/.config/opencode/skills" "opencode"
remove_brain_kanban_block "$HOME/.codex/AGENTS.md"           "codex"
remove_brain_kanban_block "$HOME/.factory/AGENTS.md"         "factory"
remove_brain_kanban_block "$HOME/.config/opencode/AGENTS.md" "opencode"
echo "Done. (This repo at $ROOT is left in place — delete it to fully remove."
echo "       MCP server entries in ~/.codex/config.toml are kept; remove manually if unwanted.)"
