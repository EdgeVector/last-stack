#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  source_dir="$(cd "$(dirname "$SOURCE")" && pwd -P)"
  link_target="$(readlink "$SOURCE")"
  case "$link_target" in
    /*) SOURCE="$link_target" ;;
    *) SOURCE="$source_dir/$link_target" ;;
  esac
done
ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd -P)"
if [ -n "${HOST_TRACK_REGISTRY:-}" ]; then
  REGISTRY="$HOST_TRACK_REGISTRY"
  REGISTRY_IS_DEFAULT=0
elif [ -f "$ROOT/config/host-track/apps.json" ]; then
  REGISTRY="$ROOT/config/host-track/apps.json"
  REGISTRY_IS_DEFAULT=1
else
  REGISTRY="$HOME/.local/share/last-stack/config/host-track/apps.json"
  REGISTRY_IS_DEFAULT=1
fi
STAMP_DIR="${HOST_TRACK_STAMP_DIR:-$HOME/.host-track/stamps}"
ARTIFACT_ROOT_DEFAULT="${HOST_TRACK_ARTIFACT_ROOT:-$HOME/.lastgit/artifacts}"
INSTALL_ROOT_DEFAULT="${HOST_TRACK_INSTALL_ROOT:-$HOME/.host-track/apps}"
REGISTRY_SYNC_ATTEMPTED=0

usage() {
  cat >&2 <<'EOF'
Usage:
  host-track status [--json] [app]
  host-track which [--json] <app>
  host-track check <app>
  host-track refresh [--force] (<app>|--all)
  host-track install [--channel candidate|canary|stable] <app>
  host-track rollback <app>

Environment:
  HOST_TRACK_REGISTRY   Registry JSON path (default: last-stack config)
  HOST_TRACK_STAMP_DIR  Stamp directory (default: ~/.host-track/stamps)
  HOST_TRACK_ARTIFACT_ROOT  LastGit artifact CAS (default: ~/.lastgit/artifacts)
  HOST_TRACK_INSTALL_ROOT   Immutable app installs (default: ~/.host-track/apps)
EOF
}

die() {
  printf 'host-track: %s\n' "$*" >&2
  exit 2
}

need_jq() {
  command -v jq >/dev/null 2>&1 || die "jq is required"
}

expand_path() {
  case "${1:-}" in
    "") printf '\n' ;;
    '$HOME') printf '%s\n' "$HOME" ;;
    '$HOME'/*) printf '%s/%s\n' "$HOME" "${1#\$HOME/}" ;;
    "~") printf '%s\n' "$HOME" ;;
    "~"/*) printf '%s/%s\n' "$HOME" "${1#~/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

app_json() {
  local app="$1"
  jq -c --arg app "$app" '.apps[]? | select(.app == $app)' "$REGISTRY"
}

maybe_sync_default_registry() {
  local self_upgrade
  [ "$REGISTRY_IS_DEFAULT" -eq 1 ] || return 1
  [ "$REGISTRY_SYNC_ATTEMPTED" -eq 0 ] || return 1
  REGISTRY_SYNC_ATTEMPTED=1

  self_upgrade="$ROOT/bin/last-stack-self-upgrade"
  [ -x "$self_upgrade" ] || return 1
  "$self_upgrade" --reason=host-track-registry-miss >/dev/null 2>&1 || return 1

  if [ -f "$ROOT/config/host-track/apps.json" ]; then
    REGISTRY="$ROOT/config/host-track/apps.json"
  fi
  return 0
}

require_app_json() {
  local app="$1" json
  json="$(app_json "$app")"
  if [ -z "$json" ]; then
    maybe_sync_default_registry || true
    json="$(app_json "$app")"
  fi
  [ -n "$json" ] || die "unknown app: $app"
  printf '%s\n' "$json"
}

field() {
  local json="$1" key="$2"
  printf '%s\n' "$json" | jq -r --arg key "$key" '.[$key] // ""'
}

setting() {
  local json="$1" key="$2" value
  value="$(field "$json" "$key")"
  if [ -z "$value" ]; then
    value="$(jq -r --arg key "$key" '.defaults[$key] // ""' "$REGISTRY")"
  fi
  printf '%s\n' "$value"
}

git_head() {
  local path="$1"
  [ -n "$path" ] || return 0
  git -C "$path" rev-parse HEAD 2>/dev/null || true
}

git_head_short() {
  local path="$1"
  [ -n "$path" ] || return 0
  git -C "$path" rev-parse --short HEAD 2>/dev/null || true
}

version_file() {
  local path="$1"
  [ -n "$path" ] || return 0
  [ -f "$path/VERSION" ] || return 0
  sed -n '1p' "$path/VERSION"
}

git_dirty() {
  local path="$1"
  [ -n "$path" ] || return 1
  [ -d "$path/.git" ] || return 1
  [ -z "$(git -C "$path" status --porcelain)" ]
}

gate_head() {
  local host_track="$1" remote="$2" ref="$3"
  [ -n "$host_track" ] || return 0
  [ -n "$remote" ] || return 0
  [ -n "$ref" ] || return 0
  git -C "$host_track" ls-remote "$remote" "$ref" 2>/dev/null | awk 'NR == 1 {print $1}' || true
}

command_path() {
  local command_name="$1"
  [ -n "$command_name" ] || return 0
  command -v "$command_name" 2>/dev/null || true
}

hash_file() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    die "shasum or sha256sum is required"
  fi
}

artifact_paths() {
  local app="$1" json="$2" artifact_app channel artifact_root install_root
  artifact_app="$(field "$json" artifact_app)"
  [ -n "$artifact_app" ] || artifact_app="$app"
  channel="$(setting "$json" artifact_channel)"
  [ -n "$channel" ] || channel="stable"
  artifact_root="$(expand_path "$(setting "$json" artifact_root)")"
  [ -n "$artifact_root" ] || artifact_root="$ARTIFACT_ROOT_DEFAULT"
  install_root="$(expand_path "$(field "$json" install_root)")"
  [ -n "$install_root" ] || install_root="$INSTALL_ROOT_DEFAULT/$app"
  printf '%s\t%s\t%s\t%s\n' "$artifact_app" "$channel" "$artifact_root" "$install_root"
}

artifact_channel_manifest() {
  local artifact_root="$1" artifact_app="$2" channel="$3" path
  path="$artifact_root/channels/$artifact_app/$channel.json"
  [ -f "$path" ] || return 0
  jq -r '.manifest_digest // ""' "$path" 2>/dev/null || true
}

status_json_for() {
  local app="$1" json kind command_name gate gate_main host_track_raw host_track refresh_raw refresh_path
  local gate_remote gate_ref notes exec_path host_head host_head_short version gate_tip stale stamp_path
  local install_mode artifact_app artifact_channel artifact_root install_root installed_digest channel_digest

  json="$(require_app_json "$app")"
  kind="$(field "$json" kind)"
  command_name="$(field "$json" command)"
  gate="$(field "$json" gate)"
  gate_main="$(field "$json" gate_main)"
  host_track_raw="$(field "$json" host_track)"
  host_track="$(expand_path "$host_track_raw")"
  refresh_raw="$(field "$json" refresh)"
  refresh_path="$(expand_path "$refresh_raw")"
  gate_remote="$(field "$json" gate_remote)"
  gate_ref="$(field "$json" gate_ref)"
  notes="$(field "$json" notes)"
  install_mode="$(setting "$json" install_mode)"
  [ -n "$install_mode" ] || install_mode="checkout"
  exec_path="$(command_path "$command_name")"
  stamp_path="$STAMP_DIR/$app.json"

  artifact_app=""
  artifact_channel=""
  artifact_root=""
  install_root=""
  installed_digest=""
  channel_digest=""
  if [ "$install_mode" = "artifact" ]; then
    IFS=$'\t' read -r artifact_app artifact_channel artifact_root install_root < <(artifact_paths "$app" "$json")
    host_track="$install_root/current"
    installed_digest="$(jq -r '.manifest_digest // ""' "$stamp_path" 2>/dev/null || true)"
    channel_digest="$(artifact_channel_manifest "$artifact_root" "$artifact_app" "$artifact_channel")"
    host_head="$(jq -r '.source_oid // ""' "$stamp_path" 2>/dev/null || true)"
    host_head_short="${host_head:0:12}"
    gate_tip="$(jq -r '.source_oid // ""' "$artifact_root/channels/$artifact_app/$artifact_channel.json" 2>/dev/null || true)"
    version=""
    stale="null"
    if [ -n "$channel_digest" ]; then
      if [ "$installed_digest" = "$channel_digest" ] && [ -L "$install_root/current" ]; then
        stale="false"
      else
        stale="true"
      fi
    fi
  else
    host_head="$(git_head "$host_track")"
    host_head_short="$(git_head_short "$host_track")"
    version="$(version_file "$host_track")"
    gate_tip="$(gate_head "$host_track" "$gate_remote" "$gate_ref")"
    stale="null"
    if [ -n "$host_head" ] && [ -n "$gate_tip" ]; then
      if [ "$host_head" = "$gate_tip" ]; then stale="false"; else stale="true"; fi
    fi
  fi

  jq -c -n \
    --arg app "$app" \
    --arg command "$command_name" \
    --arg gate "$gate" \
    --arg gate_main "$gate_main" \
    --arg host_track "$host_track" \
    --arg host_head "$host_head" \
    --arg host_head_short "$host_head_short" \
    --arg version "$version" \
    --arg gate_head "$gate_tip" \
    --arg exec_path "$exec_path" \
    --arg kind "$kind" \
    --arg notes "$notes" \
    --arg refresh "$refresh_path" \
    --arg stamp "$stamp_path" \
    --arg install_mode "$install_mode" \
    --arg artifact_app "$artifact_app" \
    --arg artifact_channel "$artifact_channel" \
    --arg artifact_root "$artifact_root" \
    --arg install_root "$install_root" \
    --arg manifest_digest "$installed_digest" \
    --arg channel_manifest_digest "$channel_digest" \
    --argjson stale "$stale" \
    '{
      app: $app,
      command: $command,
      gate: $gate,
      gate_main: $gate_main,
      host_track: $host_track,
      host_head: ($host_head | select(length > 0) // null),
      host_head_short: ($host_head_short | select(length > 0) // null),
      version: ($version | select(length > 0) // null),
      gate_head: ($gate_head | select(length > 0) // null),
      exec_path: ($exec_path | select(length > 0) // null),
      kind: $kind,
      install_mode: $install_mode,
      stale: $stale,
      stamp: $stamp,
      refresh: ($refresh | select(length > 0) // null),
      artifact_app: ($artifact_app | select(length > 0) // null),
      artifact_channel: ($artifact_channel | select(length > 0) // null),
      artifact_root: ($artifact_root | select(length > 0) // null),
      install_root: ($install_root | select(length > 0) // null),
      manifest_digest: ($manifest_digest | select(length > 0) // null),
      channel_manifest_digest: ($channel_manifest_digest | select(length > 0) // null),
      notes: $notes
    }'
}

status_plain_for() {
  local status="$1"
  printf '%s\n' "$status" | jq -r '
    [
      "app=" + .app,
      "kind=" + .kind,
      "install_mode=" + .install_mode,
      "command=" + .command,
      "exec_path=" + (.exec_path // "-"),
      "host_track=" + .host_track,
      "version=" + (.version // "-"),
      "host_head=" + (.host_head // "-"),
      "gate_head=" + (.gate_head // "-"),
      "stale=" + (.stale | tostring),
      "notes=" + .notes
    ] | @tsv'
}

list_apps() {
  jq -r '.apps[]?.app' "$REGISTRY"
}

status_cmd() {
  local json_out=0 app="" statuses=() one
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json_out=1; shift ;;
      -h|--help) usage; exit 0 ;;
      --*) die "unknown status flag: $1" ;;
      *) app="$1"; shift ;;
    esac
  done

  if [ -n "$app" ]; then
    one="$(status_json_for "$app")"
    if [ "$json_out" -eq 1 ]; then
      printf '%s\n' "$one"
    else
      status_plain_for "$one"
    fi
    return
  fi

  while IFS= read -r app; do
    [ -n "$app" ] || continue
    statuses+=("$(status_json_for "$app")")
  done < <(list_apps)

  if [ "$json_out" -eq 1 ]; then
    printf '%s\n' "${statuses[@]}" | jq -s '.'
  else
    printf '%s\n' "${statuses[@]}" | while IFS= read -r one; do
      [ -n "$one" ] || continue
      status_plain_for "$one"
    done
  fi
}

which_cmd() {
  local json_out=0 app="" status exec_path
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json_out=1; shift ;;
      -h|--help) usage; exit 0 ;;
      --*) die "unknown which flag: $1" ;;
      *) app="$1"; shift ;;
    esac
  done
  [ -n "$app" ] || die "which requires an app"
  status="$(status_json_for "$app")"
  exec_path="$(printf '%s\n' "$status" | jq -r '.exec_path // ""')"
  [ -n "$exec_path" ] || {
    printf 'host-track: no executable found for %s\n' "$app" >&2
    return 1
  }
  if [ "$json_out" -eq 1 ]; then
    printf '%s\n' "$status"
    return
  fi
  printf '%s\n' "$exec_path"
}

check_cmd() {
  local app="${1:-}" status exec_path stale json install_mode
  [ -n "$app" ] || die "check requires an app"
  status="$(status_json_for "$app")"
  exec_path="$(printf '%s\n' "$status" | jq -r '.exec_path // ""')"
  stale="$(printf '%s\n' "$status" | jq -r '.stale | tostring')"
  json="$(require_app_json "$app")"
  install_mode="$(setting "$json" install_mode)"
  [ -n "$install_mode" ] || install_mode="checkout"
  if [ -z "$exec_path" ]; then
    printf 'host-track: %s executable missing\n' "$app" >&2
    return 1
  fi
  if [ "$stale" = "true" ]; then
    printf 'host-track: %s stale\n' "$app" >&2
    return 1
  fi
  if [ "$install_mode" = "artifact" ] && ! verify_active_artifact "$app" "$json"; then
    printf 'host-track: %s active artifact verification failed\n' "$app" >&2
    return 1
  fi
  printf 'host-track: %s ok\n' "$app"
}

write_stamp() {
  local app="$1" status="$2"
  mkdir -p "$STAMP_DIR"
  printf '%s\n' "$status" | jq --arg refreshed_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '. + {refreshed_at: $refreshed_at}' > "$STAMP_DIR/$app.json"
}

base64_decode() {
  if printf '' | base64 --decode >/dev/null 2>&1; then
    base64 --decode
  else
    base64 -D
  fi
}

safe_artifact_relpath() {
  local rel="$1"
  [ -n "$rel" ] || return 1
  case "$rel" in
    /*|*\\*|*$'\n'*|*$'\r'*|*$'\t'*) return 1 ;;
  esac
  ! printf '%s\n' "$rel" | tr '/' '\n' | grep -qx '\.\.'
}

verify_active_artifact() {
  local app="$1" json="$2" artifact_app channel artifact_root install_root manifest digest current_target
  local encoded entry rel expected_sha active_file
  IFS=$'\t' read -r artifact_app channel artifact_root install_root < <(artifact_paths "$app" "$json")
  manifest="$(lastgit artifact resolve --app "$artifact_app" --channel "$channel" --root "$artifact_root" --json)" || return 1
  digest="$(printf '%s\n' "$manifest" | jq -r '.manifest_digest // ""')"
  [ -L "$install_root/current" ] || return 1
  current_target="$(readlink "$install_root/current")"
  [ "$current_target" = "versions/$digest" ] || return 1
  while IFS= read -r encoded; do
    [ -n "$encoded" ] || continue
    entry="$(printf '%s' "$encoded" | base64_decode)"
    rel="$(printf '%s\n' "$entry" | jq -r '.path')"
    expected_sha="$(printf '%s\n' "$entry" | jq -r '.sha256')"
    safe_artifact_relpath "$rel" || return 1
    active_file="$install_root/current/$rel"
    [ -f "$active_file" ] && [ ! -L "$active_file" ] || return 1
    [ "$(hash_file "$active_file")" = "$expected_sha" ] || return 1
  done < <(printf '%s\n' "$manifest" | jq -r '.files[] | @base64')
}

atomic_symlink() {
  local target="$1" link="$2" tmp
  mkdir -p "$(dirname "$link")"
  tmp="${link}.tmp-$$-$(date +%s)"
  ln -s "$target" "$tmp"
  if mv -f -h "$tmp" "$link" 2>/dev/null; then
    :
  elif mv -fT "$tmp" "$link" 2>/dev/null; then
    :
  else
    rm -f "$tmp"
    die "cannot atomically activate symlink: $link"
  fi
}

install_artifact_links() {
  local json="$1" install_root="$2" encoded entry source target_raw target
  while IFS= read -r encoded; do
    [ -n "$encoded" ] || continue
    entry="$(printf '%s' "$encoded" | base64_decode)"
    source="$(printf '%s\n' "$entry" | jq -r '.source // ""')"
    target_raw="$(printf '%s\n' "$entry" | jq -r '.target // ""')"
    safe_artifact_relpath "$source" || die "invalid artifact link source: $source"
    target="$(expand_path "$target_raw")"
    [ -n "$target" ] || die "artifact link target is required"
    [ -e "$install_root/current/$source" ] || die "artifact link source missing: $source"
    if [ -e "$target" ] && [ ! -L "$target" ]; then
      die "refusing to replace non-symlink artifact target: $target"
    fi
    atomic_symlink "$install_root/current/$source" "$target"
  done < <(printf '%s\n' "$json" | jq -r '.links[]? | @base64')
}

run_artifact_post_install() {
  local app="$1" json="$2" install_root="$3" digest="$4" post_install
  post_install="$(expand_path "$(field "$json" post_install)")"
  [ -n "$post_install" ] || return 0
  [ -x "$post_install" ] || die "artifact post-install is not executable: $post_install"
  HOST_TRACK_APP="$app" HOST_TRACK_INSTALL_ROOT="$install_root" \
    HOST_TRACK_MANIFEST_DIGEST="$digest" LAST_STACK_ROOT="$install_root/current" \
    "$post_install"
}

artifact_install_app() {
  local app="$1" channel_override="${2:-}" json install_mode artifact_app channel artifact_root install_root
  local manifest digest stage encoded entry rel expected_sha mode blob target actual_sha mode_octal
  local old_target stamp_path
  json="$(require_app_json "$app")"
  install_mode="$(setting "$json" install_mode)"
  [ "$install_mode" = "artifact" ] || die "$app is not registered for artifact installs"
  IFS=$'\t' read -r artifact_app channel artifact_root install_root < <(artifact_paths "$app" "$json")
  [ -z "$channel_override" ] || channel="$channel_override"
  case "$channel" in candidate|canary|stable) ;; *) die "invalid artifact channel: $channel" ;; esac
  command -v lastgit >/dev/null 2>&1 || die "lastgit is required for verified artifact installs"

  manifest="$(lastgit artifact resolve --app "$artifact_app" --channel "$channel" --root "$artifact_root" --json)"
  digest="$(printf '%s\n' "$manifest" | jq -r '.manifest_digest // ""')"
  [[ "$digest" =~ ^[0-9a-f]{64}$ ]] || die "resolved artifact has invalid manifest digest"
  mkdir -p "$install_root/versions"
  target="$install_root/versions/$digest"

  if [ ! -d "$target" ]; then
    stage="$(mktemp -d "$install_root/.stage-$digest.XXXXXX")"
    if ! (
      set -e
      while IFS= read -r encoded; do
        [ -n "$encoded" ] || continue
        entry="$(printf '%s' "$encoded" | base64_decode)"
        rel="$(printf '%s\n' "$entry" | jq -r '.path')"
        expected_sha="$(printf '%s\n' "$entry" | jq -r '.sha256')"
        mode="$(printf '%s\n' "$entry" | jq -r '.mode')"
        safe_artifact_relpath "$rel" || die "invalid artifact payload path: $rel"
        [[ "$expected_sha" =~ ^[0-9a-f]{64}$ ]] || die "invalid artifact blob digest: $rel"
        blob="$artifact_root/blobs/sha256/${expected_sha:0:2}/$expected_sha"
        [ -f "$blob" ] || die "artifact blob missing after verification: $rel"
        actual_sha="$(hash_file "$blob")"
        [ "$actual_sha" = "$expected_sha" ] || die "artifact blob changed during install: $rel"
        mkdir -p "$stage/$(dirname "$rel")"
        cp -p "$blob" "$stage/$rel"
        mode_octal="$(printf '%o' "$mode")"
        chmod "$mode_octal" "$stage/$rel"
        [ "$(hash_file "$stage/$rel")" = "$expected_sha" ] || die "installed artifact verification failed: $rel"
      done < <(printf '%s\n' "$manifest" | jq -r '.files[] | @base64')
    ); then
      rm -rf -- "$stage"
      return 1
    fi
    mv "$stage" "$target"
  fi

  # Last Stack only: freeze the installed version tree so agents cannot
  # hand-edit product files through ~/.last-stack compatibility symlinks.
  # Other artifact apps keep normal modes (post_install / binaries may need +w
  # bits from the manifest only).
  if [ "$app" = "last-stack" ] && [ -d "$target" ]; then
    chmod u+w "$target" 2>/dev/null || true
    find "$target" \( -type f -o -type d \) -exec chmod a-w {} + 2>/dev/null || \
      find "$target" \( -type f -o -type d \) -exec chmod a-w {} \; 2>/dev/null || true
  fi

  old_target=""
  [ ! -L "$install_root/current" ] || old_target="$(readlink "$install_root/current")"
  if [ -n "$old_target" ] && [ "$old_target" != "versions/$digest" ]; then
    atomic_symlink "$old_target" "$install_root/previous"
  fi
  atomic_symlink "versions/$digest" "$install_root/current"
  install_artifact_links "$json" "$install_root"
  run_artifact_post_install "$app" "$json" "$install_root" "$digest"

  stamp_path="$STAMP_DIR/$app.json"
  mkdir -p "$STAMP_DIR"
  printf '%s\n' "$manifest" | jq \
    --arg app "$app" --arg channel "$channel" --arg install_root "$install_root" \
    --arg artifact_root "$artifact_root" \
    --arg installed_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{app: $app, install_mode: "artifact", artifact_app: .app, artifact_channel: $channel,
      artifact_root: $artifact_root, install_root: $install_root, manifest_digest: .manifest_digest,
      source_oid: .source_oid, repo: .repo, platform: .platform, installed_at: $installed_at}' \
      > "$stamp_path"
  printf 'host-track: installed %s channel=%s oid=%s manifest=%s\n' \
    "$app" "$channel" "$(printf '%s\n' "$manifest" | jq -r '.source_oid')" "$digest"
}

rollback_artifact_app() {
  local app="$1" json install_mode artifact_app channel artifact_root install_root current_target previous_target digest manifest stamp_path
  json="$(require_app_json "$app")"
  install_mode="$(setting "$json" install_mode)"
  [ "$install_mode" = "artifact" ] || die "$app is not registered for artifact installs"
  IFS=$'\t' read -r artifact_app channel artifact_root install_root < <(artifact_paths "$app" "$json")
  [ -L "$install_root/current" ] || die "$app has no current artifact install"
  [ -L "$install_root/previous" ] || die "$app has no previous artifact install"
  current_target="$(readlink "$install_root/current")"
  previous_target="$(readlink "$install_root/previous")"
  case "$previous_target" in versions/*) ;; *) die "invalid previous artifact target: $previous_target" ;; esac
  [ -d "$install_root/$previous_target" ] || die "previous artifact directory is missing"
  atomic_symlink "$previous_target" "$install_root/current"
  atomic_symlink "$current_target" "$install_root/previous"
  install_artifact_links "$json" "$install_root"
  digest="${previous_target#versions/}"
  manifest="$artifact_root/manifests/$digest.json"
  [ -f "$manifest" ] || die "previous artifact manifest is missing"
  run_artifact_post_install "$app" "$json" "$install_root" "$digest"
  stamp_path="$STAMP_DIR/$app.json"
  mkdir -p "$STAMP_DIR"
  jq --arg app "$app" --arg channel "$channel" --arg artifact_root "$artifact_root" \
    --arg install_root "$install_root" --arg rolled_back_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{app: $app, install_mode: "artifact", artifact_app: .app, artifact_channel: $channel,
      artifact_root: $artifact_root, install_root: $install_root, manifest_digest: .manifest_digest,
      source_oid: .source_oid, repo: .repo, platform: .platform, rolled_back_at: $rolled_back_at}' \
    "$manifest" > "$stamp_path"
  printf 'host-track: rolled back %s manifest=%s\n' "$app" "$digest"
}

refresh_app() {
  local app="$1" force="$2" json status stale refresh_path refresh_mode host_track install_mode
  local self_upgrade setup_path

  json="$(require_app_json "$app")"
  install_mode="$(setting "$json" install_mode)"
  [ -n "$install_mode" ] || install_mode="checkout"
  status="$(status_json_for "$app")"
  stale="$(printf '%s\n' "$status" | jq -r '.stale | tostring')"

  if [ "$force" -eq 0 ] && [ "$stale" = "false" ]; then
    printf 'host-track: %s already current\n' "$app"
    # Artifact stamps are the provenance record written by artifact_install_app.
    # Replacing one with the projected status shape drops source_oid and other
    # manifest fields, so a no-op refresh must leave it intact.
    if [ "$install_mode" != "artifact" ]; then
      write_stamp "$app" "$status"
    fi
    return 0
  fi

  if [ "$install_mode" = "artifact" ]; then
    artifact_install_app "$app"
    return
  fi

  refresh_path="$(printf '%s\n' "$status" | jq -r '.refresh // ""')"
  refresh_mode="$(field "$json" refresh_mode)"
  host_track="$(printf '%s\n' "$status" | jq -r '.host_track')"

  if [ -n "$refresh_path" ] && [ -x "$refresh_path" ]; then
    # Local-safe helper takes "<app> [--force]"; legacy refresh scripts take only [--force].
    case "$(basename "$refresh_path")" in
      last-stack-refresh-local-safe|last-stack-safe-upgrade-cli|last-stack-safe-upgrade-all-local)
        if [ "$force" -eq 1 ]; then
          "$refresh_path" "$app" --force
        else
          "$refresh_path" "$app"
        fi
        ;;
      *)
        if [ "$force" -eq 1 ]; then
          "$refresh_path" --force
        else
          "$refresh_path"
        fi
        ;;
    esac
  elif [ "$refresh_mode" = "last-stack-self-upgrade" ]; then
    self_upgrade="$host_track/bin/last-stack-self-upgrade"
    setup_path="$host_track/setup"
    if [ -x "$self_upgrade" ]; then
      "$self_upgrade" --repair-dirty --reason=host-track-refresh
    elif [ -d "$host_track/.git" ] && [ -x "$setup_path" ]; then
      if ! git_dirty "$host_track"; then
        printf 'host-track: %s host checkout is dirty; refusing fallback refresh\n' "$app" >&2
        return 1
      fi
      git -C "$host_track" pull --ff-only
      "$setup_path"
    else
      printf 'host-track: %s has no usable last-stack refresh path\n' "$app" >&2
      return 3
    fi
  else
    printf 'host-track: %s has no refresh command yet\n' "$app" >&2
    return 3
  fi

  status="$(status_json_for "$app")"
  write_stamp "$app" "$status"
}

install_cmd() {
  local app="" channel=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --channel) [ "$#" -ge 2 ] || die "--channel requires a value"; channel="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      --*) die "unknown install flag: $1" ;;
      *) app="$1"; shift ;;
    esac
  done
  [ -n "$app" ] || die "install requires an app"
  artifact_install_app "$app" "$channel"
}

rollback_cmd() {
  local app="${1:-}"
  [ -n "$app" ] || die "rollback requires an app"
  [ "$#" -eq 1 ] || die "rollback accepts exactly one app"
  rollback_artifact_app "$app"
}

refresh_cmd() {
  local force=0 all=0 app="" failures=0 rc
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --force) force=1; shift ;;
      --all) all=1; shift ;;
      -h|--help) usage; exit 0 ;;
      --*) die "unknown refresh flag: $1" ;;
      *) app="$1"; shift ;;
    esac
  done

  if [ "$all" -eq 1 ]; then
    while IFS= read -r app; do
      [ -n "$app" ] || continue
      if refresh_app "$app" "$force"; then
        :
      else
        rc=$?
        [ "$rc" -eq 3 ] || failures=$((failures + 1))
      fi
    done < <(list_apps)
    [ "$failures" -eq 0 ]
    return
  fi

  [ -n "$app" ] || die "refresh requires an app or --all"
  refresh_app "$app" "$force"
}

main() {
  need_jq
  [ -f "$REGISTRY" ] || die "registry not found: $REGISTRY"

  case "${1:-}" in
    status) shift; status_cmd "$@" ;;
    which) shift; which_cmd "$@" ;;
    check) shift; check_cmd "$@" ;;
    refresh) shift; refresh_cmd "$@" ;;
    install) shift; install_cmd "$@" ;;
    rollback) shift; rollback_cmd "$@" ;;
    -h|--help|"") usage; exit 0 ;;
    *) die "unknown subcommand: $1" ;;
  esac
}

main "$@"
