#!/bin/bash
# last-stack-repark-shared-checkouts — keep workspace shared checkouts as
# exact read-only mirrors of their venue's main.
#
# Contract (brain: sop-shared-checkout-mirror-contract +
# preference-worktrees-only-shared-checkouts):
#   ~/code/edgevector/<repo> is nobody's working copy (WORKTREES ONLY).
#   It must literally match the gate-of-record tip of main:
#     lastgit | forgejo(origin:3300) | github per .last-stack/pr-venue
#
# Per repo this script:
#   1. skips symlinks, non-repos, and repos with dirty files touched <60 min
#      ago (a live agent may be mid-edit; FLAG instead of interfering)
#   2. fetches only refs/heads/main from the venue remote (bounded, one ref)
#   3. salvages any dirty state onto salvage/shared-checkout-<date>* (per-file;
#      NEVER `git add -A` in a shared checkout)
#   4. parks on main
#   5. makes local main **identical** to venue main:
#        - behind → ff when possible, else hard reset
#        - ahead or diverged → save tip as salvage/main-tip-<date>-<short>,
#          then hard reset to venue main
#      (WORKTREES ONLY: ambient is not a work surface; hard reset is safe)
#   6. flags repo-local .worktrees nests, seeds .git/info/exclude, prunes
#      dead worktrees; reinstalls shared-checkout write guards
#
# Exit 0 always; FLAG lines are the routine's surface. --dry-run previews.
set -u

GIT=/usr/bin/git
BIN_DIR="$(cd "$(dirname "$0")" && pwd -P)"
WS="${REPARK_WORKSPACE:-$HOME/code/edgevector}"
DATE=$(date +%Y%m%d)
SALVAGE="salvage/shared-checkout-$DATE"
NOW=$(date +%s)
RECENT_S=3600
DRY=0
[ "${1:-}" = "--dry-run" ] && DRY=1

# Repair the mechanical fence first.
if [ "$DRY" = 0 ] && [ -x "$BIN_DIR/last-stack-install-shared-checkout-guards" ]; then
  "$BIN_DIR/last-stack-install-shared-checkout-guards" "$WS" >/dev/null 2>&1 \
    || printf 'FLAG %-24s %s\n' "shared-checkout-guards" "install/audit failed"
fi

trailers() {
  if [ "${DRIVEN_BY:-}" = "routine" ]; then
    printf 'Driven-By: routine\nAutomation-Id: %s\nRun-Id: %s\n' \
      "${AUTOMATION_ID:-unknown}" "${ROUTINES_RUN_ID:-unknown}"
  fi
}

open_salvage_branch() {
  local d="$1" branch="$SALVAGE" n candidate
  if $GIT -C "$d" rev-parse --verify -q "refs/heads/$branch" >/dev/null; then
    if $GIT -C "$d" switch -q "$branch" 2>/dev/null; then
      printf '%s\n' "$branch"
      return 0
    fi
    n=1
    while :; do
      candidate="$SALVAGE-$n"
      if ! $GIT -C "$d" rev-parse --verify -q "refs/heads/$candidate" >/dev/null; then
        $GIT -C "$d" switch -q -c "$candidate" 2>/dev/null || return 1
        printf '%s\n' "$candidate"
        return 0
      fi
      n=$((n + 1))
    done
  fi
  $GIT -C "$d" switch -q -c "$branch" 2>/dev/null || return 1
  printf '%s\n' "$branch"
}

venue_remote() {
  local d="$1" venue=""
  venue=$(head -1 "$d/.last-stack/pr-venue" 2>/dev/null)
  [ -n "$venue" ] || venue=$($GIT -C "$d" config laststack.pr-venue 2>/dev/null)
  case "$venue" in
    lastgit) echo lastgit; return;;
    forgejo)
      if $GIT -C "$d" remote get-url origin 2>/dev/null | grep -q ':3300'; then
        echo origin
      else
        echo forge
      fi
      return;;
    github)
      if $GIT -C "$d" remote | grep -qx github; then echo github; else echo origin; fi
      return;;
  esac
  if $GIT -C "$d" remote | grep -qx lastgit; then echo lastgit; else echo origin; fi
}

flag() { printf 'FLAG %-24s %s\n' "$1" "$2"; }
note() { printf 'ok   %-24s %s\n' "$1" "$2"; }

# Save local tip then hard-reset main to venue tip.
# $5 optional suffix like " salvaged-on:..."
mirror_reset() {
  local d="$1" rem="$2" mb="$3" target="$4" extra="${5:-}"
  local ahead behind tip short ref
  ahead=$($GIT -C "$d" rev-list --count "$target..$mb" 2>/dev/null || echo "?")
  behind=$($GIT -C "$d" rev-list --count "$mb..$target" 2>/dev/null || echo "?")

  if [ "$ahead" = "0" ] && [ "$behind" = "0" ]; then
    $GIT -C "$d" reset --hard -q "$target" 2>/dev/null || true
    $GIT -C "$d" clean -fd -e target -e '*/target' -e node_modules -e .worktrees -e .gstack \
      >/dev/null 2>&1 || true
    note "$d" "current=$rem/$mb$extra"
    return 0
  fi

  if [ "$ahead" != "0" ] && [ "$ahead" != "?" ]; then
    tip=$($GIT -C "$d" rev-parse "$mb" 2>/dev/null) || tip=""
    if [ -n "$tip" ]; then
      short=$($GIT -C "$d" rev-parse --short "$tip" 2>/dev/null || echo tip)
      ref="salvage/main-tip-$DATE-$short"
      if ! $GIT -C "$d" rev-parse --verify -q "refs/heads/$ref" >/dev/null; then
        $GIT -C "$d" branch "$ref" "$tip" >/dev/null 2>&1 \
          || flag "$d" "could not save tip $short before reset"
      fi
    fi
  fi

  if [ "$ahead" = "0" ] && [ "$behind" != "0" ] && [ "$behind" != "?" ]; then
    if $GIT -C "$d" merge --ff-only -q "$target" >/dev/null 2>&1; then
      $GIT -C "$d" clean -fd -e target -e '*/target' -e node_modules -e .worktrees -e .gstack \
        >/dev/null 2>&1 || true
      note "$d" "ff($behind)→$rem/$mb$extra"
      return 0
    fi
  fi

  if $GIT -C "$d" reset --hard -q "$target" 2>/dev/null; then
    $GIT -C "$d" clean -fd -e target -e '*/target' -e node_modules -e .worktrees -e .gstack \
      >/dev/null 2>&1 || true
    note "$d" "reset→$rem/$mb (was ahead=$ahead behind=$behind)$extra"
  else
    flag "$d" "hard reset to $rem/$mb failed (ahead=$ahead behind=$behind)$extra"
  fi
}

cd "$WS" || exit 0
for d in */; do
  d=${d%/}
  [ -L "$d" ] && continue
  # Ambient only: linked worktrees have a .git *file*
  [ -d "$d/.git" ] || continue
  rem=$(venue_remote "$d")
  $GIT -C "$d" remote | grep -qx "$rem" || { flag "$d" "venue remote '$rem' not configured"; continue; }
  [ -d "$d/.worktrees" ] && flag "$d" "repo-local .worktrees present; canonical agent worktrees live under ~/.fkanban/worktrees"
  mb=main
  $GIT -C "$d" rev-parse --verify -q refs/heads/main >/dev/null || mb=master
  target="refs/remotes/$rem/$mb"

  # 1. recent-activity guard
  recent=""
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    f=${line:3}
    case "$f" in .worktrees/*|.gstack/*|*.tmp|node_modules/*|target/*|*/target/*) continue;; esac
    [ -e "$d/$f" ] || continue
    m=$(stat -f %m "$d/$f" 2>/dev/null) || continue
    [ $((NOW - m)) -lt $RECENT_S ] && { recent="$f"; break; }
  done <<EOF
$($GIT -C "$d" status --porcelain 2>/dev/null)
EOF
  [ -n "$recent" ] && { flag "$d" "recent activity (<60min): $recent — left alone"; continue; }

  [ -f "$d/.git/index.lock" ] && { flag "$d" "index.lock present — git op in flight or stale; left alone"; continue; }

  if [ "$DRY" = 1 ]; then
    note "$d" "dry-run: would mirror $rem/$mb (fetch+hard-reset)"
    continue
  fi

  # seed machine-local excludes
  ex="$d/.git/info/exclude"
  if [ -f "$ex" ] && ! grep -q '^\.worktrees/$' "$ex" 2>/dev/null; then
    printf '.worktrees/\n.gstack/\n' >> "$ex"
  fi

  if [ -x "$BIN_DIR/last-stack-scrub-github-token-remotes" ]; then
    "$BIN_DIR/last-stack-scrub-github-token-remotes" "$d" >/dev/null 2>&1 || true
  fi

  # 2. bounded single-ref fetch of the venue main
  $GIT -C "$d" fetch --no-tags "$rem" "+refs/heads/$mb:$target" >/dev/null 2>&1
  $GIT -C "$d" rev-parse --verify -q "$target" >/dev/null || { flag "$d" "no $rem/$mb after fetch"; continue; }

  # 3. salvage dirty state (per-file)
  cur=$($GIT -C "$d" branch --show-current)
  dirty=$($GIT -C "$d" status --porcelain 2>/dev/null)
  salvaged=""
  if [ -n "$dirty" ]; then
    if [ -z "$cur" ] || [ "$cur" = "$mb" ]; then
      cur=$(open_salvage_branch "$d") \
        || { flag "$d" "cannot open salvage branch"; continue; }
    fi
    staged=0
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      f=${line:3}
      case "$f" in .worktrees/*|.gstack/*|*.tmp|node_modules/*|target/*|*/target/*) continue;; esac
      $GIT -C "$d" add -- "$f" 2>/dev/null && staged=1
    done <<EOF
$dirty
EOF
    if [ "$staged" = 1 ] && ! $GIT -C "$d" diff --cached --quiet 2>/dev/null; then
      # Salvage commits may need override of write guard on ambient trees.
      if LAST_STACK_ALLOW_SHARED_CHECKOUT_WRITE=1 $GIT -C "$d" commit -q \
          -m "salvage: shared-checkout leftovers before mirror re-park $DATE" \
          -m "Automated by last-stack-repark-shared-checkouts; review, cherry-pick or drop." \
          -m "$(trailers)"; then
        salvaged=" salvaged-on:$cur"
      else
        flag "$d" "salvage commit failed on $cur — left as-is"
        continue
      fi
    fi
  fi

  # 4. re-park on main (force if salvage left us elsewhere)
  if [ "$($GIT -C "$d" branch --show-current)" != "$mb" ]; then
    $GIT -C "$d" switch -q "$mb" 2>/dev/null \
      || $GIT -C "$d" switch -q -f "$mb" 2>/dev/null \
      || { flag "$d" "cannot switch to $mb (parked: $cur)$salvaged"; continue; }
  fi

  # 5. force local main == venue main (WORKTREES ONLY: ambient is not a work surface)
  mirror_reset "$d" "$rem" "$mb" "$target" "$salvaged"

  # 6. prune dead worktree metadata
  $GIT -C "$d" worktree prune 2>/dev/null
done
exit 0
