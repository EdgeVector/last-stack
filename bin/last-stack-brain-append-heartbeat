#!/usr/bin/env bash
# Append one heartbeat line to a local log file — NOT LastDB / brain.
#
# Heartbeats are fleet "I ran" pings. They must not use LastDB (versioned
# full-body rewrites of a Reference record ballooned atom storage).
#
# Default log: ~/.last-stack/logs/routine-heartbeats.log
# Override:    LAST_STACK_HEARTBEATS_FILE=/path/to/file
#
# Lines are appended (newest at end). Single-line only.
set -euo pipefail

slug="routine-heartbeats" # retained for CLI compatibility; not a brain slug
line=""

default_log() {
  if [ -n "${LAST_STACK_HEARTBEATS_FILE:-}" ]; then
    printf '%s\n' "$LAST_STACK_HEARTBEATS_FILE"
    return
  fi
  # Prefer the last-stack install this script lives in, else ~/.last-stack
  local root
  root="$(cd "$(dirname "$0")/.." && pwd)"
  if [ -d "$root/logs" ] || [ -d "$root/bin" ]; then
    printf '%s\n' "$root/logs/routine-heartbeats.log"
    return
  fi
  printf '%s\n' "${HOME}/.last-stack/logs/routine-heartbeats.log"
}

usage() {
  cat <<'EOF'
Usage:
  last-stack-brain-append-heartbeat [--slug routine-heartbeats] --line "<heartbeat>"
  printf '%s\n' "<heartbeat>" | last-stack-brain-append-heartbeat --stdin

Appends one line to a filesystem log (NOT brain / LastDB).

  Default file:  <last-stack>/logs/routine-heartbeats.log
                 or ~/.last-stack/logs/routine-heartbeats.log
  Override:      LAST_STACK_HEARTBEATS_FILE=/path/to/log

  --slug is accepted for backward compatibility and ignored for storage
  (all fleet heartbeats share one file).

Read with:
  tail -n 200 "$(last-stack-heartbeats-path)"
  # or: cat "$LAST_STACK_HEARTBEATS_FILE"
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --slug)
      [ "$#" -ge 2 ] || { echo "--slug requires a value" >&2; exit 2; }
      slug="$2"
      shift 2
      ;;
    --slug=*)
      slug="${1#*=}"
      shift
      ;;
    --line)
      [ "$#" -ge 2 ] || { echo "--line requires a value" >&2; exit 2; }
      line="$2"
      shift 2
      ;;
    --line=*)
      line="${1#*=}"
      shift
      ;;
    --stdin)
      IFS= read -r line || true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -z "$line" ]; then
        line="$*"
        break
      fi
      echo "unexpected argument: $1" >&2
      exit 2
      ;;
  esac
done

if [ -z "$line" ]; then
  echo "heartbeat line is required" >&2
  exit 2
fi
case "$line" in
  *$'\n'*)
    echo "heartbeat line must be a single line" >&2
    exit 2
    ;;
esac

log_file="$(default_log)"
mkdir -p "$(dirname "$log_file")"
# Append-only — never rewrite the whole file through LastDB.
printf '%s\n' "$line" >>"$log_file"
echo "appended heartbeat to file ${log_file}${slug:+ (label=$slug)}"
