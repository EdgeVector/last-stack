#!/usr/bin/env bash
# Safely add one newest-on-top line to the typed routine-heartbeats reference.
set -euo pipefail

slug="routine-heartbeats"
line=""

usage() {
  cat <<'EOF'
Usage:
  last-stack-brain-append-heartbeat [--slug routine-heartbeats] --line "<heartbeat>"
  printf '%s\n' "<heartbeat>" | last-stack-brain-append-heartbeat --stdin

Reads the target with `brain get <slug> --type reference --json`, aborts on any
read or JSON error, then writes the new line plus the existing body back with
`brain put <slug> --type reference`. Existing lines are preserved. If an older
local brain config is missing a newly-added schema hash, falls back to
`brain append` so the heartbeat is still recorded without running `brain init`.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --slug)
      [ "$#" -ge 2 ] || { echo "--slug requires a value" >&2; exit 2; }
      slug="$2"
      shift 2
      ;;
    --slug=*)
      slug="${1#*=}"
      shift
      ;;
    --line)
      [ "$#" -ge 2 ] || { echo "--line requires a value" >&2; exit 2; }
      line="$2"
      shift 2
      ;;
    --line=*)
      line="${1#*=}"
      shift
      ;;
    --stdin)
      IFS= read -r line || true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -z "$line" ]; then
        line="$*"
        break
      fi
      echo "unexpected argument: $1" >&2
      exit 2
      ;;
  esac
done

if [ -z "$slug" ]; then
  echo "slug is required" >&2
  exit 2
fi
if [ -z "$line" ]; then
  echo "heartbeat line is required" >&2
  exit 2
fi
case "$line" in
  *$'\n'*)
    echo "heartbeat line must be a single line" >&2
    exit 2
    ;;
esac

command -v jq >/dev/null 2>&1 || { echo "jq is required" >&2; exit 127; }
command -v brain >/dev/null 2>&1 || { echo "brain is required" >&2; exit 127; }

read_err="$(mktemp)"
put_body="$(mktemp)"
append_err="$(mktemp)"
cleanup() {
  rm -f "$read_err" "$put_body" "$append_err"
}
trap cleanup EXIT

fallback_append() {
  # A new schema type can make old brain configs fail reads before the target
  # reference is reachable. In unattended routines, do not run brain init; grow
  # the heartbeat record server-side instead.
  printf '\n%s\n' "$line" | brain append "$slug" --type reference --raw --json >"$put_body" 2>"$append_err" || {
    cat "$append_err" >&2
    [ -s "$put_body" ] && cat "$put_body" >&2
    echo "aborting: fallback append failed for $slug" >&2
    exit 1
  }
  if ! jq -e 'type == "object" and .ok == true' "$put_body" >/dev/null; then
    cat "$append_err" >&2
    cat "$put_body" >&2
    echo "aborting: fallback append returned an error payload" >&2
    exit 1
  fi
  echo "appended heartbeat to $slug via brain append fallback"
  exit 0
}

if ! record_json="$(brain get "$slug" --type reference --json 2>"$read_err")"; then
  if { printf '%s\n' "$record_json"; cat "$read_err"; } | grep -q 'No canonical hash registered'; then
    fallback_append
  fi
  cat "$read_err" >&2
  [ -n "$record_json" ] && printf '%s\n' "$record_json" >&2
  echo "aborting: could not read $slug as --type reference; not writing" >&2
  exit 1
fi

if ! printf '%s' "$record_json" | jq -e 'type == "object" and (has("error") | not)' >/dev/null; then
  printf '%s\n' "$record_json" >&2
  echo "aborting: typed read returned an error payload; not writing" >&2
  exit 1
fi

body="$(printf '%s' "$record_json" | jq -r '.body // ""')"

{
  printf '%s\n' "$line"
  if [ -n "$body" ]; then
    printf '%s\n' "$body"
  fi
} > "$put_body"

brain put "$slug" --type reference --json < "$put_body" >/dev/null
echo "appended heartbeat to $slug"
