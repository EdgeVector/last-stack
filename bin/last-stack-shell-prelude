#!/bin/sh
# Source this at the start of scheduled routine snippets to restore common CLIs
# and resolve tool paths once for stripped/noninteractive shells.
# Usage: . "$last_stack/bin/last-stack-shell-prelude"

default_global_path="${LAST_STACK_ROOT:-$HOME/.last-stack}/bin:$HOME/.local/bin:$HOME/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
global_path="${LAST_STACK_GLOBAL_PATH:-$default_global_path}"

case ":$PATH:" in
  *":$global_path:"*) ;;
  *) PATH="$global_path:$PATH" ;;
esac
export PATH

if [ "${1:-}" = "--print" ] || [ "${LAST_STACK_SHELL_PRELUDE_PRINT:-}" = "1" ]; then
  printf 'PATH=%s\n' "$PATH"
fi

last_stack_resolve_tool() {
  tool="$1"
  if command -v "$tool" >/dev/null 2>&1; then
    command -v "$tool"
    return 0
  fi

  old_ifs=$IFS
  IFS=:
  for dir in $global_path; do
    if [ -x "$dir/$tool" ]; then
      IFS=$old_ifs
      printf '%s\n' "$dir/$tool"
      return 0
    fi
  done
  IFS=$old_ifs

  {
    echo "LAST_STACK_TOOL_MISSING"
    echo "PATH=$PATH"
    echo "Required CLI not found: $tool"
    echo "Remediation: export PATH=\"${global_path}:\$PATH\" before running the routine, or install the missing CLI."
  } >&2
  return 127
}

last_stack_tool_env_name() {
  printf '%s' "$1" \
    | LC_ALL=C tr '[:lower:]' '[:upper:]' \
    | LC_ALL=C tr '.-' '__' \
    | LC_ALL=C tr -c 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_' '_'
}

last_stack_require_tools() {
  missing=""
  for tool in "$@"; do
    if tool_path="$(last_stack_resolve_tool "$tool" 2>/dev/null)"; then
      tool_var="LAST_STACK_TOOL_$(last_stack_tool_env_name "$tool")"
      eval "$tool_var=\$tool_path"
      export "$tool_var"
      continue
    fi

    found=""
    old_ifs=$IFS
    IFS=:
    for dir in $global_path; do
      if [ -x "$dir/$tool" ]; then
        found="$dir/$tool"
        break
      fi
    done
    IFS=$old_ifs

    if [ -n "$found" ]; then
      missing="$missing
$tool (available at $found but not on PATH)"
    else
      missing="$missing
$tool"
    fi
  done

  if [ -n "$missing" ]; then
    {
      echo "LAST_STACK_CLI_PATH_MISSING"
      echo "PATH=$PATH"
      echo "Required CLI(s) not visible:$missing"
      echo "Remediation: export PATH=\"${global_path}:\$PATH\" before running the routine, or install the missing CLI(s)."
    } >&2
    return 127
  fi
}
