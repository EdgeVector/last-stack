#!/usr/bin/env bash
# Install/audit a small managed prelude in every ambient repo's existing Git
# hooks without replacing repo-specific hook behavior.
set -euo pipefail

workspace="${LAST_STACK_SHARED_WORKSPACE:-$HOME/code/edgevector}"
guard="${LAST_STACK_SHARED_GUARD:-$HOME/.local/bin/last-stack-shared-checkout-guard}"
mode="install"
case "${1:-}" in
  --audit) mode="audit"; shift ;;
  --help|-h)
    echo "usage: last-stack-install-shared-checkout-guards [--audit] [workspace]"
    exit 0
    ;;
esac
[ "$#" -eq 0 ] || workspace="$1"

start="# last-stack-shared-checkout-guard:start"
failures=0
count=0

install_hook() {
  local repo="$1" hook_name="$2" hooks_dir="$3" hook tmp
  hook="$hooks_dir/$hook_name"
  if [ "$mode" = "audit" ]; then
    if [ -f "$hook" ] && grep -Fq "$start" "$hook"; then
      return 0
    fi
    printf 'MISSING_GUARD repo=%s hook=%s\n' "$(basename "$repo")" "$hook_name"
    return 1
  fi

  mkdir -p "$hooks_dir"
  if [ -f "$hook" ] && grep -Fq "$start" "$hook"; then
    chmod +x "$hook"
    return 0
  fi

  tmp="$(mktemp "${TMPDIR:-/tmp}/last-stack-hook.XXXXXX")"
  {
    if [ -f "$hook" ] && head -1 "$hook" | grep -q '^#!'; then
      head -1 "$hook"
    else
      printf '#!/usr/bin/env bash\n'
    fi
    printf '%s\n' "$start"
    printf '"%s" %s || exit $?\n' "$guard" "$hook_name"
    printf '# last-stack-shared-checkout-guard:end\n'
    if [ -f "$hook" ]; then
      if head -1 "$hook" | grep -q '^#!'; then
        tail -n +2 "$hook"
      else
        cat "$hook"
      fi
    fi
  } > "$tmp"
  mv "$tmp" "$hook"
  chmod +x "$hook"
}

[ -d "$workspace" ] || {
  printf 'shared-checkout workspace missing: %s\n' "$workspace" >&2
  exit 1
}
[ "$mode" = "audit" ] || [ -x "$guard" ] || {
  printf 'shared-checkout guard missing or not executable: %s\n' "$guard" >&2
  exit 1
}

for repo in "$workspace"/*; do
  [ -d "$repo/.git" ] || continue
  count=$((count + 1))
  hooks_dir="$(git -C "$repo" rev-parse --git-path hooks 2>/dev/null || true)"
  case "$hooks_dir" in
    /*) ;;
    *) hooks_dir="$repo/$hooks_dir" ;;
  esac
  install_hook "$repo" pre-commit "$hooks_dir" || failures=$((failures + 1))
  install_hook "$repo" pre-push "$hooks_dir" || failures=$((failures + 1))
done

if [ "$failures" -ne 0 ]; then
  printf 'SHARED_CHECKOUT_GUARDS result=fail repos=%s missing=%s\n' "$count" "$failures" >&2
  exit 1
fi
printf 'SHARED_CHECKOUT_GUARDS result=ok mode=%s repos=%s\n' "$mode" "$count"
