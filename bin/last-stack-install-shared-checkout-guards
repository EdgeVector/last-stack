#!/usr/bin/env bash
# Install/audit a managed prelude in every ambient repo's Git hooks without
# replacing repo-specific hook bodies. WORKTREES-ONLY (Tom 2026-07-22).
set -euo pipefail

workspace="${LAST_STACK_SHARED_WORKSPACE:-$HOME/code/edgevector}"
guard="${LAST_STACK_SHARED_GUARD:-$HOME/.local/bin/last-stack-shared-checkout-guard}"
mode="install"
case "${1:-}" in
  --audit) mode="audit"; shift ;;
  --help|-h)
    echo "usage: last-stack-install-shared-checkout-guards [--audit] [workspace]"
    exit 0
    ;;
esac
[ "$#" -eq 0 ] || workspace="$1"

start="# last-stack-shared-checkout-guard:start"
end="# last-stack-shared-checkout-guard:end"
failures=0
count=0

# Hooks that refuse ambient writes (worktrees pass the guard).
HOOKS=(pre-commit pre-push pre-merge-commit pre-rebase prepare-commit-msg)

strip_managed_block() {
  # stdin -> stdout, remove managed prelude block; keep other lines.
  awk -v start="$start" -v end="$end" '
    $0 == start { skip=1; next }
    $0 == end { skip=0; next }
    !skip { print }
  '
}

install_hook() {
  local repo="$1" hook_name="$2" hooks_dir="$3" hook tmp body shebang
  hook="$hooks_dir/$hook_name"
  if [ "$mode" = "audit" ]; then
    # Accept any installed guard path; re-install refreshes the absolute path.
    if [ -f "$hook" ] && grep -Fq "$start" "$hook" && grep -Fq "last-stack-shared-checkout-guard" "$hook"; then
      return 0
    fi
    printf 'MISSING_GUARD repo=%s hook=%s\n' "$(basename "$repo")" "$hook_name"
    return 1
  fi

  mkdir -p "$hooks_dir"
  # Already installed with current guard path.
  if [ -f "$hook" ] && grep -Fq "$start" "$hook" && grep -Fq "$guard" "$hook"; then
    chmod +x "$hook"
    return 0
  fi

  shebang='#!/usr/bin/env bash'
  body=""
  if [ -f "$hook" ]; then
    if head -1 "$hook" | grep -q '^#!'; then
      shebang="$(head -1 "$hook")"
      body="$(tail -n +2 "$hook" | strip_managed_block)"
    else
      body="$(strip_managed_block < "$hook")"
    fi
  fi

  tmp="$(mktemp "${TMPDIR:-/tmp}/last-stack-hook.XXXXXX")"
  {
    printf '%s\n' "$shebang"
    printf '%s\n' "$start"
    printf '"%s" %s || exit $?\n' "$guard" "$hook_name"
    printf '%s\n' "$end"
    if [ -n "$body" ]; then
      printf '%s\n' "$body"
    fi
  } > "$tmp"
  mv "$tmp" "$hook"
  chmod +x "$hook"
}

[ -d "$workspace" ] || {
  printf 'shared-checkout workspace missing: %s\n' "$workspace" >&2
  exit 1
}
[ "$mode" = "audit" ] || [ -x "$guard" ] || {
  printf 'shared-checkout guard missing or not executable: %s\n' "$guard" >&2
  exit 1
}

for repo in "$workspace"/*; do
  # Ambient checkout only: real .git directory (linked worktrees use a .git file).
  [ -d "$repo/.git" ] || continue
  count=$((count + 1))
  hooks_dir="$(git -C "$repo" rev-parse --git-path hooks 2>/dev/null || true)"
  case "$hooks_dir" in
    /*) ;;
    *) hooks_dir="$repo/$hooks_dir" ;;
  esac
  for hook_name in "${HOOKS[@]}"; do
    install_hook "$repo" "$hook_name" "$hooks_dir" || failures=$((failures + 1))
  done
done

if [ "$failures" -ne 0 ]; then
  printf 'SHARED_CHECKOUT_GUARDS result=fail repos=%s missing=%s\n' "$count" "$failures" >&2
  exit 1
fi
printf 'SHARED_CHECKOUT_GUARDS result=ok mode=%s repos=%s hooks=%s\n' \
  "$mode" "$count" "${#HOOKS[@]}"
