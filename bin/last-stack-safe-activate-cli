#!/usr/bin/env bash
# last-stack-safe-activate-cli — local, no-cloud safe install switch for agent CLIs.
#
# Layout (same shape as host-track artifact installs):
#   $INSTALL_ROOT/
#     versions/<id>/     immutable built tree
#     current  -> versions/<id>
#     previous -> versions/<old-id>   (last good; for rollback)
#
# Usage:
#   last-stack-safe-activate-cli activate --app brain --version-id <id> \
#     --version-dir /path/to/built/tree --link bin/brain:$HOME/.local/bin/brain
#   last-stack-safe-activate-cli rollback --app brain \
#     --link bin/brain:$HOME/.local/bin/brain
#   last-stack-safe-activate-cli status --app brain
#
# Does NOT fetch from the cloud. Does NOT develop in the install tree.
set -euo pipefail

die() { printf 'safe-activate-cli: %s\n' "$*" >&2; exit 2; }

APPS_ROOT="${HOST_TRACK_APPS_ROOT:-$HOME/.host-track/apps}"
STAMP_DIR="${HOST_TRACK_STAMP_DIR:-$HOME/.host-track/stamps}"

atomic_symlink() {
  # $1 = target (relative or absolute), $2 = link path
  # IMPORTANT: never `mv` onto an existing symlink-to-directory — on macOS/BSD
  # that moves the source *into* the target dir instead of replacing the link.
  local target="$1" link="$2" dir tmp
  dir="$(dirname "$link")"
  mkdir -p "$dir"
  tmp="$dir/.tmp-link.$$.$RANDOM"
  ln -sfn "$target" "$tmp"
  rm -f "$link"
  mv -f "$tmp" "$link"
}

install_root_for() {
  local app="$1"
  printf '%s/%s\n' "$APPS_ROOT" "$app"
}

cmd_status() {
  local app="" install_root
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app) app="${2:-}"; shift 2 ;;
      *) die "unknown status arg: $1" ;;
    esac
  done
  [ -n "$app" ] || die "status requires --app"
  install_root="$(install_root_for "$app")"
  printf 'app=%s\ninstall_root=%s\n' "$app" "$install_root"
  if [ -L "$install_root/current" ]; then
    printf 'current=%s\n' "$(readlink "$install_root/current")"
    printf 'current_real=%s\n' "$(cd "$install_root" && cd "$(readlink current)" && pwd -P)"
  else
    printf 'current=\n'
  fi
  if [ -L "$install_root/previous" ]; then
    printf 'previous=%s\n' "$(readlink "$install_root/previous")"
  else
    printf 'previous=\n'
  fi
  if [ -d "$install_root/versions" ]; then
    printf 'versions=\n'
    ls -1 "$install_root/versions" 2>/dev/null | sed 's/^/  /' || true
  fi
}

apply_links() {
  # links are "relpath:absolute_target" pairs
  local install_root="$1"
  shift
  local pair rel abs src
  for pair in "$@"; do
    [ -n "$pair" ] || continue
    rel="${pair%%:*}"
    abs="${pair#*:}"
    [ -n "$rel" ] && [ -n "$abs" ] && [ "$rel" != "$pair" ] \
      || die "bad --link (want rel:abs): $pair"
    src="$install_root/current/$rel"
    [ -e "$src" ] || die "link source missing after activate: $src"
    mkdir -p "$(dirname "$abs")"
    atomic_symlink "$src" "$abs"
    printf 'safe-activate-cli: linked %s -> %s\n' "$abs" "$src"
  done
}

cmd_activate() {
  local app="" version_id="" version_dir="" 
  local -a links=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app) app="${2:-}"; shift 2 ;;
      --version-id) version_id="${2:-}"; shift 2 ;;
      --version-dir) version_dir="${2:-}"; shift 2 ;;
      --link) links+=("${2:-}"); shift 2 ;;
      *) die "unknown activate arg: $1" ;;
    esac
  done
  [ -n "$app" ] || die "activate requires --app"
  [ -n "$version_id" ] || die "activate requires --version-id"
  [ -n "$version_dir" ] || die "activate requires --version-dir"
  [ -d "$version_dir" ] || die "version-dir not a directory: $version_dir"
  case "$version_id" in
    *..*|/*|*\\*|*" "*) die "invalid version-id: $version_id" ;;
  esac

  local install_root dest old_target
  install_root="$(install_root_for "$app")"
  mkdir -p "$install_root/versions"
  dest="$install_root/versions/$version_id"

  # If caller already placed the tree at dest (common: safe-upgrade-cli), just re-point.
  version_dir_abs="$(cd "$version_dir" && pwd -P)"
  dest_parent="$(cd "$install_root/versions" && pwd -P)"
  if [ -d "$dest" ] && [ "$version_dir_abs" = "$(cd "$dest" 2>/dev/null && pwd -P)" ]; then
    printf 'safe-activate-cli: version %s ready; pointing current\n' "$version_id"
  elif [ -e "$dest" ]; then
    printf 'safe-activate-cli: replacing existing version %s\n' "$version_id"
    rm -rf "$dest"
    if [ "$(dirname "$version_dir_abs")" = "$dest_parent" ]; then
      mv "$version_dir" "$dest"
    else
      local stage
      stage="$(mktemp -d "$install_root/versions/.stage-$version_id.XXXXXX")"
      rm -rf "$stage"
      mkdir -p "$stage"
      if command -v rsync >/dev/null 2>&1; then
        rsync -a "$version_dir"/ "$stage"/
      else
        tar -C "$version_dir" -cf - . | tar -C "$stage" -xf -
      fi
      mv "$stage" "$dest"
    fi
  else
    # Move or copy into place. Prefer rename when on same FS under versions/.
    if [ "$(dirname "$version_dir_abs")" = "$dest_parent" ]; then
      mv "$version_dir" "$dest"
    else
      local stage
      stage="$(mktemp -d "$install_root/versions/.stage-$version_id.XXXXXX")"
      rm -rf "$stage"
      mkdir -p "$stage"
      if command -v rsync >/dev/null 2>&1; then
        rsync -a "$version_dir"/ "$stage"/
      else
        tar -C "$version_dir" -cf - . | tar -C "$stage" -xf -
      fi
      mv "$stage" "$dest"
    fi
  fi

  [ -d "$dest" ] || die "version dir missing after materialize: $dest"

  old_target=""
  if [ -L "$install_root/current" ]; then
    old_target="$(readlink "$install_root/current")"
  fi
  if [ -n "$old_target" ] && [ "$old_target" != "versions/$version_id" ]; then
    atomic_symlink "$old_target" "$install_root/previous"
  fi
  atomic_symlink "versions/$version_id" "$install_root/current"

  if [ "${#links[@]}" -gt 0 ]; then
    apply_links "$install_root" "${links[@]}"
  fi

  mkdir -p "$STAMP_DIR"
  cat >"$STAMP_DIR/${app}.json" <<STAMP
{
  "app": "$app",
  "install_mode": "local-safe",
  "install_root": "$install_root",
  "version_id": "$version_id",
  "current": "versions/$version_id",
  "previous": $( if [ -L "$install_root/previous" ]; then printf '"%s"' "$(readlink "$install_root/previous")"; else printf 'null'; fi ),
  "activated_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
STAMP

  printf 'safe-activate-cli: activated %s version=%s\n' "$app" "$version_id"
  printf '  current  %s\n' "$install_root/current"
  if [ -L "$install_root/previous" ]; then
    printf '  previous %s -> %s\n' "$install_root/previous" "$(readlink "$install_root/previous")"
  fi
}

cmd_rollback() {
  local app=""
  local -a links=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app) app="${2:-}"; shift 2 ;;
      --link) links+=("${2:-}"); shift 2 ;;
      *) die "unknown rollback arg: $1" ;;
    esac
  done
  [ -n "$app" ] || die "rollback requires --app"
  local install_root current_target previous_target
  install_root="$(install_root_for "$app")"
  [ -L "$install_root/current" ] || die "$app has no current"
  [ -L "$install_root/previous" ] || die "$app has no previous (nothing to roll back to)"
  current_target="$(readlink "$install_root/current")"
  previous_target="$(readlink "$install_root/previous")"
  case "$previous_target" in
    versions/*) ;;
    *) die "invalid previous target: $previous_target" ;;
  esac
  [ -d "$install_root/$previous_target" ] || die "previous dir missing: $install_root/$previous_target"

  atomic_symlink "$previous_target" "$install_root/current"
  atomic_symlink "$current_target" "$install_root/previous"

  if [ "${#links[@]}" -gt 0 ]; then
    apply_links "$install_root" "${links[@]}"
  fi

  mkdir -p "$STAMP_DIR"
  cat >"$STAMP_DIR/${app}.json" <<STAMP
{
  "app": "$app",
  "install_mode": "local-safe",
  "install_root": "$install_root",
  "version_id": "${previous_target#versions/}",
  "current": "$previous_target",
  "previous": "$current_target",
  "rolled_back_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
STAMP

  printf 'safe-activate-cli: rolled back %s to %s\n' "$app" "$previous_target"
}

usage() {
  sed -n '2,20p' "$0" | tr -d '#'
}

cmd="${1:-}"
[ -n "$cmd" ] || { usage; exit 2; }
shift || true
case "$cmd" in
  activate) cmd_activate "$@" ;;
  rollback) cmd_rollback "$@" ;;
  status) cmd_status "$@" ;;
  -h|--help|help) usage; exit 0 ;;
  *) die "unknown command: $cmd (activate|rollback|status)" ;;
esac
