{
  "defaults": {
    "install_mode": "artifact",
    "artifact_channel": "stable",
    "artifact_root": "$HOME/.lastgit/artifacts"
  },
  "apps": [
    {
      "app": "lastgit",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastgit",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/lastgit.git#main",
      "artifact_app": "lastgit",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastgit",
      "links": [
        {
          "source": "dist/lastgit",
          "target": "$HOME/.local/bin/lastgit"
        },
        {
          "source": "dist/git-remote-lastdb",
          "target": "$HOME/.local/bin/git-remote-lastdb"
        }
      ],
      "notes": "Verified LastGit self-artifact install; keep source work in isolated repo worktrees, not the Host Track install tree."
    },
    {
      "app": "last-stack",
      "install_mode": "artifact",
      "kind": "artifact skill-pack",
      "command": "host-track",
      "gate": "lastgit",
      "gate_main": "lastdb:///last-stack#main",
      "artifact_app": "last-stack",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.local/state/last-stack/artifacts",
      "post_install": "$HOME/.local/state/last-stack/artifacts/current/setup",
      "links": [
        {
          "source": "bin/host-track",
          "target": "$HOME/.local/bin/host-track"
        }
      ],
      "notes": "One rule: runtime is the Host Track CI artifact only. post_install activates ~/.last-stack/{bin,skills,routines,...} → .artifacts/current (immutable). Never develop in the install; use a worktree. Upgrade with: host-track refresh last-stack"
    },
    {
      "app": "brain",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "brain",
      "gate": "lastgit",
      "gate_main": "lastdb:///brain#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/brain/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["brain"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade (versions/current/previous) until LastGit CAS channel is published. CI: last-stack-safe-upgrade-cli brain --source-dir $PWD."
      },
      "notes": "Local safe-upgrade under ~/.host-track/apps/brain. Upgrade: last-stack-safe-upgrade-cli brain. Rollback: last-stack-safe-activate-cli rollback --app brain --link bin/brain:$HOME/.local/bin/brain."
    },
    {
      "app": "situations",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "situations",
      "gate": "lastgit",
      "gate_main": "lastdb:///situations#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/situations/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["situations"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade until CAS channel exists."
      },
      "notes": "Local safe-upgrade under ~/.host-track/apps/situations. PATH: situations + fsituations."
    },
    {
      "app": "kanban",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "kanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/fkanban/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["fkanban"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade shared with fkanban until CAS channel exists."
      },
      "notes": "Shares install with fkanban at ~/.host-track/apps/fkanban. Upgrade via last-stack-safe-upgrade-cli fkanban."
    },
    {
      "app": "fkanban",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "fkanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/fkanban/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["fkanban"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade until CAS channel exists."
      },
      "notes": "Local safe-upgrade; PATH links kanban + fkanban."
    },
    {
      "app": "routines",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "routines",
      "gate": "lastgit",
      "gate_main": "lastdb:///routines#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/routines/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["routines"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade after portal cutover."
      },
      "notes": "Local safe-upgrade under ~/.host-track/apps/routines."
    },
    {
      "app": "lastsecrets",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "lastsecrets",
      "gate": "lastgit",
      "gate_main": "lastdb:///lastsecrets#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/lastsecrets/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["lastsecrets"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade after portal cutover."
      },
      "notes": "Local safe-upgrade under ~/.host-track/apps/lastsecrets."
    },
    {
      "app": "configurations",
      "install_mode": "checkout",
      "kind": "B local-safe",
      "command": "configurations",
      "gate": "lastgit",
      "gate_main": "lastdb:///configurations#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/apps/configurations/current",
      "refresh": "$HOME/.local/bin/last-stack-refresh-local-safe",
      "refresh_args": ["configurations"],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Local safe-upgrade after portal cutover."
      },
      "notes": "Local safe-upgrade under ~/.host-track/apps/configurations."
    },
    {
      "app": "lastdb",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastdb",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdb",
          "target": "$HOME/.local/bin/lastdb"
        }
      ],
      "notes": "Verified paired LastDB Mini bundle. Live primary upgrades still require lastdb-safe-upgrade; do not overwrite or restart ~/.lastdb directly from Host Track."
    },
    {
      "app": "lastdbd",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastdbd",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdbd",
          "target": "$HOME/.local/bin/lastdbd"
        }
      ],
      "notes": "Verified paired LastDB Mini daemon bundle. Activation of Tom's primary node remains lastdb-safe-upgrade only."
    }
  ]
}
