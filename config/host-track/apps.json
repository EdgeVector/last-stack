{
  "defaults": {
    "install_mode": "artifact",
    "artifact_channel": "stable",
    "artifact_root": "$HOME/.lastgit/artifacts"
  },
  "apps": [
    {
      "app": "lastgit",
      "install_mode": "checkout",
      "kind": "A compile",
      "command": "lastgit",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/lastgit.git#main",
      "gate_remote": "origin",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.lastgit/host-checkout/lastgit",
      "refresh": "$HOME/.lastgit/host-checkout/lastgit/.lastgit/refresh-host.sh",
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "LastGit keeps a checkout-backed recovery path until its own artifact producer and Forgejo-gated bootstrap path are proven."
      },
      "notes": "Delegates to LastGit's host refresh script."
    },
    {
      "app": "last-stack",
      "install_mode": "artifact",
      "kind": "artifact skill-pack",
      "command": "host-track",
      "gate": "lastgit",
      "gate_main": "lastdb:///last-stack#main",
      "artifact_app": "last-stack",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.local/state/last-stack/artifacts",
      "post_install": "$HOME/.local/state/last-stack/artifacts/current/setup",
      "links": [
        {
          "source": "bin/host-track",
          "target": "$HOME/.local/bin/host-track"
        }
      ],
      "notes": "Installs the exact LastGit CI artifact; compatibility paths under ~/.last-stack point through the active immutable bundle."
    },
    {
      "app": "brain",
      "install_mode": "checkout",
      "kind": "B checkout-shim",
      "command": "brain",
      "gate": "placeholder",
      "gate_main": "",
      "gate_remote": "",
      "gate_ref": "",
      "host_track": "$HOME/code/edgevector/brain",
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Brain is a temporary checkout shim until the artifact migration publishes and installs a verified Brain bundle."
      },
      "notes": "Placeholder until brain moves from workspace symlink to host track."
    },
    {
      "app": "situations",
      "install_mode": "checkout",
      "kind": "B checkout-shim",
      "command": "situations",
      "gate": "lastgit",
      "gate_main": "lastdb:///situations#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/situations",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-situations-host-track",
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Situations remains checkout-backed while the host-track artifact rollout migrates it to a verified bundle."
      },
      "notes": "Fast-forwards the situations host checkout from LastGit and exposes the PATH shim."
    },
    {
      "app": "kanban",
      "install_mode": "checkout",
      "kind": "B checkout-shim",
      "command": "kanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/fkanban",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-fkanban-host-track",
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "Kanban remains checkout-backed while the host-track artifact rollout migrates F-Kanban to a verified bundle."
      },
      "notes": "Kind B host-track checkout; PATH shims point into ~/.host-track/fkanban/bin."
    },
    {
      "app": "fkanban",
      "install_mode": "checkout",
      "kind": "B checkout-shim",
      "command": "fkanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "gate_remote": "lastgit",
      "gate_ref": "refs/heads/main",
      "host_track": "$HOME/.host-track/fkanban",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-fkanban-host-track",
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "Tom",
        "rationale": "F-Kanban remains checkout-backed while the host-track artifact rollout migrates it to a verified bundle."
      },
      "notes": "First-class alias for the F-Kanban CLI; shares the managed host-track checkout with kanban."
    }
  ]
}
