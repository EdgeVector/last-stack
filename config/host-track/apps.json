{
  "defaults": {
    "install_mode": "artifact",
    "artifact_channel": "stable",
    "artifact_root": "$HOME/.lastgit/artifacts"
  },
  "apps": [
    {
      "app": "lastgit",
      "install_mode": "checkout",
      "kind": "checkout-shim",
      "command": "lastgit",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/lastgit.git#main",
      "host_track": "$HOME/.lastgit/host-checkout/lastgit",
      "refresh": "$HOME/.lastgit/host-checkout/lastgit/.lastgit/refresh-host.sh",
      "artifact_app": "lastgit",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastgit",
      "links": [
        {
          "source": "dist/lastgit",
          "target": "$HOME/.local/bin/lastgit"
        },
        {
          "source": "dist/git-remote-lastdb",
          "target": "$HOME/.local/bin/git-remote-lastdb"
        }
      ],
      "artifact_exemption": {
        "kind": "bootstrap-recovery",
        "owner": "platform",
        "rationale": "LastGit remains checkout-backed so LastGit fixes can still be built when the artifact/CR substrate itself is unhealthy."
      },
      "notes": "LastGit is the bootstrap forge and stays checkout-backed until its artifact producer is independent of LastGit itself."
    },
    {
      "app": "last-stack",
      "install_mode": "artifact",
      "kind": "artifact skill-pack",
      "command": "host-track",
      "gate": "lastgit",
      "gate_main": "lastdb:///last-stack#main",
      "artifact_app": "last-stack",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.local/state/last-stack/artifacts",
      "post_install": "$HOME/.local/state/last-stack/artifacts/current/setup",
      "links": [
        {
          "source": "bin/host-track",
          "target": "$HOME/.local/bin/host-track"
        }
      ],
      "notes": "One rule: runtime is the Host Track CI artifact only. post_install activates ~/.last-stack/{bin,skills,routines,...} → .artifacts/current (immutable). Never develop in the install; use a worktree. Upgrade with: host-track refresh last-stack"
    },
    {
      "app": "brain",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "brain",
      "gate": "lastgit",
      "gate_main": "lastdb:///brain#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "brain",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/brain",
      "links": [
        {
          "source": "dist/brain",
          "target": "$HOME/.local/bin/brain"
        },
        {
          "source": "dist/fbrain",
          "target": "$HOME/.local/bin/fbrain"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli and PATH links brain/fbrain from the active version."
    },
    {
      "app": "situations",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "situations",
      "gate": "lastgit",
      "gate_main": "lastdb:///situations#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "situations",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/situations",
      "links": [
        {
          "source": "dist/situations",
          "target": "$HOME/.local/bin/situations"
        },
        {
          "source": "dist/fsituations",
          "target": "$HOME/.local/bin/fsituations"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli and PATH links situations/fsituations from the active version."
    },
    {
      "app": "kanban",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "kanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "fkanban",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/fkanban",
      "links": [
        {
          "source": "dist/kanban",
          "target": "$HOME/.local/bin/kanban"
        }
      ],
      "notes": "Local-safe compatibility CLI sharing the fkanban install root."
    },
    {
      "app": "fkanban",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "fkanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "fkanban",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/fkanban",
      "links": [
        {
          "source": "dist/fkanban",
          "target": "$HOME/.local/bin/fkanban"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli and also carries the kanban compatibility CLI."
    },
    {
      "app": "routines",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "routines",
      "gate": "lastgit",
      "gate_main": "lastdb:///routines#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "routines",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/routines",
      "links": [
        {
          "source": "dist/routines",
          "target": "$HOME/.local/bin/routines"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli."
    },
    {
      "app": "lastsecrets",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "lastsecrets",
      "gate": "lastgit",
      "gate_main": "lastdb:///lastsecrets#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "lastsecrets",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastsecrets",
      "links": [
        {
          "source": "dist/lastsecrets",
          "target": "$HOME/.local/bin/lastsecrets"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli."
    },
    {
      "app": "configurations",
      "install_mode": "local-safe",
      "kind": "local-safe cli",
      "command": "configurations",
      "gate": "lastgit",
      "gate_main": "lastdb:///configurations#main",
      "refresh": "$HOME/.last-stack/bin/last-stack-refresh-local-safe",
      "artifact_app": "configurations",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/configurations",
      "links": [
        {
          "source": "dist/configurations",
          "target": "$HOME/.local/bin/configurations"
        }
      ],
      "notes": "Local-safe CLI install; refresh uses last-stack-safe-upgrade-cli."
    },
    {
      "app": "lastdb",
      "install_mode": "checkout",
      "kind": "safe-upgrade-managed binary",
      "command": "lastdb",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdb",
          "target": "$HOME/.local/bin/lastdb"
        }
      ],
      "artifact_exemption": {
        "kind": "deployment-only",
        "owner": "platform",
        "rationale": "Live primary Mini activation is managed by lastdb-safe-upgrade and ~/.lastdb/current, not generic host-track artifact refresh."
      },
      "notes": "LastDB Mini is deployment-managed; live primary upgrades still require lastdb-safe-upgrade and must not be performed by Host Track refresh."
    },
    {
      "app": "lastdbd",
      "install_mode": "checkout",
      "kind": "safe-upgrade-managed binary",
      "command": "lastdbd",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdbd",
          "target": "$HOME/.local/bin/lastdbd"
        }
      ],
      "artifact_exemption": {
        "kind": "deployment-only",
        "owner": "platform",
        "rationale": "Live primary Mini daemon activation is managed by lastdb-safe-upgrade and ~/.lastdb/current, not generic host-track artifact refresh."
      },
      "notes": "LastDB Mini daemon is deployment-managed; activation of Tom's primary node remains lastdb-safe-upgrade only."
    }
  ]
}
