{
  "defaults": {
    "install_mode": "artifact",
    "artifact_channel": "stable",
    "artifact_root": "$HOME/.lastgit/artifacts"
  },
  "apps": [
    {
      "app": "lastgit",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastgit",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/lastgit.git#main",
      "artifact_app": "lastgit",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastgit",
      "links": [
        {
          "source": "dist/lastgit",
          "target": "$HOME/.local/bin/lastgit"
        },
        {
          "source": "dist/git-remote-lastdb",
          "target": "$HOME/.local/bin/git-remote-lastdb"
        }
      ],
      "notes": "Verified LastGit self-artifact install; keep source work in isolated repo worktrees, not the Host Track install tree."
    },
    {
      "app": "last-stack",
      "install_mode": "artifact",
      "kind": "artifact skill-pack",
      "command": "host-track",
      "gate": "lastgit",
      "gate_main": "lastdb:///last-stack#main",
      "artifact_app": "last-stack",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.local/state/last-stack/artifacts",
      "post_install": "$HOME/.local/state/last-stack/artifacts/current/setup",
      "links": [
        {
          "source": "bin/host-track",
          "target": "$HOME/.local/bin/host-track"
        }
      ],
      "notes": "One rule: runtime is the Host Track CI artifact only. post_install activates ~/.last-stack/{bin,skills,routines,...} → .artifacts/current (immutable). Never develop in the install; use a worktree. Upgrade with: host-track refresh last-stack"
    },
    {
      "app": "brain",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "brain",
      "gate": "lastgit",
      "gate_main": "lastdb:///brain#main",
      "artifact_app": "brain",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/brain",
      "links": [
        {
          "source": "dist/brain",
          "target": "$HOME/.local/bin/brain"
        },
        {
          "source": "dist/fbrain",
          "target": "$HOME/.local/bin/fbrain"
        }
      ],
      "notes": "Verified Brain artifact install. PATH links brain and fbrain from the same artifact."
    },
    {
      "app": "situations",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "situations",
      "gate": "lastgit",
      "gate_main": "lastdb:///situations#main",
      "artifact_app": "situations",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/situations",
      "links": [
        {
          "source": "dist/situations",
          "target": "$HOME/.local/bin/situations"
        },
        {
          "source": "dist/fsituations",
          "target": "$HOME/.local/bin/fsituations"
        }
      ],
      "notes": "Verified Situations artifact install. PATH links situations and fsituations from the same artifact."
    },
    {
      "app": "kanban",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "kanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "artifact_app": "fkanban",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/fkanban",
      "links": [
        {
          "source": "dist/kanban",
          "target": "$HOME/.local/bin/kanban"
        }
      ],
      "notes": "Shares the verified fkanban artifact bundle with fkanban."
    },
    {
      "app": "fkanban",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "fkanban",
      "gate": "lastgit",
      "gate_main": "lastdb:///fkanban#main",
      "artifact_app": "fkanban",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/fkanban",
      "links": [
        {
          "source": "dist/fkanban",
          "target": "$HOME/.local/bin/fkanban"
        }
      ],
      "notes": "Verified fkanban artifact install. The artifact also carries the kanban compatibility CLI."
    },
    {
      "app": "routines",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "routines",
      "gate": "lastgit",
      "gate_main": "lastdb:///routines#main",
      "artifact_app": "routines",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/routines",
      "links": [
        {
          "source": "dist/routines",
          "target": "$HOME/.local/bin/routines"
        }
      ],
      "notes": "Verified Routines artifact install."
    },
    {
      "app": "lastsecrets",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastsecrets",
      "gate": "lastgit",
      "gate_main": "lastdb:///lastsecrets#main",
      "artifact_app": "lastsecrets",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastsecrets",
      "links": [
        {
          "source": "dist/lastsecrets",
          "target": "$HOME/.local/bin/lastsecrets"
        }
      ],
      "notes": "Verified LastSecrets artifact install."
    },
    {
      "app": "configurations",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "configurations",
      "gate": "lastgit",
      "gate_main": "lastdb:///configurations#main",
      "artifact_app": "configurations",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/configurations",
      "links": [
        {
          "source": "dist/configurations",
          "target": "$HOME/.local/bin/configurations"
        }
      ],
      "notes": "Verified Configurations artifact install."
    },
    {
      "app": "lastdb",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastdb",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdb",
          "target": "$HOME/.local/bin/lastdb"
        }
      ],
      "notes": "Verified paired LastDB Mini bundle. Live primary upgrades still require lastdb-safe-upgrade; do not overwrite or restart ~/.lastdb directly from Host Track."
    },
    {
      "app": "lastdbd",
      "install_mode": "artifact",
      "kind": "artifact-bundle",
      "command": "lastdbd",
      "gate": "forgejo",
      "gate_main": "http://localhost:3300/EdgeVector/fold.git#main",
      "artifact_app": "lastdb-bundle",
      "artifact_channel": "stable",
      "artifact_root": "$HOME/.lastgit/artifacts",
      "install_root": "$HOME/.host-track/apps/lastdb-bundle",
      "links": [
        {
          "source": "bin/lastdbd",
          "target": "$HOME/.local/bin/lastdbd"
        }
      ],
      "notes": "Verified paired LastDB Mini daemon bundle. Activation of Tom's primary node remains lastdb-safe-upgrade only."
    }
  ]
}
